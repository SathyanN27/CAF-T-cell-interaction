def build_edge_matrix_from_row(row: pd.Series, motifs: List[str]) -> pd.DataFrame:
    """
    Build a symmetric motif x motif matrix from EDGE__MotifA__MotifB columns.
    Diagonal is NaN because self-edges are not used in this network definition.
    """
    M = pd.DataFrame(np.nan, index=motifs, columns=motifs, dtype=float)

    for i, a in enumerate(motifs):
        for j, b in enumerate(motifs):
            if i == j:
                M.loc[a, b] = np.nan
                continue
            x, y = sorted([a, b], key=motif_sort_key)
            col = f"EDGE__{x}__{y}"
            val = row.get(col, np.nan)
            M.loc[a, b] = float(val) if pd.notna(val) else np.nan

    return M

def aggregate_group_edge_matrix(df: pd.DataFrame,
                                motifs: List[str],
                                group_col: Optional[str] = None,
                                group_value: Optional[str] = None,
                                stat: str = "median") -> pd.DataFrame:
    """
    Aggregate patient-level edge features into one symmetric motif x motif matrix.
    """
    use = df.copy()
    if group_col is not None and group_value is not None:
        use = use[use[group_col].astype(str) == str(group_value)].copy()

    edge_cols = [c for c in use.columns if c.startswith("EDGE__")]
    if len(use) == 0 or len(edge_cols) == 0:
        return pd.DataFrame(np.nan, index=motifs, columns=motifs)

    if stat == "mean":
        agg_row = use[edge_cols].mean(numeric_only=True)
    else:
        agg_row = use[edge_cols].median(numeric_only=True)

    return build_edge_matrix_from_row(agg_row, motifs)

def save_edge_matrix_csv(mat: pd.DataFrame, out_csv: Path):
    mat.to_csv(out_csv, index=True)

def shared_heatmap_limits(mats: List[pd.DataFrame]) -> Tuple[Optional[float], Optional[float]]:
    vals = []
    for mat in mats:
        if mat is None or mat.empty:
            continue
        x = mat.values[np.isfinite(mat.values)]
        if x.size:
            vals.append(x)

    if not vals:
        return None, None

    all_vals = np.concatenate(vals)
    return float(np.nanmin(all_vals)), float(np.nanmax(all_vals))

def plot_triangle_heatmap(mat: pd.DataFrame,
                          out_png: Path,
                          title: str,
                          cmap: str = "mako",
                          vmin: Optional[float] = None,
                          vmax: Optional[float] = None,
