def aggregate_core_level(theta_all: np.ndarray, cell_meta: pd.DataFrame) -> pd.DataFrame:
    motifs = [f"Motif{t+1}" for t in range(theta_all.shape[1])]
    df = cell_meta.copy()

    for t, m in enumerate(motifs):
        df[m] = theta_all[:, t]

    dom = assign_dominant_neighbourhood(
        theta_all=theta_all,
        is_isolated=df["is_isolated"].astype(bool).values,
        dominance_threshold=DOMINANCE_THRESHOLD
    )
    df["Dominant_Class"] = dom["Dominant_Neighbourhood"].values

    df[PAT_COL] = df[PAT_COL].astype(str).str.strip()
    df[CORE_COL] = df[CORE_COL].astype(str).str.strip()
    df[ROI_COL] = df[ROI_COL].astype(str).str.strip()
    df["main_type_lc"] = df["main_type_lc"].astype(str).str.strip().str.lower()
    df["is_informative"] = ~df["is_isolated"].astype(bool)

    classes = motifs + [ISOLATED_LABEL]
    if DOMINANCE_THRESHOLD is not None:
        classes = motifs + [MIXED_LABEL, ISOLATED_LABEL]

    core_rows = []

    for (pid, rid), sub in df.groupby([PAT_COL, ROI_COL], sort=False):
        inf = sub[sub["is_informative"]].copy()

        row = {
            PAT_COL: pid,
            ROI_COL: rid,
            CORE_COL: str(sub[CORE_COL].iloc[0]),
            BLOCK_COL: str(sub[BLOCK_COL].iloc[0]),
            "n_cells_core": int(len(sub)),
            "n_informative_core": int(len(inf)),
            "n_isolated_core": int(sub["is_isolated"].sum()),
            "frac_isolated_core": float(sub["is_isolated"].mean()) if len(sub) else np.nan,
            "median_neigh_count_core": float(np.median(sub["neigh_count"].astype(float))) if len(sub) else np.nan,
            "median_neigh_count_informative_core": float(np.median(inf["neigh_count"].astype(float))) if len(inf) else np.nan,
        }

        for m in motifs:
            row[f"GLOBAL__{m}"] = float(inf[m].mean()) if len(inf) else np.nan

        for comp_name, comp_mask in [
            ("TUMOUR", sub["main_type_lc"].eq("tumour")),
            ("CAF", sub["main_type_lc"].eq("caf")),
            ("IMMUNE", sub["main_type_lc"].eq("immune")),
        ]:
            comp = sub[comp_mask].copy()
            comp_inf = comp[comp["is_informative"]].copy()

            row[f"{comp_name}__n_cells"] = int(len(comp))
            row[f"{comp_name}__n_informative"] = int(len(comp_inf))
            row[f"{comp_name}__n_isolated"] = int(comp["is_isolated"].sum())
            row[f"{comp_name}__frac_isolated"] = float(comp["is_isolated"].mean()) if len(comp) else np.nan

            for m in motifs:
                row[f"{comp_name}__{m}"] = float(comp_inf[m].mean()) if len(comp_inf) else np.nan

        for cls in classes:
            row[f"DOMPROP__{cls}"] = float((sub["Dominant_Class"] == cls).mean()) if len(sub) else np.nan

        if len(inf):
            for m in motifs:
                row[f"DOMPROP_INF__{m}"] = float((inf["Dominant_Class"] == m).mean())
        else:
            for m in motifs:
                row[f"DOMPROP_INF__{m}"] = np.nan

        core_rows.append(row)

    core_feat = pd.DataFrame(core_rows)
    core_feat.to_csv(DIRS["04_core_level"] / "core_level_LDA_motif_burdens.csv", index=False)

    idx = (
        core_feat.groupby(PAT_COL)
        .agg(
            n_cores=(ROI_COL, "nunique"),
            n_cells=("n_cells_core", "sum"),
            n_informative=("n_informative_core", "sum"),
            n_isolated=("n_isolated_core", "sum"),
        )
        .reset_index()
    )
    idx.to_csv(DIRS["04_core_level"] / "patient_core_counts_and_cells.csv", index=False)

    return core_feat

def patient_core_median(core_feat: pd.DataFrame) -> pd.DataFrame:
    numeric_cols = core_feat.select_dtypes(include=[np.number]).columns.tolist()

    pat_med = (
        core_feat.groupby(PAT_COL, as_index=False)[numeric_cols]
        .median()
    )

    totals = (
        core_feat.groupby(PAT_COL, as_index=False)
        .agg(
            n_cores=(ROI_COL, "nunique"),
            n_cells_patient_total=("n_cells_core", "sum"),
            n_informative_patient_total=("n_informative_core", "sum"),
            n_isolated_patient_total=("n_isolated_core", "sum"),
        )
    )
    totals["frac_isolated_patient_total"] = (
        totals["n_isolated_patient_total"] / (totals["n_cells_patient_total"] + EPS)
    )

    out = totals.merge(pat_med, on=PAT_COL, how="left")
    out.to_csv(DIRS["05_patient_level"] / "patient_level_LDA_core_median.csv", index=False)
    return out

def weighted_mean_from_core_table(sub: pd.DataFrame, value_col: str, weight_col: str) -> float:
    if value_col not in sub.columns or weight_col not in sub.columns:
        return np.nan

    x = pd.to_numeric(sub[value_col], errors="coerce").astype(float).values
    w = pd.to_numeric(sub[weight_col], errors="coerce").fillna(0).astype(float).values
    mask = np.isfinite(x) & np.isfinite(w) & (w > 0)

    if not np.any(mask):
        return np.nan
    return float(np.sum(x[mask] * w[mask]) / (np.sum(w[mask]) + EPS))

def patient_informative_weighted(core_feat: pd.DataFrame) -> pd.DataFrame:
    motifs = sorted(
        {c.split("__")[-1] for c in core_feat.columns if c.startswith("GLOBAL__Motif")},
        key=motif_sort_key
    )
    patients = sorted(core_feat[PAT_COL].astype(str).unique().tolist())
    rows = []

    for pid in patients:
        sub = core_feat[core_feat[PAT_COL].astype(str) == pid].copy()
        row = {
            PAT_COL: pid,
            "n_cores": int(sub[ROI_COL].nunique()),
            "GLOBAL_W__n_informative_total": float(sub["n_informative_core"].sum()),
            "GLOBAL_W__n_isolated_total": float(sub["n_isolated_core"].sum()),
            "GLOBAL_W__frac_isolated": float(sub["n_isolated_core"].sum() / (sub["n_cells_core"].sum() + EPS)),
        }

        for m in motifs:
            row[f"GLOBAL_W__{m}"] = weighted_mean_from_core_table(sub, f"GLOBAL__{m}", "n_informative_core")

        for comp in ["TUMOUR", "CAF", "IMMUNE"]:
            wcol = f"{comp}__n_informative"
            row[f"{comp}_W__n_informative_total"] = float(sub[wcol].sum()) if wcol in sub.columns else 0.0
            for m in motifs:
                row[f"{comp}_W__{m}"] = weighted_mean_from_core_table(sub, f"{comp}__{m}", wcol)

        rows.append(row)

    out = pd.DataFrame(rows)
    out.to_csv(DIRS["05_patient_level"] / "patient_level_LDA_informative_weighted.csv", index=False)
    return out


