def fit_final_lda(X_fit: sparse.csr_matrix, vocab: List[str], n_topics: int) -> Tuple[LatentDirichletAllocation, np.ndarray, pd.DataFrame]:
    print(f"[LDA] final fit on informative docs only: n_docs={X_fit.shape[0]:,}, n_vocab={X_fit.shape[1]:,}, K={n_topics}")

    lda = LatentDirichletAllocation(
        n_components=n_topics,
        learning_method=LDA_LEARNING_METHOD,
        max_iter=LDA_MAX_ITER,
        random_state=RANDOM_SEED,
        doc_topic_prior=LDA_DOC_PRIOR,
        topic_word_prior=LDA_TOPIC_PRIOR,
        evaluate_every=0,
        verbose=0,
    )
    theta_fit = lda.fit_transform(X_fit)

    motifs = [f"Motif{t+1}" for t in range(n_topics)]
    beta = topic_beta(lda)
    beta_df = pd.DataFrame(beta, columns=vocab, index=motifs)

    beta_df.to_csv(DIRS["03_lda"] / "LDA_beta_topic_compositions.csv")
    np.save(DIRS["03_lda"] / "LDA_theta_informative_cells.npy", theta_fit)
    sparse.save_npz(DIRS["03_lda"] / "X_docs_sparse_counts_informative_cells.npz", X_fit)

    plt.figure(figsize=(max(10, 0.25 * len(vocab)), max(5, 0.35 * n_topics + 2)))
    sns.heatmap(beta_df, cmap="mako", linewidths=0.2, linecolor="lightgrey")
    plt.title("Spatial-LDA motif compositions (beta): label probability per motif")
    plt.tight_layout()
    plt.savefig(DIRS["07_figures"] / "LDA_beta_heatmap.png", dpi=300)
    plt.close()

    lines = []
    topn = 12
    for m in motifs:
        row = beta_df.loc[m].sort_values(ascending=False)
        tops = row.head(topn)
        lines.append(f"{m}: " + ", ".join([f"{k}({v:.3f})" for k, v in tops.items()]))

        plt.figure(figsize=(7, 3.8))
        tops.sort_values(ascending=True).plot(kind="barh")
        plt.title(f"{m} — top labels (beta)")
        plt.xlabel("Probability")
        plt.tight_layout()
        plt.savefig(DIRS["07_figures"] / f"{m}_top_labels.png", dpi=300)
        plt.close()

    (DIRS["03_lda"] / "LDA_topic_top_labels.txt").write_text("\n".join(lines) + "\n")
    return lda, theta_fit, beta_df

def expand_theta_to_all_cells(theta_fit: np.ndarray, fit_mask: np.ndarray) -> np.ndarray:
    n_all = len(fit_mask)
    k = theta_fit.shape[1]
    theta_all = np.full((n_all, k), np.nan, dtype=float)
    theta_all[fit_mask] = theta_fit
    np.save(DIRS["03_lda"] / "LDA_theta_all_cells_nan_for_isolated.npy", theta_all)
    return theta_all

def assign_dominant_neighbourhood(theta_all: np.ndarray,
                                  is_isolated: np.ndarray,
                                  dominance_threshold: Optional[float] = None) -> pd.DataFrame:
    motifs = [f"Motif{t+1}" for t in range(theta_all.shape[1])]
    out = pd.DataFrame(index=np.arange(len(is_isolated)))
    out["Dominant_Neighbourhood"] = ISOLATED_LABEL
    out["Dominant_Theta"] = np.nan

    inf_mask = ~is_isolated.astype(bool)
    if np.any(inf_mask):
        T = theta_all[inf_mask]
        idx = np.argmax(T, axis=1)
        mx = np.max(T, axis=1)
        labs = np.array(motifs, dtype=object)[idx]

        if dominance_threshold is not None:
            labs = np.where(mx >= dominance_threshold, labs, MIXED_LABEL)

        out.loc[inf_mask, "Dominant_Neighbourhood"] = labs
        out.loc[inf_mask, "Dominant_Theta"] = mx

    return out

def save_cell_assignments(theta_all: np.ndarray, cell_meta: pd.DataFrame) -> pd.DataFrame:
    motifs = [f"Motif{t+1}" for t in range(theta_all.shape[1])]
    df = cell_meta.copy()

    for t, m in enumerate(motifs):
        df[m] = theta_all[:, t]

    dom = assign_dominant_neighbourhood(
        theta_all=theta_all,
        is_isolated=df["is_isolated"].astype(bool).values,
        dominance_threshold=DOMINANCE_THRESHOLD
    )
    df["Dominant_Class"] = dom["Dominant_Neighbourhood"].values
    df["Dominant_Class_Weight"] = dom["Dominant_Theta"].values

    df.to_csv(DIRS["03_lda"] / "cell_assignments_all_cells.csv.gz", index=False, compression="gzip")

    counts = df["Dominant_Class"].value_counts(dropna=False).rename_axis("class").reset_index(name="n_cells")
    counts.to_csv(DIRS["03_lda"] / "cell_assignment_counts.csv", index=False)
    return df


