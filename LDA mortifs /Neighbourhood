def clean_label_series(s: pd.Series) -> pd.Series:
    x = s.astype(str).str.strip().str.replace(r"\s+", " ", regex=True)
    low = x.str.lower()
    mapped = low.map(LABEL_ALIASES)
    out = mapped.fillna(x)
    out = out.replace({"nan": np.nan, "": np.nan, "None": np.nan})
    return out

