        how="inner"
    ).copy()

    # Include both relative composition and burden/count features
    test_cols = [
        c for c in df.columns
        if (
            c.startswith("NODE__")
            or c.startswith("EDGE__")
            or c.startswith("NPATCH__")
            or c.startswith("EDGECOUNT__")
            or "n_patch_contacts" in c
            or "n_patches" in c
            or "n_retained_patch_cells" in c
            or "frac_informative_cells_in_retained_patches" in c
        )
    ]

    rows = []
    for col in test_cols:
        groups = []
        group_names = []
        for grp in SURV_GROUP_ORDER:
            vals = df[df[SURV_GROUP_NAME].astype(str) == grp][col].dropna().astype(float)
            if len(vals) > 0:
                groups.append(vals.values)
                group_names.append(grp)

