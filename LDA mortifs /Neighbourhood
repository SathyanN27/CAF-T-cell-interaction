def topic_beta(lda: LatentDirichletAllocation) -> np.ndarray:
    beta = lda.components_.astype(float)
    beta = beta / (beta.sum(axis=1, keepdims=True) + EPS)
    return beta

def cosine_sim_matrix(A: np.ndarray) -> np.ndarray:
    n = np.linalg.norm(A, axis=1, keepdims=True) + EPS
    An = A / n
    return An @ An.T

def topic_redundancy(beta: np.ndarray) -> float:
    S = cosine_sim_matrix(beta)
    k = S.shape[0]
    mask = ~np.eye(k, dtype=bool)
    return float(np.mean(S[mask])) if k > 1 else 0.0

def stability_hungarian(beta_a: np.ndarray, beta_b: np.ndarray) -> float:
    Sa = beta_a / (np.linalg.norm(beta_a, axis=1, keepdims=True) + EPS)
    Sb = beta_b / (np.linalg.norm(beta_b, axis=1, keepdims=True) + EPS)
    sim = Sa @ Sb.T
    cost = 1.0 - sim
    r, c = linear_sum_assignment(cost)
    return float(np.mean(sim[r, c]))

def minmax_scale(x: np.ndarray, invert: bool = False) -> np.ndarray:
    x = np.asarray(x, dtype=float)
    if np.all(~np.isfinite(x)) or np.nanmax(x) - np.nanmin(x) < 1e-12:
        out = np.zeros_like(x)
    else:
        out = (x - np.nanmin(x)) / (np.nanmax(x) - np.nanmin(x) + EPS)
    return 1.0 - out if invert else out

def fit_lda(X_train: sparse.csr_matrix, n_topics: int, seed: int) -> LatentDirichletAllocation:
    lda = LatentDirichletAllocation(
        n_components=n_topics,
        learning_method=LDA_LEARNING_METHOD,
        max_iter=LDA_MAX_ITER,
        random_state=seed,
        doc_topic_prior=LDA_DOC_PRIOR,
        topic_word_prior=LDA_TOPIC_PRIOR,
        evaluate_every=0,
        verbose=0,
    )
    lda.fit(X_train)
    return lda

def select_k_via_sweep(X: sparse.csr_matrix, cell_meta: pd.DataFrame) -> int:
    roi_ids = cell_meta[ROI_COL].astype(str).unique().tolist()

    if len(roi_ids) < 4:
        fallback_k = min(10, max(2, min(X.shape[0] - 1, X.shape[1])))
        fallback_k = int(max(2, fallback_k))
        (DIRS["02_k_sweep"] / "K_SWEEP_SKIPPED.txt").write_text(
            f"Too few informative ROIs for K-sweep ({len(roi_ids)} ROIs). Using fallback K={fallback_k}.\n"
        )
        print(f"[K-sweep] skipped (too few informative ROIs); using K={fallback_k}")
        return fallback_k

    tr_rois, te_rois = train_test_split(roi_ids, test_size=KSWEEP_TEST_SIZE, random_state=RANDOM_SEED)

    tr_mask = cell_meta[ROI_COL].astype(str).isin(tr_rois).values
    te_mask = ~tr_mask

    X_train = X[tr_mask]
    X_test  = X[te_mask]

    max_valid_k = max(2, min(X_train.shape[0] - 1, X_train.shape[1]))
    k_list = [k for k in K_SWEEP if 2 <= k <= max_valid_k]
    if not k_list:
        k_list = [max_valid_k]

    report_rows = []
    print(f"[K-sweep] train ROIs={len(tr_rois):,} test ROIs={len(te_rois):,} | train docs={X_train.shape[0]:,} test docs={X_test.shape[0]:,}")
    print(f"[K-sweep] evaluating K values: {k_list}")

    for K in k_list:
        print(f"  [K-sweep] K={K} ...")
        lda_a = fit_lda(X_train, n_topics=K, seed=KSWEEP_STABILITY_SEEDS[0])
        lda_b = fit_lda(X_train, n_topics=K, seed=KSWEEP_STABILITY_SEEDS[1])

        perp = float(lda_a.perplexity(X_test)) if X_test.shape[0] > 0 else np.nan
        beta_a = topic_beta(lda_a)
        beta_b = topic_beta(lda_b)

        stab = stability_hungarian(beta_a, beta_b)
        red  = topic_redundancy(beta_a)
        sep  = 1.0 - red

        report_rows.append({
            "K": K,
            "heldout_perplexity": perp,
            "stability_mean_cosine": stab,
            "redundancy_mean_cosine": red,
            "separation_1_minus_redundancy": sep,
        })

    rep = pd.DataFrame(report_rows)
    rep.to_csv(DIRS["02_k_sweep"] / "K_sweep_report.csv", index=False)

    s_perp = minmax_scale(rep["heldout_perplexity"].values, invert=True)
    s_stab = minmax_scale(rep["stability_mean_cosine"].values, invert=False)
    s_sep  = minmax_scale(rep["separation_1_minus_redundancy"].values, invert=False)

    w = KSWEEP_SCORE_WEIGHTS
    rep["score"] = w["perplexity"] * s_perp + w["stability"] * s_stab + w["separation"] * s_sep
    rep["score_perplexity_scaled"] = s_perp
    rep["score_stability_scaled"] = s_stab
    rep["score_separation_scaled"] = s_sep
    rep.to_csv(DIRS["02_k_sweep"] / "K_sweep_report_with_scores.csv", index=False)

    for ycol, title, fname in [
        ("heldout_perplexity", "Held-out perplexity vs K (lower is better)", "K_sweep_perplexity.png"),
        ("stability_mean_cosine", "Stability vs K (higher is better)", "K_sweep_stability.png"),
        ("separation_1_minus_redundancy", "Separation vs K (higher is better)", "K_sweep_separation.png"),
        ("score", "Overall K-sweep score (higher is better)", "K_sweep_overall_score.png"),
    ]:
        plt.figure(figsize=(8, 4.5))
        plt.plot(rep["K"], rep[ycol], marker="o")
        plt.title(title)
        plt.xlabel("K topics")
        plt.ylabel(ycol)
        plt.tight_layout()
        plt.savefig(DIRS["02_k_sweep"] / fname, dpi=300)
        plt.close()

    best = rep.sort_values(
        ["score", "stability_mean_cosine", "separation_1_minus_redundancy"],
        ascending=[False, False, False]
    ).iloc[0]
    bestK = int(best["K"])

    (DIRS["02_k_sweep"] / "K_SELECTED.txt").write_text(
        f"Selected K = {bestK}\n\n{best.to_string()}\n"
    )
    print(f"[K-sweep] selected K={bestK}")
    return bestK


