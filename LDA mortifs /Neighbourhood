    Lower-triangle heatmap of a symmetric interaction matrix.
    """
    if mat.empty:
        (out_png.with_suffix(".txt")).write_text("No matrix available.\n")
        return

    plot_mat = mat.copy()
    mask = np.triu(np.ones_like(plot_mat, dtype=bool), k=0)

    fig_w = max(8, 0.45 * len(plot_mat.columns) + 3)
    fig_h = max(7, 0.42 * len(plot_mat.index) + 2)

    plt.figure(figsize=(fig_w, fig_h))
    sns.heatmap(
        plot_mat,
        mask=mask,
        cmap=cmap,
        square=True,
        linewidths=0.3,
        linecolor="lightgrey",
        cbar_kws={"shrink": 0.8, "label": "Interaction strength"},
        vmin=vmin,
        vmax=vmax,
        annot=annot,
        fmt=".2f"
    )
    plt.title(title)
    plt.xlabel("")
    plt.ylabel("")
    plt.xticks(rotation=45, ha="right")
    plt.yticks(rotation=0)
    plt.tight_layout()
    plt.savefig(out_png, dpi=300, bbox_inches="tight")
    plt.close()

def plot_triangle_heatmap_diff(mat_a: pd.DataFrame,
                               mat_b: pd.DataFrame,
                               out_png: Path,
                               title: str,
                               cmap: str = "coolwarm",
                               annot: bool = False):
    """
    Lower-triangle heatmap of matrix difference: mat_a - mat_b
    """
    if mat_a.empty or mat_b.empty:
        (out_png.with_suffix(".txt")).write_text("No matrices available for difference heatmap.\n")
        return

    diff = mat_a - mat_b
    finite_vals = diff.values[np.isfinite(diff.values)]
    vmax = float(np.nanmax(np.abs(finite_vals))) if finite_vals.size else 1.0
    vmax = max(vmax, 1e-6)

    mask = np.triu(np.ones_like(diff, dtype=bool), k=0)

    fig_w = max(8, 0.45 * len(diff.columns) + 3)
    fig_h = max(7, 0.42 * len(diff.index) + 2)

    plt.figure(figsize=(fig_w, fig_h))
    sns.heatmap(
        diff,
        mask=mask,
        cmap=cmap,
        square=True,
        linewidths=0.3,
        linecolor="lightgrey",
        cbar_kws={"shrink": 0.8, "label": "Difference in interaction strength"},
        vmin=-vmax,
        vmax=vmax,
        center=0,
        annot=annot,
        fmt=".2f"
    )
