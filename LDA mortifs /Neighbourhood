def safe_name(x) -> str:
    return re.sub(r"[^A-Za-z0-9]+", "_", str(x)).strip("_")

def to_num(s):
    return pd.to_numeric(s, errors="coerce")

def zscore(s: pd.Series) -> pd.Series:
    s = s.astype(float)
    return (s - s.mean()) / (s.std(ddof=0) + EPS)

def bh_fdr(pvals: pd.Series) -> pd.Series:
    p = pvals.astype(float).values
    n = len(p)
    if n == 0:
        return pd.Series(dtype=float)

    order = np.argsort(p)
    ranks = np.empty(n, dtype=int)
    ranks[order] = np.arange(1, n + 1)
    q = p * n / np.maximum(ranks, 1)

    q_sorted = q[order]
    q_sorted = np.minimum.accumulate(q_sorted[::-1])[::-1]

    out = np.empty(n, dtype=float)
    out[order] = np.clip(q_sorted, 0, 1)
    return pd.Series(out, index=pvals.index)

def motif_sort_key(x):
    m = re.search(r"Motif(\d+)$", str(x))
    return int(m.group(1)) if m else 10**9

