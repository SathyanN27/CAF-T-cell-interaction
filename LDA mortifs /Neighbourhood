def connected_components_radius(coords: np.ndarray, radius: float) -> List[np.ndarray]:
    n = len(coords)
    if n == 0:
        return []

    parent = np.arange(n, dtype=int)
    rank = np.zeros(n, dtype=int)

    def find(x):
        while parent[x] != x:
            parent[x] = parent[parent[x]]
            x = parent[x]
        return x

    def union(a, b):
        ra, rb = find(a), find(b)
        if ra == rb:
            return
        if rank[ra] < rank[rb]:
            parent[ra] = rb
        elif rank[ra] > rank[rb]:
            parent[rb] = ra
        else:
            parent[rb] = ra
            rank[ra] += 1

    tree = cKDTree(coords)
    for a, b in tree.query_pairs(r=float(radius)):
        union(int(a), int(b))

    groups: Dict[int, List[int]] = {}
    for i in range(n):
        r = find(i)
        groups.setdefault(r, []).append(i)

    return [np.array(v, dtype=int) for v in groups.values()]

def min_distance_between_coords(coords_a: np.ndarray, coords_b: np.ndarray) -> float:
    if len(coords_a) == 0 or len(coords_b) == 0:
        return np.inf
    if len(coords_a) <= len(coords_b):
        tree = cKDTree(coords_b)
        d, _ = tree.query(coords_a, k=1)
        return float(np.min(d))
    else:
        tree = cKDTree(coords_a)
        d, _ = tree.query(coords_b, k=1)
        return float(np.min(d))

def build_neighbourhood_patch_networks(theta_all: np.ndarray, cell_meta: pd.DataFrame) -> pd.DataFrame:
    motifs = [f"Motif{t+1}" for t in range(theta_all.shape[1])]

    df = cell_meta.copy()
    dom = assign_dominant_neighbourhood(
        theta_all=theta_all,
        is_isolated=df["is_isolated"].astype(bool).values,
        dominance_threshold=DOMINANCE_THRESHOLD
    )
    df["Dominant_Class"] = dom["Dominant_Neighbourhood"].values

    # informative motif-labelled cells only
    valid_classes = set(motifs)
    df = df[df["Dominant_Class"].isin(valid_classes)].copy()

    edge_pairs = [(motifs[i], motifs[j]) for i in range(len(motifs)) for j in range(i + 1, len(motifs))]
    rows = []

    for (pid, rid), sub in df.groupby([PAT_COL, ROI_COL], sort=False):
        roi_total_inf_cells = int(len(sub))

        row = {
            PAT_COL: str(pid),
            ROI_COL: str(rid),
            CORE_COL: str(sub[CORE_COL].iloc[0]),
            BLOCK_COL: str(sub[BLOCK_COL].iloc[0]),
            "n_informative_cells_roi": roi_total_inf_cells,
            "n_retained_patch_cells_roi": 0,
            "n_patches_roi": 0,
            "n_patch_contacts_roi": 0,
            "frac_informative_cells_in_retained_patches": np.nan,
        }

        for m in motifs:
            row[f"NODE__{m}"] = 0.0
            row[f"NPATCH__{m}"] = 0.0

        for a, b in edge_pairs:
            row[f"EDGE__{a}__{b}"] = np.nan
            row[f"EDGECOUNT__{a}__{b}"] = np.nan

        patches = []
        patch_id = 0

        for m in motifs:
            sm = sub[sub["Dominant_Class"] == m].copy()
            if sm.empty:
                continue

            coords = sm[[X_COL, Y_COL]].to_numpy(float)
            comps = connected_components_radius(coords, PATCH_RADIUS_UM)

            kept = [comp for comp in comps if len(comp) >= PATCH_MIN_CELLS]
            row[f"NPATCH__{m}"] = float(len(kept))

            for comp in kept:
                comp_df = sm.iloc[comp].copy()
                patch_coords = comp_df[[X_COL, Y_COL]].to_numpy(float)
                patch = {
                    "patch_id": patch_id,
                    "motif": m,
                    "n_cells": int(len(comp_df)),
                    "coords": patch_coords,
                }
                patches.append(patch)
                patch_id += 1
                row[f"NODE__{m}"] += int(len(comp_df))

        row["n_patches_roi"] = int(len(patches))
        row["n_retained_patch_cells_roi"] = int(sum(p["n_cells"] for p in patches))
        row["frac_informative_cells_in_retained_patches"] = (
            row["n_retained_patch_cells_roi"] / (roi_total_inf_cells + EPS)
            if roi_total_inf_cells > 0 else np.nan
        )

        # node burden as fraction of informative cells in ROI
        for m in motifs:
            row[f"NODE__{m}"] = float(row[f"NODE__{m}"] / (roi_total_inf_cells + EPS))

        if len(patches) < 2:
            rows.append(row)
            continue

        edge_weight_map = {f"EDGE__{a}__{b}": 0.0 for a, b in edge_pairs}
        edge_count_map = {f"EDGECOUNT__{a}__{b}": 0 for a, b in edge_pairs}
        total_weight = 0.0
        total_contacts = 0

        for i in range(len(patches)):
            pi = patches[i]
            for j in range(i + 1, len(patches)):
                pj = patches[j]

                if pi["motif"] == pj["motif"]:
                    continue

                dmin = min_distance_between_coords(pi["coords"], pj["coords"])
                if not np.isfinite(dmin) or dmin > PATCH_INTERACT_RADIUS_UM:
                    continue

                a, b = sorted([pi["motif"], pj["motif"]], key=motif_sort_key)
                edge_col = f"EDGE__{a}__{b}"
                edgecount_col = f"EDGECOUNT__{a}__{b}"

                # closer patch contacts contribute more
                w = max(0.0, 1.0 - (dmin / PATCH_INTERACT_RADIUS_UM))

                edge_weight_map[edge_col] += float(w)
                edge_count_map[edgecount_col] += 1
                total_weight += float(w)
                total_contacts += 1

        row["n_patch_contacts_roi"] = int(total_contacts)

        if total_contacts > 0 and total_weight > 0:
            for k, v in edge_weight_map.items():
                row[k] = float(v / (total_weight + EPS))
            for k, v in edge_count_map.items():
                row[k] = float(v)
        else:
            for k in edge_weight_map.keys():
                row[k] = np.nan
            for k in edge_count_map.keys():
                row[k] = 0.0

        rows.append(row)

    out = pd.DataFrame(rows)
    out.to_csv(DIRS["04_core_level"] / "core_level_neighbourhood_patch_networks.csv", index=False)
    return out

