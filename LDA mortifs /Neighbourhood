    if len(motifs) < 2:
        (outdir / "TOO_FEW_MOTIFS.txt").write_text("Need at least 2 motifs for triangle heatmaps.\n")
        return

    group_order = [g for g in SURV_GROUP_ORDER if g in df[SURV_GROUP_NAME].astype(str).unique().tolist()]
    if not group_order:
        group_order = sorted(df[SURV_GROUP_NAME].astype(str).unique().tolist())

    # Overall matrix
    overall_mat = aggregate_group_edge_matrix(
        df=df,
        motifs=motifs,
        group_col=None,
        group_value=None,
        stat=NETWORK_HEATMAP_STAT
    )
    save_edge_matrix_csv(overall_mat, outdir / "Neighbourhood_network_OVERALL_matrix.csv")

    # Per-survival-group matrices
    group_mats = {}
    group_ns = {}
    for grp in group_order:
        sub = df[df[SURV_GROUP_NAME].astype(str) == str(grp)].copy()
        if len(sub) < NETWORK_MIN_GROUP_N:
            continue

        mat = aggregate_group_edge_matrix(
            df=df,
            motifs=motifs,
            group_col=SURV_GROUP_NAME,
            group_value=grp,
            stat=NETWORK_HEATMAP_STAT
        )
        group_mats[grp] = mat
        group_ns[grp] = len(sub)

        save_edge_matrix_csv(mat, outdir / f"Neighbourhood_network_{safe_name(grp)}_matrix.csv")

    # Shared colour scale across survival-group heatmaps
    vmin_shared, vmax_shared = shared_heatmap_limits(list(group_mats.values()))

    # Overall heatmap uses its own scale
    plot_triangle_heatmap(
        overall_mat,
        out_png=outdir / "Neighbourhood_network_OVERALL_triangle_heatmap.png",
        title=f"Overall neighbourhood interaction matrix ({NETWORK_HEATMAP_STAT} across patients)",
        cmap=NETWORK_HEATMAP_CMAP
    )

    # Group heatmaps use shared scale
    for grp in group_order:
        if grp not in group_mats:
            continue

        plot_triangle_heatmap(
            group_mats[grp],
            out_png=outdir / f"Neighbourhood_network_{safe_name(grp)}_triangle_heatmap.png",
            title=f"{grp} survival neighbourhood interaction matrix ({NETWORK_HEATMAP_STAT}; n={group_ns[grp]})",
            cmap=NETWORK_HEATMAP_CMAP,
            vmin=vmin_shared,
            vmax=vmax_shared
        )

    # Save shared scale for reference
    pd.DataFrame({
        "shared_vmin": [vmin_shared],
        "shared_vmax": [vmax_shared],
        "stat": [NETWORK_HEATMAP_STAT]
    }).to_csv(outdir / "Neighbourhood_network_group_heatmap_shared_scale.csv", index=False)

    # Difference heatmaps
    diff_pairs = [
        ("Short", "Long"),
        ("Short", "Intermediate"),
        ("Intermediate", "Long"),
    ]
    for a, b in diff_pairs:
        if a in group_mats and b in group_mats:
            plot_triangle_heatmap_diff(
                group_mats[a],
                group_mats[b],
                out_png=outdir / f"Neighbourhood_network_DIFF_{safe_name(a)}_minus_{safe_name(b)}.png",
                title=f"Neighbourhood interaction difference: {a} minus {b}",
                cmap=NETWORK_DIFF_CMAP
            )


