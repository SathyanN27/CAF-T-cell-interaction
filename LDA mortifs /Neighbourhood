def hybrid_neigh_indices(coords_um: np.ndarray, k: int, r_um: float) -> List[np.ndarray]:
    n = coords_um.shape[0]
    if n == 0:
        return []

    tree = cKDTree(coords_um)
    nbr_lists = tree.query_ball_point(coords_um, r=float(r_um))

    out = []
    for i, nbrs in enumerate(nbr_lists):
        nbrs2 = [j for j in nbrs if j != i]
        if not nbrs2:
            out.append(np.array([], dtype=int))
            continue

        nbrs2 = np.array(nbrs2, dtype=int)
        if nbrs2.size <= k:
            out.append(nbrs2)
            continue

        d = np.sqrt(((coords_um[nbrs2] - coords_um[i]) ** 2).sum(axis=1))
        sel = np.argsort(d)[:k]
        out.append(nbrs2[sel])

    return out

def build_docs_sparse(cells: pd.DataFrame, vocab: List[str]) -> Tuple[sparse.csr_matrix, pd.DataFrame]:
    vocab_index = {v: i for i, v in enumerate(vocab)}

    roi_ids = list(cells[ROI_COL].astype(str).unique())
    print(f"[docs] hybrid kNN-within-radius: k={K_NEIGHBORS}, R={RADIUS_UM} µm | ROIs={len(roi_ids):,} | vocab={len(vocab):,}")

    data = []
    rows = []
    cols = []
    meta_rows = []
    neigh_count_list = []
    row_offset = 0

    for i, rid in enumerate(roi_ids, start=1):
        core = (
            cells[cells[ROI_COL].astype(str) == str(rid)]
            .copy()
            .dropna(subset=[X_COL, Y_COL])
            .reset_index(drop=True)
        )
        if core.empty:
            continue

        coords = core[[X_COL, Y_COL]].to_numpy(float)
        labs = core["LDA_Label"].astype(str).to_numpy()

        neigh_idx = hybrid_neigh_indices(coords, k=K_NEIGHBORS, r_um=RADIUS_UM)

        for r_local, nbrs in enumerate(neigh_idx):
            n_nbr = int(nbrs.size)
            neigh_count_list.append(n_nbr)

            if n_nbr > 0:
                neigh_labs = labs[nbrs]
                idxs = [vocab_index.get(l, None) for l in neigh_labs]
                idxs = [j for j in idxs if j is not None]

                if idxs:
                    bc = np.bincount(np.array(idxs, dtype=int), minlength=len(vocab_index))
                    nz = np.where(bc > 0)[0]
                    for j in nz:
                        rows.append(row_offset + r_local)
                        cols.append(int(j))
                        data.append(int(bc[j]))

            meta_rows.append({
                CELLID_COL: str(core[CELLID_COL].iloc[r_local]),
                BLOCK_COL: str(core[BLOCK_COL].iloc[r_local]),
                PAT_COL: str(core[PAT_COL].iloc[r_local]),
                CORE_COL: str(core[CORE_COL].iloc[r_local]),
                ROI_COL: str(core[ROI_COL].iloc[r_local]),
                MAIN_TYPE_COL: str(core[MAIN_TYPE_COL].iloc[r_local]),
                DETAIL_COL: str(core[DETAIL_COL].iloc[r_local]),
                FINAL_PHEN_COL: str(core[FINAL_PHEN_COL].iloc[r_local]),
                "LDA_Label": str(core["LDA_Label"].iloc[r_local]),
                "main_type_lc": str(core["main_type_lc"].iloc[r_local]),
                "is_tumour": bool(core["is_tumour"].iloc[r_local]),
                "is_caf": bool(core["is_caf"].iloc[r_local]),
                "is_immune": bool(core["is_immune"].iloc[r_local]),
                X_COL: float(coords[r_local, 0]),
                Y_COL: float(coords[r_local, 1]),
                "neigh_count": n_nbr,
                "is_isolated": bool(n_nbr == 0),
            })

        row_offset += len(core)

        if i % 100 == 0 or i == len(roi_ids):
            print(f"  processed ROIs {i}/{len(roi_ids)} | rows so far={len(meta_rows):,}")

    X_all = sparse.csr_matrix(
        (data, (rows, cols)),
        shape=(len(meta_rows), len(vocab_index)),
        dtype=np.int32
    )
    cell_meta = pd.DataFrame(meta_rows)

    cell_meta.to_csv(
        DIRS["01_docs"] / "cell_meta_index_all_cells.csv.gz",
        index=False,
        compression="gzip"
    )
    sparse.save_npz(DIRS["01_docs"] / "X_docs_sparse_counts_all_cells.npz", X_all)

    qc = pd.DataFrame({"neigh_count": np.array(neigh_count_list, dtype=int)})
    qc.to_csv(DIRS["01_docs"] / "QC_neighbour_counts_per_cell.csv", index=False)

    plt.figure(figsize=(7, 4))
    sns.histplot(qc["neigh_count"].values, bins=30)
    plt.title("Neighbour count per cell (hybrid kNN-within-radius)")
    plt.xlabel("Number of neighbours used")
    plt.tight_layout()
    plt.savefig(DIRS["07_figures"] / "QC_neighbour_counts_hist.png", dpi=300)
    plt.close()

    iso_n = int(cell_meta["is_isolated"].sum())
    iso_pct = 100.0 * iso_n / max(len(cell_meta), 1)
    pd.DataFrame({
        "n_total_cells": [len(cell_meta)],
        "n_isolated_cells": [iso_n],
        "pct_isolated_cells": [iso_pct]
    }).to_csv(DIRS["01_docs"] / "QC_isolated_cell_summary.csv", index=False)

    print(f"[docs] total cells={len(cell_meta):,} | isolated={iso_n:,} ({iso_pct:.2f}%)")
    return X_all, cell_meta

def prepare_fit_subset(X_all: sparse.csr_matrix, cell_meta: pd.DataFrame) -> Tuple[sparse.csr_matrix, pd.DataFrame, np.ndarray]:
    fit_mask = cell_meta["neigh_count"].astype(int).values > 0
    X_fit = X_all[fit_mask]
    cell_meta_fit = cell_meta.loc[fit_mask].reset_index(drop=True).copy()

    pd.DataFrame({
        "n_total_cells": [len(cell_meta)],
        "n_fit_cells": [int(fit_mask.sum())],
        "n_isolated_cells": [int((~fit_mask).sum())],
        "pct_fit_cells": [100.0 * fit_mask.sum() / max(len(cell_meta), 1)],
        "pct_isolated_cells": [100.0 * (~fit_mask).sum() / max(len(cell_meta), 1)],
    }).to_csv(DIRS["01_docs"] / "QC_fit_subset_summary.csv", index=False)

    if X_fit.shape[0] == 0:
        raise ValueError("No informative cells (neigh_count > 0) available for LDA fitting.")

    print(f"[fit-subset] informative cells={X_fit.shape[0]:,} | isolated cells={(~fit_mask).sum():,}")
    return X_fit, cell_meta_fit, fit_mask


