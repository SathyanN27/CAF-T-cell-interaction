def plot_stacked_bar(df_wide: pd.DataFrame,
                     out_png: Path,
                     title: str,
                     ylabel: str,
                     palette: Optional[dict] = None):
    if df_wide.empty or df_wide.shape[1] == 0:
        (out_png.with_suffix(".txt")).write_text("No data available for stacked bar plot.\n")
        return

    plot_df = df_wide.copy()
    plot_df = plot_df.fillna(0.0)

    fig_w = max(12, 0.18 * len(plot_df))
    fig, ax = plt.subplots(figsize=(fig_w, 6.5))

    bottom = np.zeros(len(plot_df))
    x = np.arange(len(plot_df))

    for col in plot_df.columns:
        color = palette.get(col, None) if palette is not None else None
        ax.bar(x, plot_df[col].values, bottom=bottom, width=0.85, label=col, color=color)
        bottom += plot_df[col].values

    ax.set_title(title)
    ax.set_ylabel(ylabel)
    ax.set_xlabel("Patient")
    ax.set_xticks(x)
    ax.set_xticklabels(plot_df.index.astype(str).tolist(), rotation=90, fontsize=7)
    ax.set_ylim(0, 1.02)
    ax.legend(loc="center left", bbox_to_anchor=(1.01, 0.5), frameon=False, fontsize=8)
    plt.tight_layout()
    fig.savefig(out_png, dpi=300, bbox_inches="tight")
    plt.close(fig)

