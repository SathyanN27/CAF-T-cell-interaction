def load_cells() -> pd.DataFrame:
    header = pd.read_csv(FINAL_CSV, nrows=0).columns.tolist()

    required = [BLOCK_COL, PAT_COL, CORE_COL, "X", "Y", MAIN_TYPE_COL, DETAIL_COL, FINAL_PHEN_COL]
    missing = [c for c in required if c not in header]
    if missing:
        raise ValueError(f"FINAL_CSV is missing required columns: {missing}")

    usecols = [c for c in [CELLID_COL] + required if c in header]
    df = pd.read_csv(FINAL_CSV, usecols=usecols, low_memory=False)

    if CELLID_COL not in df.columns:
        df[CELLID_COL] = np.arange(len(df)).astype(str)

    df[X_PX_COL] = to_num(df["X"])
    df[Y_PX_COL] = to_num(df["Y"])
    df = df.dropna(subset=[X_PX_COL, Y_PX_COL]).copy()

    df[X_COL] = df[X_PX_COL].astype(float) * UM_PER_PX
    df[Y_COL] = df[Y_PX_COL].astype(float) * UM_PER_PX

    for c in [CELLID_COL, BLOCK_COL, PAT_COL, CORE_COL, MAIN_TYPE_COL]:
        df[c] = df[c].astype(str).str.strip()

    df[DETAIL_COL] = clean_label_series(df[DETAIL_COL])
    df[FINAL_PHEN_COL] = clean_label_series(df[FINAL_PHEN_COL])

    df["main_type_lc"] = df[MAIN_TYPE_COL].astype(str).str.strip().str.lower()
    df["is_tumour"] = df["main_type_lc"].eq("tumour")
    df["is_caf"] = df["main_type_lc"].eq("caf")
    df["is_immune"] = df["main_type_lc"].eq("immune")

    # Hybrid label logic:
    #   tumour -> Main_Cell_Type
    #   all other cells -> Final_Phenotype
    #   fallback -> Detailed_Phenotype -> Main_Cell_Type
    df["LDA_Label"] = np.where(
        df["is_tumour"].values,
        df[MAIN_TYPE_COL].values,
        df[FINAL_PHEN_COL].values
    )
    df["LDA_Label"] = pd.Series(df["LDA_Label"], index=df.index)
    df["LDA_Label"] = df["LDA_Label"].where(df["LDA_Label"].notna(), df[DETAIL_COL])
    df["LDA_Label"] = df["LDA_Label"].where(df["LDA_Label"].notna(), df[MAIN_TYPE_COL])

    df = df[df["LDA_Label"].notna()].copy()
    df["LDA_Label"] = df["LDA_Label"].astype(str).str.strip()
    df = df[df["LDA_Label"].str.len() > 0].copy()
    df = df[df["LDA_Label"].str.lower() != "nan"].copy()

    # Robust ROI key
    df[ROI_COL] = (
        df[PAT_COL].astype(str).str.strip() + "||" +
        df[BLOCK_COL].astype(str).str.strip() + "||" +
        df[CORE_COL].astype(str).str.strip()
    )

    return df

def load_and_parse_survival(clin_csv: str) -> pd.DataFrame:
    clin = pd.read_csv(clin_csv, low_memory=False)
    clin.columns = [str(c).strip() for c in clin.columns]

    for req in [PAT_COL, OS_COL, FU_COL, STATUS_COL]:
        if req not in clin.columns:
            raise ValueError(f"Clinical file missing required column: {req}. Columns: {clin.columns.tolist()}")

    clin[PAT_COL] = clin[PAT_COL].astype(str).str.strip()

    status = clin[STATUS_COL].astype(str).str.strip().str.lower()
    is_deceased = status.isin(["deceased", "dead", "died"]) | status.str.contains("deceased", na=False)
    is_alive = status.str.contains("alive", na=False)
    is_ltfu = status.str.contains("lost", na=False)

    os_days = pd.to_numeric(clin[OS_COL], errors="coerce")
    fu_days = pd.to_numeric(clin[FU_COL], errors="coerce")

    event = np.where(is_deceased, 1, np.where(is_alive | is_ltfu, 0, np.nan)).astype(float)

    # Safer time handling:
    # - deceased patients should use OS_days
    # - alive/LTFU patients preferentially use Follow_up, with OS_days as backup
    time_days = pd.Series(np.nan, index=clin.index, dtype=float)
    time_days.loc[is_deceased] = os_days.loc[is_deceased]
    time_days.loc[is_alive | is_ltfu] = fu_days.loc[is_alive | is_ltfu]
    alive_missing_fu = (is_alive | is_ltfu) & time_days.isna()
    time_days.loc[alive_missing_fu] = os_days.loc[alive_missing_fu]

    surv = pd.DataFrame({
        PAT_COL: clin[PAT_COL],
        "OS_days": time_days,
        "OS_event": event
    })

    if SURV_GROUP_COL is not None and SURV_GROUP_COL in clin.columns:
        surv[SURV_GROUP_NAME] = clin[SURV_GROUP_COL].astype(str).str.strip()

    surv = surv.dropna(subset=["OS_days", "OS_event"]).copy()
    surv["OS_event"] = surv["OS_event"].astype(int)
    surv["OS_days"] = surv["OS_days"].astype(float)
    surv = surv[surv["OS_days"] > 0].copy()

    if surv[PAT_COL].duplicated().any():
        surv = (
            surv.sort_values([PAT_COL, "OS_event", "OS_days"], ascending=[True, False, False])
                .drop_duplicates(subset=[PAT_COL], keep="first")
                .reset_index(drop=True)
        )

    n_ok = surv[PAT_COL].nunique()
    n_event = int(surv["OS_event"].sum())
    n_cens = int((surv["OS_event"] == 0).sum())
    print(f"[survival] usable patients={n_ok:,} events={n_event:,} censored={n_cens:,}")

    surv.to_csv(DIRS["00_inputs"] / "SURVIVAL_cleaned_patient_table.csv", index=False)
    return surv

def ensure_survival_groups(surv: pd.DataFrame) -> pd.DataFrame:
    out = surv.copy()

    if SURV_GROUP_NAME in out.columns:
        out[SURV_GROUP_NAME] = out[SURV_GROUP_NAME].astype(str).str.strip()
        out.loc[out[SURV_GROUP_NAME].isin(["", "nan", "None"]), SURV_GROUP_NAME] = np.nan

    if SURV_GROUP_NAME not in out.columns or out[SURV_GROUP_NAME].isna().all():
        q1, q2 = out["OS_days"].quantile([1/3, 2/3]).values
        if q1 >= q2:
            med = out["OS_days"].median()
            out[SURV_GROUP_NAME] = np.where(out["OS_days"] <= med, "Short", "Long")
        else:
            out[SURV_GROUP_NAME] = pd.cut(
                out["OS_days"],
                bins=[-np.inf, q1, q2, np.inf],
                labels=SURV_GROUP_ORDER,
                include_lowest=True
            ).astype(str)

    return out


