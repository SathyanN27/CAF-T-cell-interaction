def parse_edge_col(col: str) -> Tuple[str, str]:
    _, a, b = col.split("__")
    return a, b

def extract_edge_values_from_row(row: pd.Series) -> np.ndarray:
    edge_cols = [c for c in row.index if c.startswith("EDGE__")]
    vals = []
    for c in edge_cols:
        v = row.get(c, np.nan)
        if pd.notna(v) and float(v) > 0:
            vals.append(float(v))
    return np.asarray(vals, dtype=float) if vals else np.asarray([], dtype=float)

def shared_edge_max(rows: List[pd.Series]) -> Optional[float]:
    vals = []
    for row in rows:
        x = extract_edge_values_from_row(row)
        if x.size:
            vals.append(x)
    if not vals:
        return None
    return float(np.nanmax(np.concatenate(vals)))

def plot_weighted_network_from_row(row: pd.Series,
                                   motifs: List[str],
                                   out_png: Path,
                                   title: str,
                                   layout_pos: Optional[dict] = None,
                                   edge_vmax: Optional[float] = None):
    edge_cols = [c for c in row.index if c.startswith("EDGE__")]
    G = nx.Graph()
    pal = sns.color_palette("tab20", n_colors=max(len(motifs), 3))
    color_map = {m: pal[i] for i, m in enumerate(motifs)}

    for m in motifs:
        val = float(row.get(f"NODE__{m}", 0.0))
        if not np.isfinite(val):
            val = 0.0
        G.add_node(m, weight=val)

    edges = []
    for c in edge_cols:
        val = row.get(c, np.nan)
        if pd.isna(val) or float(val) <= 0:
            continue
        a, b = parse_edge_col(c)
        edges.append((a, b, float(val)))

    edges = sorted(edges, key=lambda x: x[2], reverse=True)[:NETWORK_TOP_EDGES]
    for a, b, w in edges:
        G.add_edge(a, b, weight=w)

    if layout_pos is None:
        if G.number_of_edges() > 0:
            layout_pos = nx.spring_layout(G, seed=NETWORK_LAYOUT_SEED, weight="weight")
        else:
            layout_pos = nx.circular_layout(G)

    node_sizes = [
        NETWORK_NODE_SIZE_BASE + NETWORK_NODE_SIZE_SCALE * float(G.nodes[m]["weight"])
        for m in G.nodes()
    ]
    node_colors = [color_map[m] for m in G.nodes()]

    fig, ax = plt.subplots(figsize=(10, 10))
    ax.set_facecolor("#f0f0f0")

    nx.draw_networkx_nodes(
        G, pos=layout_pos,
        node_size=node_sizes,
        node_color=node_colors,
        edgecolors="none",
        ax=ax
    )

    if G.number_of_edges() > 0:
        ew = np.array([G[u][v]["weight"] for u, v in G.edges()], dtype=float)
        denom = edge_vmax if (edge_vmax is not None and edge_vmax > 0) else np.max(ew)
        denom = max(float(denom), EPS)
        ew_scaled = NETWORK_EDGE_WIDTH_SCALE * (ew / denom)
        ew_alpha = 0.15 + 0.85 * np.clip(ew / denom, 0, 1)

        for (u, v), w, a in zip(G.edges(), ew_scaled, ew_alpha):
            nx.draw_networkx_edges(
                G, pos=layout_pos,
                edgelist=[(u, v)],
                width=float(w),
                edge_color="grey",
                alpha=float(a),
                ax=ax
            )

    nx.draw_networkx_labels(
        G, pos=layout_pos,
        font_size=11,
        font_color="black",
        ax=ax
    )

    ax.set_title(title, fontsize=14)
    ax.axis("off")
    plt.tight_layout()
    fig.savefig(out_png, dpi=300, bbox_inches="tight")
    plt.close(fig)

    return layout_pos

