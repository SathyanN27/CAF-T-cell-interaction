def representative_patient_neighbourhood_maps(theta_all: np.ndarray,
                                              cell_meta: pd.DataFrame,
                                              core_feat: pd.DataFrame,
                                              patient_table: pd.DataFrame,
                                              n_patients_per_motif: int = 6,
                                              ncols: int = 3,
                                              dominance_threshold: Optional[float] = None):
    motifs = [f"Motif{t+1}" for t in range(theta_all.shape[1])]
    palette = make_palette(motifs + [ISOLATED_LABEL])

    df = cell_meta[[PAT_COL, CORE_COL, ROI_COL, BLOCK_COL, X_COL, Y_COL, "is_isolated"]].copy()
    dom = assign_dominant_neighbourhood(
        theta_all=theta_all,
        is_isolated=df["is_isolated"].astype(bool).values,
        dominance_threshold=dominance_threshold
    )
    df["Dominant_Neighbourhood"] = dom["Dominant_Neighbourhood"].values

    outdir = DIRS["07_figures"] / "Representative_Patient_Neighbourhood_Maps"
    outdir.mkdir(parents=True, exist_ok=True)

    patient_global_cols = sorted(
        [c for c in patient_table.columns if c.startswith("GLOBAL__Motif")],
        key=lambda c: motif_sort_key(c.split("__")[-1])
    )

    legend_order = motifs.copy()
    if dominance_threshold is not None:
        legend_order += [MIXED_LABEL]
        palette[MIXED_LABEL] = (0.55, 0.55, 0.55)
    legend_order += [ISOLATED_LABEL]

    for col in patient_global_cols:
        motif = col.split("__")[-1]
        tmp_pat = patient_table[[PAT_COL, col]].dropna().copy()
        if tmp_pat.empty:
            continue

        tmp_pat = tmp_pat.sort_values(col, ascending=False).head(n_patients_per_motif)
        rep_patients = tmp_pat[PAT_COL].astype(str).tolist()
        if len(rep_patients) == 0:
            continue

        n = len(rep_patients)
        ncols_use = min(ncols, n)
        nrows_use = int(np.ceil(n / ncols_use))

        fig, axes = plt.subplots(
            nrows_use, ncols_use,
            figsize=(5.2 * ncols_use, 4.9 * nrows_use),
            squeeze=False
        )
        axes = axes.flatten()

        for ax_i, pid in enumerate(rep_patients):
            ax = axes[ax_i]

            core_col = f"GLOBAL__{motif}"
            sub_core = core_feat[core_feat[PAT_COL].astype(str) == str(pid)].copy()
            sub_core = sub_core.dropna(subset=[core_col])
            if sub_core.empty:
                ax.axis("off")
                continue

            best_core_row = sub_core.sort_values(core_col, ascending=False).iloc[0]
            rid = str(best_core_row[ROI_COL])
            cid = str(best_core_row[CORE_COL])

            sub = df[
                (df[PAT_COL].astype(str) == str(pid)) &
                (df[ROI_COL].astype(str) == rid)
            ].copy()

            if sub.empty:
                ax.axis("off")
                continue

            for cls in legend_order:
                s = sub[sub["Dominant_Neighbourhood"] == cls]
                if s.empty:
                    continue
