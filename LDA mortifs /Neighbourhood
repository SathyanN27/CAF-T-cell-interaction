def km_quartile_extremes(df: pd.DataFrame, feature: str, out_png: Path, min_per_group: int = 12):
    if not HAVE_LIFELINES:
        return None

    d = df[[feature, "OS_days", "OS_event"]].dropna().copy()
    if len(d) < 40 or d[feature].nunique() < 2:
        return None

    d["_pct_rank"] = d[feature].rank(method="average", pct=True)
    low = d[d["_pct_rank"] <= 0.25].copy()
    high = d[d["_pct_rank"] >= 0.75].copy()

    if len(low) < min_per_group or len(high) < min_per_group:
        return None

    km1 = KaplanMeierFitter()
    km2 = KaplanMeierFitter()
    fig, ax = plt.subplots(figsize=(8.2, 6.6))

    km1.fit(low["OS_days"], low["OS_event"], label=f"Low (≤Q1) n={len(low)}").plot(ax=ax, ci_show=True)
    km2.fit(high["OS_days"], high["OS_event"], label=f"High (≥Q3) n={len(high)}").plot(ax=ax, ci_show=True)

    lr = logrank_test(low["OS_days"], high["OS_days"],
                      event_observed_A=low["OS_event"],
                      event_observed_B=high["OS_event"])

    ax.set_title(f"{feature} (quartile extremes)  Log-rank p={lr.p_value:.3g}")
    ax.set_xlabel("Days")
    ax.set_ylabel("Survival probability")
    add_at_risk_counts(km1, km2, ax=ax)
    fig.subplots_adjust(bottom=0.25)
    fig.tight_layout()
    fig.savefig(out_png, dpi=300)
    plt.close(fig)

    return float(lr.p_value)

def univariate_cox(df: pd.DataFrame, feature: str, penalizer: float = 0.0):
    if not HAVE_LIFELINES:
        return None

    d = df[[feature, "OS_days", "OS_event"]].dropna().copy()
    if len(d) < 30 or d[feature].nunique() < 2:
        return None

    d[feature] = zscore(d[feature])
    cph = CoxPHFitter(penalizer=penalizer)

    try:
        cph.fit(d, duration_col="OS_days", event_col="OS_event")
        s = cph.summary.loc[feature].copy()
        return {
            "feature": feature,
            "coef": float(s["coef"]),
            "HR": float(np.exp(s["coef"])),
            "p": float(s["p"]),
            "CI95_low": float(np.exp(s["coef lower 95%"])),
            "CI95_high": float(np.exp(s["coef upper 95%"])),
            "n": int(len(d)),
        }
    except Exception:
        return None

def forest_plot_with_q(cox_table: pd.DataFrame, outpng: Path, title: str):
    if cox_table.empty:
        return

    d = cox_table.sort_values("q", ascending=True).copy()
    if len(d) > 30:
        d = d.head(30).copy()

    y = np.arange(len(d))
    hr = d["HR"].values
    lo = d["CI95_low"].values
    hi = d["CI95_high"].values

    labels = [f"{r['feature']}  (q={r['q']:.3g})" for _, r in d.iterrows()]

    fig_h = max(6, 0.35 * len(d) + 2.0)
    fig, ax = plt.subplots(figsize=(10, fig_h))
    ax.hlines(y, lo, hi, lw=2)
    ax.plot(hr, y, "o")
    ax.axvline(1.0, linestyle="--")
    ax.set_yticks(y)
    ax.set_yticklabels(labels, fontsize=8.5)
    ax.set_xlabel("Hazard Ratio (per 1 SD)")
    ax.set_title(title)
    ax.invert_yaxis()
    ax.grid(True, axis="x", alpha=0.25)
    fig.tight_layout()
    fig.savefig(outpng, dpi=300)
    plt.close(fig)

def run_survival(patient_table: pd.DataFrame, surv: pd.DataFrame, table_tag: str):
    outdir = DIRS["06_survival"] / table_tag
    outdir.mkdir(parents=True, exist_ok=True)
    km_dir = outdir / "KM_quartile_extremes"
    km_dir.mkdir(parents=True, exist_ok=True)

    df = patient_table.merge(surv, on=PAT_COL, how="inner")
    df.to_csv(outdir / f"{table_tag}_with_survival.csv", index=False)

    feature_cols = [
        c for c in df.columns
        if c not in [PAT_COL, "OS_days", "OS_event", SURV_GROUP_NAME]
        and (
            c.startswith("GLOBAL__Motif")
            or c.startswith("TUMOUR__Motif")
            or c.startswith("CAF__Motif")
            or c.startswith("IMMUNE__Motif")
            or c.startswith("GLOBAL_W__Motif")
            or c.startswith("TUMOUR_W__Motif")
            or c.startswith("CAF_W__Motif")
            or c.startswith("IMMUNE_W__Motif")
            or c.startswith("DOMPROP__")
            or c.startswith("DOMPROP_INF__")
            or c.startswith("NODE__")
            or c.startswith("EDGE__")
            or c.startswith("NPATCH__")
            or c.startswith("EDGECOUNT__")
            or "frac_isolated" in c
            or "median_neigh_count" in c
            or "n_patch_contacts" in c
            or "n_patches" in c
            or "n_retained_patch_cells" in c
            or "frac_informative_cells_in_retained_patches" in c
        )
    ]

    if not feature_cols:
        (outdir / "NO_FEATURES_FOUND.txt").write_text("No eligible feature columns detected.\n")
        return

    if not HAVE_LIFELINES:
        (outdir / "README_lifelines.txt").write_text("lifelines not installed; KM/Cox skipped.\n")
        return

    km_rows = []
    for f in feature_cols:
        p = km_quartile_extremes(df, f, km_dir / f"KM_{safe_name(f)}.png", min_per_group=12)
        if p is not None:
            km_rows.append({"feature": f, "logrank_p": p})

    if km_rows:
        km_tab = pd.DataFrame(km_rows).sort_values("logrank_p")
        km_tab["q"] = bh_fdr(km_tab["logrank_p"])
        km_tab.to_csv(outdir / "KM_logrank_pvalues_with_FDR.csv", index=False)

    cox_rows = []
    for f in feature_cols:
        res = univariate_cox(df, f, penalizer=0.0)
        if res is not None:
            cox_rows.append(res)

    cox = pd.DataFrame(cox_rows)
    if not cox.empty:
        cox["q"] = bh_fdr(cox["p"])
        cox.sort_values("q").to_csv(outdir / "Cox_univariate_features_with_FDR.csv", index=False)
        forest_plot_with_q(cox, outdir / "Forest_Cox_univariate_features.png",
                           title=f"Univariate Cox (per 1 SD) — {table_tag}")
    else:
        (outdir / "EMPTY_COX.txt").write_text("No Cox models converged / insufficient samples.\n")


