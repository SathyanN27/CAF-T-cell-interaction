def ensure_dir(path):
    Path(path).mkdir(parents=True, exist_ok=True)

def safe_name(x):
    return re.sub(r"[^A-Za-z0-9]+", "_", str(x))

def _mw_pval(a, b):
    a = np.asarray(a, dtype=float)
    b = np.asarray(b, dtype=float)
    a = a[np.isfinite(a)]
    b = b[np.isfinite(b)]
    if len(a) < 2 or len(b) < 2:
        return np.nan
    try:
        return mannwhitneyu(a, b, alternative="two-sided")[1]
    except Exception:
        return np.nan

def _paired_wilcoxon_p(a, b):
    a = np.asarray(a, dtype=float)
    b = np.asarray(b, dtype=float)

    keep = np.isfinite(a) & np.isfinite(b)
    a = a[keep]
    b = b[keep]

    if len(a) < 2 or len(b) < 2:
        return np.nan, np.nan, len(a)

    d = a - b
    if np.allclose(d, 0, equal_nan=False):
        return np.nan, np.nan, len(a)

    try:
        res = wilcoxon(a, b, zero_method="wilcox", alternative="two-sided")
        p = float(res.pvalue)
        stat = float(res.statistic)

        z = getattr(res, "zstatistic", np.nan)
        if z is not None and np.isfinite(z):
            r = abs(float(z)) / np.sqrt(len(a))
        else:
            r = np.nan

        return p, r, len(a)
    except Exception:
        return np.nan, np.nan, len(a)

def _norm_core_id(v):
    """Normalise Spot Id 2 so 142 and 142.0 match; keep non-numeric IDs as-is."""
    if pd.isna(v):
        return np.nan
    s = str(v).strip()
    try:
        f = float(s)
        if np.isfinite(f):
            if abs(f - int(f)) < 1e-9:
                return str(int(f))
            return s
    except Exception:
        pass
    return s

def _clean_block_name(v):
    if pd.isna(v):
        return ""
    s = str(v).strip()
    if s.lower() in {"nan", "none"}:
        return ""
    return s

def add_roi_key(df):
    """
    Build the most specific ROI key available.

    Preferred:
        ROI_KEY = Spot Id 1 + "__" + TMA Block Name + "__" + Spot Id 2
    Fallback:
        ROI_KEY = Spot Id 1 + "__" + Spot Id 2
    """
    d = df.copy()

    if "Spot Id 1" not in d.columns or "Spot Id 2" not in d.columns:
        return d

    d["Spot Id 1"] = d["Spot Id 1"].astype(str).str.strip()
    d["Spot Id 2"] = d["Spot Id 2"].apply(_norm_core_id)

    if "TMA Block Name" in d.columns:
        d["TMA Block Name"] = d["TMA Block Name"].apply(_clean_block_name)
        use_block = d["TMA Block Name"].ne("")
        d["ROI_KEY"] = np.where(
            use_block,
            d["Spot Id 1"].astype(str) + "__" + d["TMA Block Name"].astype(str) + "__" + d["Spot Id 2"].astype(str),
            d["Spot Id 1"].astype(str) + "__" + d["Spot Id 2"].astype(str),
        )
    else:
        d["ROI_KEY"] = d["Spot Id 1"].astype(str) + "__" + d["Spot Id 2"].astype(str)

    return d

def prepare_area_table(area_df, final_df):
    """
    Prepare Area.csv so densities map to the correct ROI.

    Priority for mapping:
      1) Spot Id 1 + TMA Block Name + Spot Id 2
      2) Spot Id 1 + Spot Id 2
      3) If Area.csv lacks Spot Id 1, infer it from final_df using the most specific available key

    If duplicate area rows remain for the same ROI_KEY, collapse them using median(Total).
    """
    a = area_df.copy()
    f = final_df.copy()

    if "Spot Id 2" not in a.columns:
        raise ValueError("Area.csv must contain 'Spot Id 2'.")
    if "Total" not in a.columns:
        raise ValueError("Area.csv must contain 'Total'.")

    a["Spot Id 2"] = a["Spot Id 2"].apply(_norm_core_id)
    a["Total"] = pd.to_numeric(a["Total"], errors="coerce")

    if "Spot Id 1" in a.columns:
        a["Spot Id 1"] = a["Spot Id 1"].astype(str).str.strip()
    if "TMA Block Name" in a.columns:
        a["TMA Block Name"] = a["TMA Block Name"].apply(_clean_block_name)

    if "Spot Id 1" in a.columns:
        a = add_roi_key(a)
    else:
        if "TMA Block Name" in a.columns and "TMA Block Name" in f.columns:
            mapper = (
                f[["Spot Id 1", "TMA Block Name", "Spot Id 2"]]
                .drop_duplicates()
                .copy()
            )

            amb = (
                mapper.groupby(["TMA Block Name", "Spot Id 2"])["Spot Id 1"]
                .nunique()
            )
            amb = amb[amb > 1]
            if len(amb) > 0:
                ex = [f"{idx[0]} | {idx[1]}" for idx in amb.index[:10]]
                raise ValueError(
                    "Could not infer patient ID uniquely from Area.csv using "
                    "'TMA Block Name' + 'Spot Id 2'. Example ambiguous keys: "
                    + ", ".join(ex)
                )

            a = a.merge(
                mapper,
                on=["TMA Block Name", "Spot Id 2"],
                how="left",
                validate="many_to_one",
            )

        else:
            mapper = f[["Spot Id 1", "Spot Id 2"]].drop_duplicates().copy()

            amb = mapper.groupby("Spot Id 2")["Spot Id 1"].nunique()
            amb = amb[amb > 1]
            if len(amb) > 0:
                ex = amb.index.astype(str).tolist()[:10]
                raise ValueError(
                    "Area.csv does not contain 'Spot Id 1', and 'Spot Id 2' is "
                    "not unique enough to infer patient ID. Example ambiguous "
                    "Spot Id 2 values: " + ", ".join(ex)
                )

            a = a.merge(
                mapper,
                on="Spot Id 2",
                how="left",
                validate="many_to_one",
            )

        if "Spot Id 1" not in a.columns or a["Spot Id 1"].isna().any():
            missing = a.loc[a["Spot Id 1"].isna(), "Spot Id 2"].astype(str).unique().tolist()[:10]
            raise ValueError(
                "Some Area.csv rows could not be mapped to a patient. "
                "Example Spot Id 2 values: " + ", ".join(missing)
            )

        a = add_roi_key(a)

    keep_cols = ["ROI_KEY", "Spot Id 1", "Spot Id 2", "Total"]
    if "TMA Block Name" in a.columns:
        keep_cols.insert(2, "TMA Block Name")

    a = a[keep_cols].copy()

    qc = (
        a.groupby("ROI_KEY")
        .agg(
            **{
                "Spot Id 1": ("Spot Id 1", "first"),
                "Spot Id 2": ("Spot Id 2", "first"),
                **({"TMA Block Name": ("TMA Block Name", "first")} if "TMA Block Name" in a.columns else {}),
                "Total": ("Total", "median"),
                "Area_n_rows": ("Total", "size"),
                "Area_Total_min": ("Total", "min"),
                "Area_Total_max": ("Total", "max"),
            }
        )
        .reset_index()
    )

    n_conflict = int((qc["Area_Total_min"] != qc["Area_Total_max"]).sum())
    if n_conflict > 0:
        print(
            f"WARNING: Area.csv had {n_conflict} ROI_KEY values with conflicting "
            f"'Total' entries. Using median(Total) per ROI_KEY."
        )

    return qc

def load_data(final_csv, area_csv, clin_csv):
    final = pd.read_csv(final_csv)
    area = pd.read_csv(area_csv)
    clinical = pd.read_csv(clin_csv)

    if "Spot Id 1" in final.columns:
        final["Spot Id 1"] = final["Spot Id 1"].astype(str).str.strip()
    if "Spot Id 2" in final.columns:
        final["Spot Id 2"] = final["Spot Id 2"].apply(_norm_core_id)
    if "TMA Block Name" in final.columns:
        final["TMA Block Name"] = final["TMA Block Name"].apply(_clean_block_name)

    if "Spot Id 1" in clinical.columns:
        clinical["Spot Id 1"] = clinical["Spot Id 1"].astype(str).str.strip()

    final = add_roi_key(final)
    area = prepare_area_table(area, final)

    return final, area, clinical

def preprocess_clinical(df):
    """
    OS logic:
    - OS days in 'Overall_Survival_(days)'.
    - If OS is NA and Alive -> use 'Follow_up' (days).
    - Event=1 if Deceased, Event=0 if Alive
    - SurvivalCategory bins (days): Short<=540, Intermediate 541–900, Long>900
    """
    d = df.copy()

    os_col = "Overall_Survival_(days)"
    status_col = "Alive_or_deceased?"
    fu_col = "Follow_up"

    if os_col not in d.columns:
        for c in d.columns:
            if "Overall" in c and "Survival" in c and "day" in c.lower():
                os_col = c
                break
    if status_col not in d.columns:
        for c in d.columns:
            if "alive" in c.lower() and "dece" in c.lower():
                status_col = c
                break
    if fu_col not in d.columns:
        for c in d.columns:
            if "follow" in c.lower():
                fu_col = c
                break

    d[os_col] = d[os_col].replace(["NA", "N/A", "na", "n/a", ""], np.nan)
    d[fu_col] = d[fu_col].replace(["NA", "N/A", "na", "n/a", ""], np.nan)

    d["OS_days_raw"] = pd.to_numeric(d[os_col], errors="coerce")
    d["FollowUp_days_raw"] = pd.to_numeric(d[fu_col], errors="coerce")

    status = d[status_col].astype(str).str.strip().str.lower()
    is_alive = status.eq("alive")
    is_deceased = status.eq("deceased")

    d["SurvivalDays"] = d["OS_days_raw"].copy()
    mask_need = d["SurvivalDays"].isna() & is_alive
    d.loc[mask_need, "SurvivalDays"] = d.loc[mask_need, "FollowUp_days_raw"]

    d["Event"] = np.where(is_deceased, 1, np.where(is_alive, 0, np.nan))

    if "Spot Id 1" not in d.columns:
        raise ValueError("Clinical file must contain 'Spot Id 1' patient ID column.")
    d["Spot Id 1"] = d["Spot Id 1"].astype(str).str.strip()
    d["SurvivalDays"] = pd.to_numeric(d["SurvivalDays"], errors="coerce")

    d["SurvivalCategory"] = pd.cut(
        d["SurvivalDays"],
        bins=[-np.inf, 540, 900, np.inf],
        labels=["Short", "Intermediate", "Long"],
    )

    return d[["Spot Id 1", "SurvivalDays", "Event", "SurvivalCategory"]].drop_duplicates()

def save_boxplot(df, x, y, order, palette, outpath, title=None, xlabel=None, ylabel=None):
    plt.figure(figsize=(max(6, len(order) * 0.45), 6))
    sns.boxplot(x=x, y=y, data=df, order=order, palette=palette)
    sns.stripplot(x=x, y=y, data=df, order=order, color="k", size=3, alpha=0.35, jitter=0.15)
    plt.xticks(rotation=90)
    if title:
        plt.title(title)
    if xlabel:
        plt.xlabel(xlabel)
    if ylabel:
        plt.ylabel(ylabel)
    plt.tight_layout()
    plt.savefig(outpath, dpi=300)
    plt.close()

def save_triangle_corr_heatmap(corr_mat, outpath, title=None, cmap=HEATMAP_CMAP):
    mat = corr_mat.copy()
    mask = np.triu(np.ones_like(mat, dtype=bool), k=1)
    plt.figure(figsize=(10, 8))
    sns.heatmap(
        mat,
        mask=mask,
        cmap=cmap,
        square=True,
        vmin=-1,
        vmax=1,
        center=0,
        cbar_kws={"label": "Correlation"},
    )
    if title:
        plt.title(title)
    plt.tight_layout()
    plt.savefig(outpath, dpi=300)
    plt.close()

def save_heatmap(
    mat,
    outpath,
    title=None,
    cbar_label=None,
    cmap=HEATMAP_CMAP,
    square=True,
    vmin=None,
    vmax=None,
    center=None,
    xlabel=None,
    ylabel=None,
    xtick_rotation=90,
    ytick_rotation=0,
    annot=False,
    fmt=".2f",
):
    plt.figure(figsize=(10, 8))
    ax = sns.heatmap(
        mat,
        cmap=cmap,
        square=square,
        vmin=vmin,
        vmax=vmax,
        center=center,
        cbar_kws={"label": cbar_label if cbar_label else ""},
        annot=annot,
        fmt=fmt if annot else None,
    )
    if title:
        plt.title(title)
    if xlabel is not None:
        ax.set_xlabel(xlabel)
    if ylabel is not None:
        ax.set_ylabel(ylabel)
    plt.xticks(rotation=xtick_rotation)
    plt.yticks(rotation=ytick_rotation)
    plt.tight_layout()
    plt.savefig(outpath, dpi=300)
    plt.close()


