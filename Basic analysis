# Stage 8b: Kaplan–Meier per phenotype (quadrants) + Cox HRs + at-risk table
# ──────────────────────────────────────────────────────────────────────────────
def stage8b_km_by_quadrant(
    quad_df,
    clinical_df,
    outdir,
    group_order,
    time_col="SurvivalDays",
    event_col="Event",
):
    outdir = Path(outdir)
    ensure_dir(outdir)

    if not LIFELINES_OK:
        print("Stage 8b: lifelines not installed/available. Skipping KM + forest plots.")
        return

    df = quad_df.merge(clinical_df[["Spot Id 1", time_col, event_col]], on="Spot Id 1", how="left")
    df = df.dropna(subset=[time_col, event_col])
    if df.empty:
        print("Stage 8b: no survival data after merge.")
        return

    quad_order = [
        "Low infiltration Included",
        "High infiltration Included",
        "Low infiltration Excluded",
        "High infiltration Excluded",
    ]

    km_dir = outdir / "KM"
    ensure_dir(km_dir)

    forest_rows = []

    for ph in group_order:
        sub = df[df["Detailed_Phenotype"] == ph].copy().dropna(subset=["Quadrant"])
        if sub.empty:
            continue

        try:
            lr = multivariate_logrank_test(
                event_durations=sub[time_col].astype(float),
                groups=sub["Quadrant"].astype(str),
                event_observed=sub[event_col].astype(int),
            )
            lr_p = float(lr.p_value)
        except Exception:
            lr_p = np.nan

        fig, ax = plt.subplots(1, 1, figsize=(7.8, 6.8))
        kmfs = []
        for q in quad_order:
            qsub = sub[sub["Quadrant"] == q]
            if qsub.empty:
                continue
            kmf = KaplanMeierFitter()
            kmf.fit(
                durations=qsub[time_col].astype(float),
                event_observed=qsub[event_col].astype(int),
                label=f"{q} (n={len(qsub)})",
            )
            kmf.plot_survival_function(ax=ax, ci_show=True)
            kmfs.append(kmf)

        ax.set_title(f"{ph} — KM by quadrant\nlog-rank p={lr_p:.3g}" if np.isfinite(lr_p) else f"{ph} — KM by quadrant")
        ax.set_xlabel("Days")
        ax.set_ylabel("Survival probability")
        ax.grid(True, alpha=0.25)

        try:
            if len(kmfs) >= 1:
                add_at_risk_counts(*kmfs, ax=ax)
                fig.subplots_adjust(bottom=0.28)
        except Exception:
            pass

        fig.savefig(km_dir / f"KM_{safe_name(ph)}.png", dpi=300)
        plt.close(fig)

        present = [q for q in quad_order if q in set(sub["Quadrant"])]
        if len(present) >= 2:
            ref = present[0]
            cox_df = sub[[time_col, event_col, "Quadrant"]].copy()
            cox_df["Quadrant"] = pd.Categorical(cox_df["Quadrant"], categories=present, ordered=True)

            X = pd.get_dummies(cox_df["Quadrant"], drop_first=True, prefix="Q")
            cox_in = pd.concat(
                [cox_df[[time_col, event_col]].reset_index(drop=True), X.reset_index(drop=True)],
                axis=1,
            )
            cox_in = cox_in.dropna()

            if cox_in[event_col].nunique() > 0 and len(cox_in) >= 10:
                try:
                    cph = CoxPHFitter()
                    cph.fit(cox_in, duration_col=time_col, event_col=event_col)
                    summ = cph.summary.copy()
                    for cov in summ.index:
                        forest_rows.append({
                            "Phenotype": ph,
                            "Covariate": cov,
                            "ReferenceQuadrant": ref,
                            "HR": float(np.exp(summ.loc[cov, "coef"])),
                            "CI_lower": float(np.exp(summ.loc[cov, "coef lower 95%"])),
                            "CI_upper": float(np.exp(summ.loc[cov, "coef upper 95%"])),
                            "p": float(summ.loc[cov, "p"]),
                            "n": int(len(cox_in)),
                        })
                except Exception:
                    pass

    forest_df = pd.DataFrame(forest_rows)
    forest_df.to_csv(outdir / "Stage8b_Cox_ForestTable.csv", index=False)

    if not forest_df.empty:
        forest_df = forest_df.sort_values(["Phenotype", "p"], ascending=[True, True]).reset_index(drop=True)

        fig_h = max(6, 0.28 * len(forest_df) + 1.5)
        fig, ax = plt.subplots(1, 1, figsize=(9, fig_h))

        y = np.arange(len(forest_df))
        hr = forest_df["HR"].values
        lo = forest_df["CI_lower"].values
        hi = forest_df["CI_upper"].values

        ax.hlines(y=y, xmin=lo, xmax=hi)
        ax.plot(hr, y, "o")
        ax.axvline(1.0, ls="--")

        labels = [
            f"{r.Phenotype} | {r.Covariate} (ref={r.ReferenceQuadrant}) | p={r.p:.2g}"
            for r in forest_df.itertuples(index=False)
        ]
        ax.set_yticks(y)
        ax.set_yticklabels(labels, fontsize=8)
        ax.set_xlabel("Hazard Ratio (HR) with 95% CI")
        ax.set_title("Stage 8b — Cox HRs for Quadrant (per phenotype)")
        ax.invert_yaxis()
        ax.grid(True, axis="x", alpha=0.25)
        fig.tight_layout()
        fig.savefig(outdir / "Stage8b_Cox_ForestPlot.png", dpi=300)
        plt.close(fig)


