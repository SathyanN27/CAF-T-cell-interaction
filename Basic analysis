# Stage 2: Median Proportion (by Detailed_Phenotype) + Short comparisons
# ──────────────────────────────────────────────────────────────────────────────
def stage2_median_proportion(final_data, outdir, group_order, palette_dict):
    ensure_dir(outdir)

    prop = (
        final_data.groupby(["Spot Id 1", "ROI_KEY", "Detailed_Phenotype"])
        .size()
        .reset_index(name="CellCount")
    )
    tot = (
        final_data.groupby(["Spot Id 1", "ROI_KEY"])
        .size()
        .reset_index(name="TotalCount")
    )

    merged = prop.merge(tot, on=["Spot Id 1", "ROI_KEY"], how="left")
    merged["Proportion"] = merged["CellCount"] / merged["TotalCount"] * 100

    df = (
        merged.groupby(["Spot Id 1", "Detailed_Phenotype"])["Proportion"]
        .median()
        .reset_index(name="MedianProportion")
    )

    save_boxplot(
        df,
        "Detailed_Phenotype",
        "MedianProportion",
        group_order,
        palette_dict,
        Path(outdir) / "MedianProportion_Boxplot.png",
        ylabel="Median Proportion (%)",
    )
    return df

def stage2_proportion_by_survival(df_prop, clinical_df, outdir, group_order, surv_palette):
    ensure_dir(outdir)
    df = df_prop.merge(clinical_df[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")

    stats_rows = []
    for ph in group_order:
        sub = df[df["Detailed_Phenotype"] == ph].dropna(subset=["SurvivalCategory"])
        if sub.empty:
            continue
        s = sub.loc[sub["SurvivalCategory"] == "Short", "MedianProportion"].values
        i = sub.loc[sub["SurvivalCategory"] == "Intermediate", "MedianProportion"].values
        l = sub.loc[sub["SurvivalCategory"] == "Long", "MedianProportion"].values

        p_si = _mw_pval(s, i)
        p_sl = _mw_pval(s, l)

        stats_rows.append({
            "Detailed_Phenotype": ph,
            "n_Short": int(np.isfinite(s).sum()),
            "n_Intermediate": int(np.isfinite(i).sum()),
            "n_Long": int(np.isfinite(l).sum()),
            "MW_p_Short_vs_Intermediate": p_si,
            "MW_p_Short_vs_Long": p_sl,
        })

    stats_df = pd.DataFrame(stats_rows)
    stats_df.to_csv(Path(outdir) / "Stage2_Proportion_BySurvival_ShortComparisons.csv", index=False)

    for ph in group_order:
        sub = df[df["Detailed_Phenotype"] == ph].dropna(subset=["SurvivalCategory"])
        if sub.empty:
            continue

        p_si = np.nan
        p_sl = np.nan
        if not stats_df.empty and ph in set(stats_df["Detailed_Phenotype"]):
            row = stats_df.loc[stats_df["Detailed_Phenotype"] == ph].iloc[0]
            p_si = row["MW_p_Short_vs_Intermediate"]
            p_sl = row["MW_p_Short_vs_Long"]

        title = ph
        if np.isfinite(p_si) or np.isfinite(p_sl):
            title = f"{ph}\nMWU p: Short vs Intermediate={p_si:.3g} | Short vs Long={p_sl:.3g}"

        save_boxplot(
            sub,
            "SurvivalCategory",
            "MedianProportion",
            ["Short", "Intermediate", "Long"],
            surv_palette,
            Path(outdir) / f"{safe_name(ph)}_Proportion_BySurvival.png",
            title=title,
            xlabel="Survival Category",
            ylabel="Median Proportion (%)",
        )


