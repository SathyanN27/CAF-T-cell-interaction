# Stage 1: Median Density (by Detailed_Phenotype)
# ──────────────────────────────────────────────────────────────────────────────
def stage1_median_density(final_data, area_data, outdir, group_order, palette_dict):
    ensure_dir(outdir)

    area_lookup = area_data[["ROI_KEY", "Total"]].drop_duplicates()

    merged = final_data.merge(area_lookup, on="ROI_KEY", how="left")

    cnt = (
        merged.groupby(["Spot Id 1", "ROI_KEY", "Detailed_Phenotype"])
        .size()
        .reset_index(name="CellCount")
    )
    cnt = cnt.merge(area_lookup, on="ROI_KEY", how="left")
    cnt["Density"] = cnt["CellCount"] / cnt["Total"]

    df = cnt.groupby(["Spot Id 1", "Detailed_Phenotype"])["Density"].median().reset_index()

    save_boxplot(
        df,
        "Detailed_Phenotype",
        "Density",
        group_order,
        palette_dict,
        Path(outdir) / "MedianDensity_Boxplot.png",
        ylabel="Median Density (cells / area unit)",
    )
    return df

def stage1_density_by_survival(df_density, clinical_df, outdir, group_order, surv_palette):
    ensure_dir(outdir)
    df = df_density.merge(clinical_df[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")
    for ph in group_order:
        sub = df[df["Detailed_Phenotype"] == ph].dropna(subset=["SurvivalCategory"])
        if sub.empty:
            continue
        save_boxplot(
            sub,
            "SurvivalCategory",
            "Density",
            ["Short", "Intermediate", "Long"],
            surv_palette,
            Path(outdir) / f"{safe_name(ph)}_Density_BySurvival.png",
            title=ph,
            xlabel="Survival Category",
            ylabel="Median Density",
        )


