def stage6_compartment_by_nn_tumour(
    final_data,
    outdir,
    mic=0.325002431869506,
    juxta_um=100.0,
    tumour_min_neigh=5,
    tumour_neigh_um=50.0,
    make_scatter=True,
    scatter_max_rois=None,
):
    outdir = Path(outdir)
    ensure_dir(outdir)
    scatter_dir = outdir / "Stage6_ScatterROIs"
    if make_scatter:
        ensure_dir(scatter_dir)

    df = final_data.copy()

    df["DistToTumour_um"] = np.nan
    df["DistBin"] = "NoTumour"
    df["Compartment"] = "Panstromal"

    bin_edges = [0, 50, 100, 200, 300, np.inf]
    bin_labels = ["0–50 µm", "50–100 µm", "100–200 µm", "200–300 µm", ">300 µm"]

    def is_tumour(sub):
        return sub["Main_Cell_Type"].astype(str).str.strip().str.lower().eq("tumour")

    def is_caf(sub):
        return sub["Main_Cell_Type"].astype(str).str.strip().str.lower().eq("caf")

    def is_immune(sub):
        return sub["Main_Cell_Type"].astype(str).str.strip().str.lower().eq("immune")

    qc_rows = []
    plotted = 0

    for roi_key, sub in df.groupby("ROI_KEY"):
        sub_valid = sub.dropna(subset=["X", "Y"]).copy()
        if sub_valid.empty:
            continue

        idx = sub_valid.index.values
        coords_all_px = sub_valid[["X", "Y"]].to_numpy(dtype=float)

        patient_id = sub_valid["Spot Id 1"].iloc[0] if "Spot Id 1" in sub_valid.columns else np.nan
        spot_id = sub_valid["Spot Id 2"].iloc[0] if "Spot Id 2" in sub_valid.columns else np.nan
        block_name = sub_valid["TMA Block Name"].iloc[0] if "TMA Block Name" in sub_valid.columns else ""

        tum = sub_valid[is_tumour(sub_valid)].copy()
        if tum.empty:
            qc_rows.append({
                "ROI_KEY": roi_key,
                "Spot Id 1": patient_id,
                "TMA Block Name": block_name,
                "Spot Id 2": spot_id,
                "n_cells_total": int(len(sub_valid)),
                "n_tumour_total": 0,
                "n_tumour_kept": 0,
                "n_juxta": 0,
                "n_panstromal": int(len(sub_valid)),
                "status": "NO_TUMOUR",
            })
            continue

        tum_coords_px = tum[["X", "Y"]].to_numpy(dtype=float)
        tum_tree = cKDTree(tum_coords_px)

        tumour_neigh_px = tumour_neigh_um / mic
        neigh_lists = tum_tree.query_ball_point(tum_coords_px, r=tumour_neigh_px)
        neigh_counts = np.array([len(nl) - 1 for nl in neigh_lists], dtype=int)
        keep_tum = neigh_counts >= tumour_min_neigh

        tum_kept = tum.loc[tum.index.values[keep_tum]].copy()
        if tum_kept.empty:
            qc_rows.append({
                "ROI_KEY": roi_key,
                "Spot Id 1": patient_id,
                "TMA Block Name": block_name,
                "Spot Id 2": spot_id,
                "n_cells_total": int(len(sub_valid)),
                "n_tumour_total": int(len(tum)),
                "n_tumour_kept": 0,
                "n_juxta": 0,
                "n_panstromal": int(len(sub_valid)),
                "status": "TUMOUR_FILTER_REMOVED_ALL",
            })
            continue

        tree = cKDTree(tum_kept[["X", "Y"]].to_numpy(dtype=float))
        d_px, _ = tree.query(coords_all_px, k=1)
        d_um = d_px * mic

        df.loc[idx, "DistToTumour_um"] = d_um
        df.loc[idx, "DistBin"] = pd.cut(
            d_um,
            bins=bin_edges,
            labels=bin_labels,
            include_lowest=True
        ).astype(object)

        comp = np.where(d_um < juxta_um, "Juxtatumoural", "Panstromal").astype(object)
        df.loc[idx, "Compartment"] = comp

        n_juxta = int(np.sum(comp == "Juxtatumoural"))
        n_pan = int(np.sum(comp == "Panstromal"))

        qc_rows.append({
            "ROI_KEY": roi_key,
            "Spot Id 1": patient_id,
            "TMA Block Name": block_name,
            "Spot Id 2": spot_id,
            "n_cells_total": int(len(sub_valid)),
            "n_tumour_total": int(len(tum)),
            "n_tumour_kept": int(len(tum_kept)),
            "n_juxta": n_juxta,
            "n_panstromal": n_pan,
            "status": "OK",
        })

        if make_scatter and (scatter_max_rois is None or plotted < scatter_max_rois):
            s = sub_valid.copy()
            s["Compartment"] = comp

            mask_t = is_tumour(s)

            mask_i = is_immune(s)
            mask_i_j = mask_i & (s["Compartment"] == "Juxtatumoural")
            mask_i_p = mask_i & (s["Compartment"] == "Panstromal")

            mask_c = is_caf(s)
            mask_c_j = mask_c & (s["Compartment"] == "Juxtatumoural")
            mask_c_p = mask_c & (s["Compartment"] == "Panstromal")

            mask_other = ~(mask_t | mask_i | mask_c)

            plt.figure(figsize=(6.5, 6.5))
            if mask_other.any():
                plt.scatter(
                    s.loc[mask_other, "X"],
                    s.loc[mask_other, "Y"],
                    s=4,
                    c="lightgrey",
                    alpha=0.35,
                    linewidths=0,
                )

            if mask_i_p.any():
                plt.scatter(
                    s.loc[mask_i_p, "X"],
                    s.loc[mask_i_p, "Y"],
                    s=6,
                    c="green",
                    alpha=0.8,
                    linewidths=0,
                    label="Panstromal Immune",
                )
            if mask_c_p.any():
                plt.scatter(
                    s.loc[mask_c_p, "X"],
                    s.loc[mask_c_p, "Y"],
                    s=6,
                    c="orange",
                    alpha=0.85,
                    linewidths=0,
                    label="Panstromal CAF",
                )
            if mask_i_j.any():
                plt.scatter(
                    s.loc[mask_i_j, "X"],
                    s.loc[mask_i_j, "Y"],
                    s=7,
                    c="red",
                    alpha=0.85,
                    linewidths=0,
                    label="Juxtatumoural Immune",
                )
            if mask_c_j.any():
                plt.scatter(
                    s.loc[mask_c_j, "X"],
                    s.loc[mask_c_j, "Y"],
                    s=7,
                    c="yellow",
                    alpha=0.9,
                    linewidths=0,
                    label="Juxtatumoural CAF",
                )
            if mask_t.any():
                plt.scatter(
                    s.loc[mask_t, "X"],
                    s.loc[mask_t, "Y"],
                    s=12,
                    c="blue",
                    alpha=0.95,
                    linewidths=0,
                    label="Tumour",
                )

            plt.gca().invert_yaxis()
            plt.axis("equal")
            plt.xticks([])
            plt.yticks([])

            title_bits = [f"Patient {patient_id}"]
            if str(block_name).strip() not in ["", "nan", "None"]:
                title_bits.append(f"Block {block_name}")
            title_bits.append(f"ROI {spot_id}")
            title_bits.append(f"tumour kept={len(tum_kept)}")
            title_bits.append(f"juxta={n_juxta} pan={n_pan}")
            plt.title(" | ".join(title_bits))

            plt.legend(loc="best", fontsize=8, frameon=True)
            plt.tight_layout()
            plt.savefig(
                scatter_dir / (
                    f"Stage6_Scatter_{safe_name(patient_id)}_"
                    f"{safe_name(block_name)}_{safe_name(spot_id)}.png"
                ),
                dpi=300,
            )
            plt.close()
            plotted += 1

    qc_df = pd.DataFrame(qc_rows)
    qc_df.to_csv(outdir / "Stage6_QC_PerROI.csv", index=False)

    summary = {
        "mic_um_per_px": mic,
        "juxta_um": juxta_um,
        "tumour_neigh_um": tumour_neigh_um,
        "tumour_min_neigh": tumour_min_neigh,
        "n_rois": int(qc_df.shape[0]),
        "n_rois_ok": int((qc_df["status"] == "OK").sum()) if not qc_df.empty else 0,
        "n_rois_no_tumour": int((qc_df["status"] == "NO_TUMOUR").sum()) if not qc_df.empty else 0,
        "total_cells": int(qc_df["n_cells_total"].sum()) if not qc_df.empty else 0,
        "total_tumour_total": int(qc_df["n_tumour_total"].sum()) if not qc_df.empty else 0,
        "total_tumour_kept": int(qc_df["n_tumour_kept"].sum()) if not qc_df.empty else 0,
        "total_juxta": int(qc_df["n_juxta"].sum()) if not qc_df.empty else 0,
        "total_panstromal": int(qc_df["n_panstromal"].sum()) if not qc_df.empty else 0,
    }
    pd.DataFrame([summary]).to_csv(outdir / "Stage6_QC_Summary.csv", index=False)

    qc_hist_dir = outdir / "QC_Histograms"
    ensure_dir(qc_hist_dir)

    dvals = df["DistToTumour_um"].to_numpy(dtype=float)
    dvals = dvals[np.isfinite(dvals)]
    if dvals.size > 0:
        bins_um = np.arange(0, 801, 25)

        plt.figure(figsize=(7, 4))
        plt.hist(dvals, bins=bins_um)
        plt.xlabel("Distance to nearest tumour cell (µm)")
        plt.ylabel("Number of cells")
        plt.title("Stage 6 QC: DistToTumour_um (all finite)")
        plt.tight_layout()
        plt.savefig(qc_hist_dir / "Stage6_QC_Hist_AllCells.png", dpi=300)
        plt.close()

        plt.figure(figsize=(7, 4))
        for comp_ in ["Juxtatumoural", "Panstromal"]:
            subd = df.loc[df["Compartment"] == comp_, "DistToTumour_um"].to_numpy(dtype=float)
            subd = subd[np.isfinite(subd)]
            if subd.size == 0:
                continue
            plt.hist(subd, bins=bins_um, alpha=0.5, label=f"{comp_} (n={subd.size})")
        plt.xlabel("Distance to nearest tumour cell (µm)")
        plt.ylabel("Number of cells")
        plt.title("Stage 6 QC: DistToTumour_um by compartment")
        plt.legend()
        plt.tight_layout()
        plt.savefig(qc_hist_dir / "Stage6_QC_Hist_ByCompartment.png", dpi=300)
        plt.close()

    return df


# ──────────────────────────────────────────────────────────────────────────────
# Stage 7: remove tumour states from PANSTROMAL compartment only
# ──────────────────────────────────────────────────────────────────────────────
STAGE7_PANSTROMAL_EXCLUDE = {"Hypoxic", "Normoxic"}


def _drop_panstromal_tumour_states(df):
    df = df.copy()
    mask = (
        df["Compartment"].eq("Panstromal") &
        df["Detailed_Phenotype"].isin(STAGE7_PANSTROMAL_EXCLUDE)
    )
    n_drop = int(mask.sum())
    if n_drop > 0:
        print(f"Stage 7: dropping {n_drop} panstromal tumour-state rows "
              f"({sorted(STAGE7_PANSTROMAL_EXCLUDE)})")
    return df.loc[~mask].copy()


# ──────────────────────────────────────────────────────────────────────────────
# Stage 7: Within-compartment proportions
# denominator = all remaining cells in that compartment
# NOTE:
#   - Hypoxic/Normoxic are removed from PANSTROMAL only
#   - therefore panstromal denominators are recalculated after removal
# ──────────────────────────────────────────────────────────────────────────────
def stage7_within_compartment_composition(
    final_data,
    outdir,
    group_order,
    summarise="median",
    make_patient_delta_heatmap=True,
):
    outdir = Path(outdir)
    ensure_dir(outdir)
    indiv_dir = outdir / "IndividualPhenotypes"
    ensure_dir(indiv_dir)

    df = final_data.copy()
    df = df[df["Compartment"].isin(["Juxtatumoural", "Panstromal"])].copy()
    df = df.dropna(subset=["Spot Id 1", "ROI_KEY", "Detailed_Phenotype"])
    if df.empty:
        print("Stage 7: no Juxtatumoural/Panstromal rows found.")
        return pd.DataFrame()

    # Remove tumour states from PANSTROMAL only
    df = _drop_panstromal_tumour_states(df)

    if df.empty:
        print("Stage 7: no rows remain after panstromal tumour-state exclusion.")
        return pd.DataFrame()

    # Phenotypes that still make sense for paired Juxta-vs-Pan comparison
    compare_order = [ph for ph in group_order if ph not in STAGE7_PANSTROMAL_EXCLUDE]

    # ROI-level counts and denominators
    cnt = (
        df.groupby(["Spot Id 1", "ROI_KEY", "Compartment", "Detailed_Phenotype"])
        .size()
        .reset_index(name="N_ph")
    )
    den = (
        df.groupby(["Spot Id 1", "ROI_KEY", "Compartment"])
        .size()
        .reset_index(name="N_comp")
    )

    roi_frac = cnt.merge(den, on=["Spot Id 1", "ROI_KEY", "Compartment"], how="left")
    roi_frac["FracWithinCompartment"] = roi_frac["N_ph"] / roi_frac["N_comp"]
    roi_frac.to_csv(outdir / "Stage7_ROI_WithinCompartmentFractions.csv", index=False)

    aggfunc = np.median if summarise.lower() == "median" else np.mean
    pt_frac = (
        roi_frac.groupby(["Spot Id 1", "Compartment", "Detailed_Phenotype"])["FracWithinCompartment"]
        .apply(aggfunc)
        .reset_index(name="FracWithinCompartment")
    )
    pt_frac.to_csv(outdir / "Stage7_Patient_WithinCompartmentFractions.csv", index=False)

    # -------------------------------------------------------------------------
    # Individual paired boxplots
    # Skip Hypoxic/Normoxic because Pan values were deliberately removed
    # -------------------------------------------------------------------------
    for ph in compare_order:
        sub = pt_frac[pt_frac["Detailed_Phenotype"] == ph].copy()
        if sub.empty:
            continue

        piv = (
            sub.pivot(index="Spot Id 1", columns="Compartment", values="FracWithinCompartment")
            .reindex(columns=["Juxtatumoural", "Panstromal"])
        )

        df_long = piv.reset_index().melt(
            id_vars="Spot Id 1",
            value_vars=["Juxtatumoural", "Panstromal"],
            var_name="Compartment",
            value_name="FracWithinCompartment",
        )

        plt.figure(figsize=(5.5, 5))
        sns.boxplot(
            data=df_long,
            x="Compartment",
            y="FracWithinCompartment",
            order=["Juxtatumoural", "Panstromal"],
            palette={"Juxtatumoural": "#377eb8", "Panstromal": "#e41a1c"},
        )
        sns.stripplot(
            data=df_long,
            x="Compartment",
            y="FracWithinCompartment",
            order=["Juxtatumoural", "Panstromal"],
            color="k",
            alpha=0.45,
            size=3,
            jitter=0.15,
        )

        both = piv.dropna(subset=["Juxtatumoural", "Panstromal"])
        for _, row in both.iterrows():
            plt.plot(
                [0, 1],
                [row["Juxtatumoural"], row["Panstromal"]],
                color="grey",
                alpha=0.25,
                linewidth=1,
            )

        plt.title(f"{ph} — within-compartment fraction (per patient)")
        plt.ylabel("Fraction within compartment")
        plt.xlabel("")
        plt.tight_layout()
        plt.savefig(indiv_dir / f"Stage7_{safe_name(ph)}_Juxta_vs_Pan.png", dpi=300)
        plt.close()

    # -------------------------------------------------------------------------
    # Main heatmap
    # Keep full group_order so Hypoxic/Normoxic still appear for Juxta,
    # but their Panstromal cells will be blank/NaN
    # -------------------------------------------------------------------------
    med_by_comp = (
        pt_frac.groupby(["Detailed_Phenotype", "Compartment"])["FracWithinCompartment"]
        .median()
        .reset_index()
    )
    heat = (
        med_by_comp.pivot(index="Detailed_Phenotype", columns="Compartment", values="FracWithinCompartment")
        .reindex(index=group_order, columns=["Juxtatumoural", "Panstromal"])
    )

    plt.figure(figsize=(6, max(5, 0.25 * len(group_order))))
    sns.heatmap(
        heat,
        cmap="RdBu_r",
        vmin=0,
        vmax=0.125,
        annot=False,
        linewidths=0.5,
    )
    plt.title("Stage 7 — median within-compartment fraction (across patients)")
    plt.xlabel("Compartment")
    plt.ylabel("Detailed_Phenotype")
    plt.tight_layout()
    plt.savefig(outdir / "Stage7_MedianFraction_ByCompartment_Heatmap.png", dpi=300)
    plt.close()

    # -------------------------------------------------------------------------
    # Patient delta heatmap
    # Exclude Hypoxic/Normoxic because Pan values were removed
    # -------------------------------------------------------------------------
    if make_patient_delta_heatmap:
        user_exclude_patients = {
            "C02P102",
            "Patient 112",
            "Patient 157",
            "Patient 16",
            "Patient 35",
        }

        piv2 = (
            pt_frac[pt_frac["Detailed_Phenotype"].isin(compare_order)]
            .pivot_table(
                index=["Spot Id 1", "Detailed_Phenotype"],
                columns="Compartment",
                values="FracWithinCompartment",
                aggfunc="first",
            )
            .reset_index()
        )

        piv2["Delta_JuxtaMinusPan"] = (
            piv2.get("Juxtatumoural", np.nan) - piv2.get("Panstromal", np.nan)
        )

        delta = (
            piv2.pivot(index="Spot Id 1", columns="Detailed_Phenotype", values="Delta_JuxtaMinusPan")
            .reindex(columns=compare_order)
        )

        auto_blank_patients = set(delta.index[delta.isna().all(axis=1)].astype(str))
        present_patients = set(delta.index.astype(str))
        manual_excluded_present = user_exclude_patients & present_patients

        excluded_rows = []
        for p in sorted(auto_blank_patients):
            excluded_rows.append({"Spot Id 1": p, "Reason": "All values missing"})
        for p in sorted(manual_excluded_present - auto_blank_patients):
            excluded_rows.append({"Spot Id 1": p, "Reason": "User-requested exclusion"})

        delta_plot = delta.dropna(axis=0, how="all").copy()
        delta_plot = delta_plot.loc[
            ~delta_plot.index.astype(str).isin(user_exclude_patients)
        ].copy()

        delta_plot.to_csv(outdir / "Stage7_PatientDelta_JuxtaMinusPan_FILTERED.csv")
        pd.DataFrame(excluded_rows).to_csv(
            outdir / "Stage7_PatientDelta_ExcludedPatients.csv",
            index=False
        )

        if not delta_plot.empty:
            plt.figure(figsize=(12, max(5, 0.22 * delta_plot.shape[0])))
            sns.heatmap(delta_plot, cmap="RdBu_r", center=0, linewidths=0.3)
            plt.title("Stage 7 — patient delta (Juxta − Pan) within-compartment fractions")
            plt.xlabel("Detailed_Phenotype")
            plt.ylabel("Spot Id 1")
            plt.tight_layout()
            plt.savefig(outdir / "Stage7_PatientDelta_JuxtaMinusPan_Heatmap.png", dpi=300)
            plt.close()
        else:
            print("Stage 7 delta heatmap: no rows remain after exclusions.")

        piv2.to_csv(outdir / "Stage7_PatientDelta_JuxtaMinusPan.csv", index=False)

    return pt_frac


# ──────────────────────────────────────────────────────────────────────────────
# Stage 7: paired Juxta vs Pan stats
# Excludes Hypoxic/Normoxic because Pan values were deliberately removed
# ──────────────────────────────────────────────────────────────────────────────
def stage7_juxta_vs_pan_stats(pt_frac, outdir, group_order):
    outdir = Path(outdir)
    ensure_dir(outdir)

    compare_order = [ph for ph in group_order if ph not in STAGE7_PANSTROMAL_EXCLUDE]
    rows = []

    for ph in compare_order:
        sub = pt_frac[pt_frac["Detailed_Phenotype"] == ph].copy()
        if sub.empty:
            rows.append({
                "Detailed_Phenotype": ph,
                "n_paired_patients": 0,
                "wilcoxon_p": np.nan,
                "median_delta_JuxtaMinusPan": np.nan,
                "mean_delta_JuxtaMinusPan": np.nan,
                "r_effect_if_available": np.nan,
            })
            continue

        piv = (
            sub.pivot(index="Spot Id 1", columns="Compartment", values="FracWithinCompartment")
            .reindex(columns=["Juxtatumoural", "Panstromal"])
        )

        paired = piv.dropna(subset=["Juxtatumoural", "Panstromal"]).copy()
        if paired.empty:
            rows.append({
                "Detailed_Phenotype": ph,
                "n_paired_patients": 0,
                "wilcoxon_p": np.nan,
                "median_delta_JuxtaMinusPan": np.nan,
                "mean_delta_JuxtaMinusPan": np.nan,
                "r_effect_if_available": np.nan,
            })
            continue

        a = paired["Juxtatumoural"].to_numpy(dtype=float)
        b = paired["Panstromal"].to_numpy(dtype=float)
        delta = a - b

        p, r, n = _paired_wilcoxon_p(a, b)

        rows.append({
            "Detailed_Phenotype": ph,
            "n_paired_patients": int(n),
            "wilcoxon_p": p,
            "median_delta_JuxtaMinusPan": float(np.nanmedian(delta)),
            "mean_delta_JuxtaMinusPan": float(np.nanmean(delta)),
            "r_effect_if_available": r,
        })

    res_df = pd.DataFrame(rows)

    res_df["wilcoxon_p_FDR"] = np.nan
    valid = res_df["wilcoxon_p"].notna()
    if valid.any():
        res_df.loc[valid, "wilcoxon_p_FDR"] = smm.multipletests(
            res_df.loc[valid, "wilcoxon_p"],
            method="fdr_bh"
        )[1]

    res_df.to_csv(outdir / "Stage7_Juxta_vs_Pan_Stats.csv", index=False)
    return res_df


# ──────────────────────────────────────────────────────────────────────────────
# Stage 7b: Compartment-specific correlation heatmaps (SPEARMAN)
# Uses WITHIN-COMPARTMENT PROPORTIONS, not density
# Remove Hypoxic/Normoxic from PANSTROMAL only
# NOTE:
#   area_data is kept in the signature for compatibility with main(), but is
#   not used here because compartment-specific area is not available.
# ──────────────────────────────────────────────────────────────────────────────
def stage7b_corr_heatmaps(final_data, group_order, area_data, outdir):
    ensure_dir(outdir)
    outdir = Path(outdir)

    df = final_data.copy()
    df = df[df["Compartment"].isin(["Juxtatumoural", "Panstromal"])].copy()
    df = df.dropna(subset=["Spot Id 1", "ROI_KEY", "Detailed_Phenotype"])

    if df.empty:
        print("Stage 7b: no Juxtatumoural/Panstromal rows found.")
        return

    # Remove tumour states from PANSTROMAL only
    df = _drop_panstromal_tumour_states(df)

    if df.empty:
        print("Stage 7b: no rows remain after panstromal tumour-state exclusion.")
        return

    juxta_order = list(group_order)
    pan_order = [ph for ph in group_order if ph not in STAGE7_PANSTROMAL_EXCLUDE]

    # -------------------------------------------------------------------------
    # Build ROI-level within-compartment fractions
    # denominator = all cells in that compartment within that ROI
    # -------------------------------------------------------------------------
    cnt = (
        df.groupby(["Spot Id 1", "ROI_KEY", "Compartment", "Detailed_Phenotype"])
        .size()
        .reset_index(name="N_ph")
    )
    den = (
        df.groupby(["Spot Id 1", "ROI_KEY", "Compartment"])
        .size()
        .reset_index(name="N_comp")
    )

    roi_frac = cnt.merge(den, on=["Spot Id 1", "ROI_KEY", "Compartment"], how="left")
    roi_frac["FracWithinCompartment"] = roi_frac["N_ph"] / roi_frac["N_comp"]

    roi_frac.to_csv(outdir / "7b_ROI_WithinCompartmentFractions_ForCorrelation.csv", index=False)

    # -------------------------------------------------------------------------
    # Patient-level median across ROIs
    # -------------------------------------------------------------------------
    pt_frac = (
        roi_frac.groupby(["Spot Id 1", "Compartment", "Detailed_Phenotype"])["FracWithinCompartment"]
        .median()
        .reset_index(name="FracWithinCompartment")
    )

    pt_frac.to_csv(outdir / "7b_PatientMedian_WithinCompartmentFractions_ForCorrelation.csv", index=False)

    def comp_df(label_, phenotype_order):
        sub = pt_frac[pt_frac["Compartment"] == label_].copy()
        if sub.empty:
            return pd.DataFrame(index=[], columns=phenotype_order).fillna(0)

        return (
            sub.pivot(index="Spot Id 1", columns="Detailed_Phenotype", values="FracWithinCompartment")
            .reindex(columns=phenotype_order)
            .fillna(0)
        )

    pj = comp_df("Juxtatumoural", juxta_order)
    pp = comp_df("Panstromal", pan_order)

    # -------------------------------------------------------------------------
    # A) Juxtatumoural — Spearman correlation
    # -------------------------------------------------------------------------
    juxta_corr = pj.corr(method="spearman")
    save_triangle_corr_heatmap(
        juxta_corr,
        outdir / "7b_Corr_Juxtatumoural_TRI.png",
        title="7b.1 Juxtatumoural (Spearman, within-compartment fraction)",
        cmap=HEATMAP_CMAP,
    )

    juxta_corr.to_csv(outdir / "7b_Corr_Juxtatumoural_TRI.csv")

    # -------------------------------------------------------------------------
    # B) Panstromal — Spearman correlation
    # -------------------------------------------------------------------------
    pan_corr = pp.corr(method="spearman")
    save_triangle_corr_heatmap(
        pan_corr,
        outdir / "7b_Corr_Panstromal_TRI.png",
        title="7b.2 Panstromal (Spearman, within-compartment fraction)",
        cmap=HEATMAP_CMAP,
