def stage3_correlation(df_density, df_prop, group_order, outdir):
    ensure_dir(outdir)
    dp = (
        df_density.pivot(index="Spot Id 1", columns="Detailed_Phenotype", values="Density")
        .reindex(columns=group_order)
        .fillna(0)
    )
    pp = (
        df_prop.pivot(index="Spot Id 1", columns="Detailed_Phenotype", values="MedianProportion")
        .reindex(columns=group_order)
        .fillna(0)
    )

    save_triangle_corr_heatmap(
        dp.corr(),
        Path(outdir) / "Density_CorrHeatmap_TRI.png",
        title="Density correlation (triangle)",
        cmap=HEATMAP_CMAP,
    )
    save_triangle_corr_heatmap(
        pp.corr(),
        Path(outdir) / "Proportion_CorrHeatmap_TRI.png",
        title="Proportion correlation (triangle)",
        cmap=HEATMAP_CMAP,
    )


