# Stage 4: Mann–Whitney Tests (Detailed proportions by survival)
# ──────────────────────────────────────────────────────────────────────────────
def stage4_mannwhitney_detailed(df_prop, clinical_df, outdir):
    ensure_dir(outdir)
    sp = df_prop.merge(clinical_df[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")
    rows = []
    for ph, grp_df in sp.groupby("Detailed_Phenotype"):
        grp = grp_df.dropna(subset=["SurvivalCategory"]).groupby("SurvivalCategory")["MedianProportion"].apply(list)
        row = {"Phenotype": ph}
        for a, b in [("Short", "Intermediate"), ("Short", "Long"), ("Intermediate", "Long")]:
            row[f"{a}_vs_{b}"] = (
                mannwhitneyu(grp.get(a, []), grp.get(b, []))[1]
                if a in grp and b in grp and len(grp.get(a, [])) >= 2 and len(grp.get(b, [])) >= 2
                else np.nan
            )
        rows.append(row)
    pd.DataFrame(rows).to_csv(Path(outdir) / "MannWhitney_Detailed.csv", index=False)


# ──────────────────────────────────────────────────────────────────────────────
# Stage 5: Mann–Whitney Tests (per patient, proportions)
# ──────────────────────────────────────────────────────────────────────────────
def stage5_mannwhitney_per_spot(final_data, clinical_df, outdir):
    ensure_dir(outdir)

    prop = (
        final_data.groupby(["Spot Id 1", "ROI_KEY", "Detailed_Phenotype"])
        .size()
        .reset_index(name="CellCount")
    )
    tot = (
        final_data.groupby(["Spot Id 1", "ROI_KEY"])
        .size()
        .reset_index(name="TotalCount")
    )
    det = prop.merge(tot, on=["Spot Id 1", "ROI_KEY"], how="left")
    det["Proportion"] = det["CellCount"] / det["TotalCount"] * 100

    med = (
        det.groupby(["Spot Id 1", "Detailed_Phenotype"])["Proportion"]
        .median()
        .reset_index(name="MedProp")
    )

    det_surv = med.merge(clinical_df[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")
    rows = []
    for ph, sub in det_surv.groupby("Detailed_Phenotype"):
        grp = sub.dropna(subset=["SurvivalCategory"]).groupby("SurvivalCategory")["MedProp"].apply(list)
        row = {"Phenotype": ph}
        for a, b in [("Short", "Intermediate"), ("Short", "Long"), ("Intermediate", "Long")]:
            row[f"{a}_vs_{b}"] = (
                mannwhitneyu(grp.get(a, []), grp.get(b, []))[1]
                if a in grp and b in grp and len(grp.get(a, [])) >= 2 and len(grp.get(b, [])) >= 2
                else np.nan
            )
        rows.append(row)
    pd.DataFrame(rows).to_csv(Path(outdir) / "MannWhitney_PerPatient.csv", index=False)


