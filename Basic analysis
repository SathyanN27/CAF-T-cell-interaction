def stage9_quadrant_stats(quad_df, clinical_df, outdir):
    ensure_dir(outdir)
    quad_palette = [
        "Low infiltration Included",
        "High infiltration Included",
        "Low infiltration Excluded",
        "High infiltration Excluded",
    ]
    qmap = {k: i for i, k in enumerate(quad_palette)}
    df = quad_df.merge(clinical_df[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")
    df["QuadCode"] = df["Quadrant"].map(qmap)

    results = []
    comparisons = [("Short", "Intermediate"), ("Short", "Long"), ("Intermediate", "Long")]

    for ph in df["Detailed_Phenotype"].unique():
        sub = df[df["Detailed_Phenotype"] == ph].dropna(subset=["SurvivalCategory"])
        groups = {
            cat: sub[sub["SurvivalCategory"] == cat]["QuadCode"].dropna().values
            for cat in ["Short", "Intermediate", "Long"]
        }
        if sum(len(v) > 0 for v in groups.values()) < 2:
            continue
        try:
            _, kw_p = kruskal(*[groups[cat] for cat in ["Short", "Intermediate", "Long"] if len(groups[cat]) > 0])
        except Exception:
            kw_p = np.nan

        row = {"Phenotype": ph, "KW_p": kw_p}
        for a, b in comparisons:
            if len(groups.get(a, [])) > 0 and len(groups.get(b, [])) > 0:
                try:
                    mw_p = mannwhitneyu(groups[a], groups[b], alternative="two-sided")[1]
                except Exception:
                    mw_p = np.nan
            else:
                mw_p = np.nan
            row[f"{a}_vs_{b}_p"] = mw_p
        results.append(row)

    res_df = pd.DataFrame(results)
    if not res_df.empty:
        res_df["KW_p_FDR"] = smm.multipletests(res_df["KW_p"].fillna(1), method="fdr_bh")[1]
        for a, b in comparisons:
            col = f"{a}_vs_{b}_p"
            res_df[f"{col}_FDR"] = smm.multipletests(res_df[col].fillna(1), method="fdr_bh")[1]

    res_df.to_csv(Path(outdir) / "Quadrant_Stats_BySurvival.csv", index=False)
    return res_df


