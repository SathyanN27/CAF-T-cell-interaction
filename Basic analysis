# Stage 8a: Distance-bin quadrants + patient proportions per quadrant
# ──────────────────────────────────────────────────────────────────────────────
def stage8a_quadrant_scatter(final_data, outdir, group_order, near_bins=None, far_bins=None):
    ensure_dir(outdir)
    outdir = Path(outdir)

    if near_bins is None:
        near_bins = ["0–50 µm", "50–100 µm"]
    if far_bins is None:
        far_bins = ["100–200 µm", "200–300 µm", ">300 µm"]

    df = final_data.copy()
    df = df.dropna(subset=["DistBin"])
    df = df[df["DistBin"] != "NoTumour"]

    if df.empty:
        print("Stage 8a: no rows with defined DistBin (tumour absent everywhere).")
        return pd.DataFrame()

    frac_all = df.groupby(["Spot Id 1", "Detailed_Phenotype"]).size().reset_index(name="Count")
    frac_tot = df.groupby("Spot Id 1").size().reset_index(name="Total")
    ov = frac_all.merge(frac_tot, on="Spot Id 1")
    ov["OverallFraction"] = ov["Count"] / ov["Total"]

    near_df = df[df["DistBin"].isin(near_bins)]
    near_counts = near_df.groupby(["Spot Id 1", "Detailed_Phenotype"]).size().reset_index(name="NearCount")

    far_df = df[df["DistBin"].isin(far_bins)]
    far_counts = far_df.groupby(["Spot Id 1", "Detailed_Phenotype"]).size().reset_index(name="FarCount")

    prox = near_counts.merge(far_counts, on=["Spot Id 1", "Detailed_Phenotype"], how="outer").fillna(0)
    prox["TotalNF"] = prox["NearCount"] + prox["FarCount"]
    prox = prox[prox["TotalNF"] > 0]
    if prox.empty:
        print("Stage 8a: no cells fall into near/far bins.")
        return pd.DataFrame()

    prox["ProximalFraction"] = prox["NearCount"] / prox["TotalNF"]

    merged = ov.merge(
        prox[["Spot Id 1", "Detailed_Phenotype", "ProximalFraction"]],
        on=["Spot Id 1", "Detailed_Phenotype"],
        how="inner",
    )

    rows = []
    pdf = PdfPages(outdir / "QuadrantPlots_DistBins.pdf")

    for ph in group_order:
        sub = merged[merged["Detailed_Phenotype"] == ph]
        if sub.empty:
            continue

        med_overall = sub["OverallFraction"].median()
        med_prox = sub["ProximalFraction"].median()

        for _, r in sub.iterrows():
            x = r["OverallFraction"] - med_overall
            y = r["ProximalFraction"] - med_prox

            if x > 0 and y > 0:
                quad = "High infiltration Included"
            elif x < 0 and y > 0:
                quad = "Low infiltration Included"
            elif x < 0 and y < 0:
                quad = "Low infiltration Excluded"
            else:
                quad = "High infiltration Excluded"

            rows.append({
                "Spot Id 1": r["Spot Id 1"],
                "Detailed_Phenotype": ph,
                "OverallFraction": r["OverallFraction"],
                "ProximalFraction": r["ProximalFraction"],
                "OverallCentered": x,
                "ProximalCentered": y,
                "Quadrant": quad,
            })

        d_plot = sub.copy()
        d_plot["OverallCentered"] = d_plot["OverallFraction"] - med_overall
        d_plot["ProximalCentered"] = d_plot["ProximalFraction"] - med_prox

        plt.figure(figsize=(5, 5))
        sns.scatterplot(x="OverallCentered", y="ProximalCentered", data=d_plot)
        plt.axhline(0, ls="--", color="grey")
        plt.axvline(0, ls="--", color="grey")
        plt.title(ph)
        plt.xlabel("Overall fraction (centered per phenotype)")
        plt.ylabel("Proximal fraction (0–100 µm, centered)")
        plt.tight_layout()
        pdf.savefig()
        plt.close()

    pdf.close()

    quad_df = pd.DataFrame(rows)
    if quad_df.empty:
        return quad_df

    quads_order = [
        "Low infiltration Included",
        "High infiltration Included",
        "Low infiltration Excluded",
        "High infiltration Excluded",
    ]
    counts = (
        quad_df.groupby(["Detailed_Phenotype", "Quadrant"])["Spot Id 1"]
        .nunique()
        .unstack(fill_value=0)
        .reindex(columns=quads_order, fill_value=0)
    )
    props = counts.div(counts.sum(axis=1).replace(0, np.nan), axis=0).fillna(0)

    counts.to_csv(outdir / "Stage8a_Quadrant_PatientCounts_ByPhenotype.csv")
    props.to_csv(outdir / "Stage8a_Quadrant_PatientProportions_ByPhenotype.csv")

    plt.figure(figsize=(10, max(4, len(props) * 0.35)))
    sns.heatmap(props, annot=True, fmt=".2f", cmap=HEATMAP_CMAP, vmin=0, vmax=1, linewidths=0.5)
    plt.title("Stage 8a: Proportion of patients in each quadrant (per phenotype)")
    plt.xlabel("Quadrant")
    plt.ylabel("Detailed_Phenotype")
    plt.tight_layout()
    plt.savefig(outdir / "Stage8a_Quadrant_PatientProportions_Heatmap.png", dpi=300)
    plt.close()

    quad_df.to_csv(outdir / "Stage8a_Quadrant_Assignments.csv", index=False)
    return quad_df


