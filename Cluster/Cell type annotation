def safe_npcs(adata, cap=20):
    """
    Return a safe number of PCs: <= n_vars and <= n_obs-1, at least 1, capped by 'cap'.
    (Amendment #2)
    """
    return int(max(1, min(cap, adata.n_vars, adata.n_obs - 1)))

