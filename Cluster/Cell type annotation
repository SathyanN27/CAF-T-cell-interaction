def subcluster_immune_subtype(df, subtype_name, subtype_markers, outdir, resolution=0.2):
    """
    Immune sub-subclustering within a given immune subtype (e.g., CD4, CD8, B Cell, Macrophage).

    - Supports single-marker panels:
        * If n_features == 1: skip PCA, build neighbors directly on scaled X (use_rep="X").
        * Else: scale -> PCA -> neighbors with safe_npcs.
    - Produces:
        * Z-score (per-marker) heatmap of sub-subcluster means (±2 cap; centered at 0; RdBu_r)
        * UMAP scatter colored by sub-subcluster ID
    - Skips gracefully if too few cells or zero variance.
    """
    subset = df[df["Immune_Subcluster_Label"] == subtype_name].copy()
    # Need enough cells to form a graph; allow ≥1 marker
    if subset.shape[0] < 3 or len(subtype_markers) < 1:
        print(f"Skipping {subtype_name}: cells={subset.shape[0]}, markers={len(subtype_markers)} (need ≥3 cells & ≥1 marker).")
        return

    have = [m for m in subtype_markers if m in subset.columns]
    if len(have) < 1:
        print(f"Skipping {subtype_name}: none of the requested markers present.")
        return

    X = subset[have].astype(float).values
    adata = sc.AnnData(
        X,
        obs=pd.DataFrame(index=subset.index.astype(str)),
        var=pd.DataFrame(index=have)
    )

    try:
        sc.pp.scale(adata, zero_center=True, max_value=10)
        nn = int(max(2, min(15, adata.n_obs - 1)))

        if adata.n_vars == 1:
            # Single-marker path: require finite variability; skip PCA
            if not np.isfinite(adata.X).all() or float(np.std(adata.X)) == 0.0:
                print(f"Skipping {subtype_name}: single marker has zero/near-zero variance.")
                return
            sc.pp.neighbors(adata, n_neighbors=nn, use_rep="X")
        else:
            sc.tl.pca(adata, svd_solver='auto')
            sc.pp.neighbors(adata, n_neighbors=nn, n_pcs=safe_npcs(adata))

        sc.tl.leiden(adata, resolution=resolution, flavor="igraph", n_iterations=2, directed=False)
        sc.tl.umap(adata, random_state=42)

        cluster_col = f"{subtype_name}_SubSubCluster"
        umap_col1   = f"UMAP_{subtype_name}_1"
        umap_col2   = f"UMAP_{subtype_name}_2"

        # Write back assignments & UMAP
        df.loc[adata.obs_names, cluster_col] = adata.obs["leiden"].astype(int).values
        df.loc[adata.obs_names, umap_col1]   = adata.obsm["X_umap"][:, 0]
        df.loc[adata.obs_names, umap_col2]   = adata.obsm["X_umap"][:, 1]

        # ---- Z-score (per-marker) heatmap of sub-subcluster means ----
        sub_subset = df.loc[adata.obs_names]
        aggregated = sub_subset.groupby(cluster_col)[have].mean()

        def _zscore_cols(m):
            def zcol(col):
                sd = col.std(ddof=0)
                if not np.isfinite(sd) or sd == 0:
                    return (col - col.mean()) * 0  # neutral if no variance
                return (col - col.mean()) / sd
            return m.apply(zcol, axis=0).clip(-2, 2)

        z = _zscore_cols(aggregated)

        plt.figure(figsize=(max(8, 1.8 + 0.6 * len(have)),
                            max(5, 1.8 + 0.6 * z.shape[0])))
        sns.heatmap(
            z, cmap="RdBu_r", center=0, annot=True, fmt=".2f",
            linewidths=0.5, linecolor="gray",
            cbar_kws={'label': 'Marker Z-score (±2 cap)'}
        )
        plt.xticks(rotation=45, ha='right')
        plt.xlabel("Markers")
        plt.ylabel(f"{subtype_name} Sub-Subcluster")
        plt.title(f"{subtype_name} Sub-Subcluster Marker Expression (Z-score)")
        plt.tight_layout()
        heatmap_path = os.path.join(outdir, f"Heatmap_{subtype_name}_SubSubclusters_Zscore.png")
        plt.savefig(heatmap_path, dpi=300)
        plt.close()
        print(f"Z-score heatmap for {subtype_name} saved: {heatmap_path}")

        # ---- UMAP ----
        plt.figure(figsize=(8, 6))
        sns.scatterplot(x=umap_col1, y=umap_col2, hue=cluster_col,
                        data=sub_subset, palette="tab10", s=10, legend="full")
        plt.title(f"{subtype_name} Sub-Subcluster UMAP")
        plt.xlabel("UMAP1"); plt.ylabel("UMAP2")
        plt.legend(title=f"{subtype_name} Sub-Subcluster", bbox_to_anchor=(1, 0.5))
        plt.tight_layout()
        umap_path = os.path.join(outdir, f"UMAP_{subtype_name}_SubSubclusters.png")
        plt.savefig(umap_path, dpi=300); plt.close()
        print(f"UMAP for {subtype_name} saved: {umap_path}")

        n_clusters = len(np.unique(adata.obs['leiden']))
        print(f"For {subtype_name} sub-subclustering, there are {n_clusters} clusters.")

    except Exception as e:
        print(f"Sub-subclustering failed for {subtype_name}: {e}. Assigning a single cluster (0).")
        cluster_col = f"{subtype_name}_SubSubCluster"
        umap_col1   = f"UMAP_{subtype_name}_1"
        umap_col2   = f"UMAP_{subtype_name}_2"
        df.loc[subset.index, cluster_col] = 0
        df.loc[subset.index, [umap_col1, umap_col2]] = np.nan

