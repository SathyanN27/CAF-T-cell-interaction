def plot_subcluster_heatmaps(df, cluster_col, markers, label, outdir, clusters_per_page=15):
    # nothing to plot?
    if df[cluster_col].notna().sum() == 0:
        print(f"No {label} subcluster assignments to plot.")
        return

    # Mean per subcluster
    means = df.groupby(cluster_col)[markers].mean()

    # Z-score per marker (column-wise) with ±2 cap; avoid div/0 if std = 0
    def zscore_col(col):
        sd = col.std(ddof=0)
        if sd == 0 or np.isnan(sd):
            return (col - col.mean())  # will be all zeros
        return (col - col.mean()) / sd
    z = means.apply(zscore_col, axis=0).clip(-2, 2)

    # Paginate
    n_clusters = z.shape[0]
    n_pages = math.ceil(n_clusters / clusters_per_page)
    for page in range(n_pages):
        start = page * clusters_per_page
        end = min(start + clusters_per_page, n_clusters)
