def assign_final_phenotype(row):
    if row["RefinedPhenotype"] == "Tumour":
        return row.get("Tumour_Subcluster_Label") if pd.notnull(row.get("Tumour_Subcluster_Label")) else "Tumour"
    elif row["RefinedPhenotype"] == "CAF":
        return row.get("CAF_Subcluster_Label") if pd.notnull(row.get("CAF_Subcluster_Label")) else "CAF"
    elif row["RefinedPhenotype"] == "Immune":
        return row.get("Final_Immune_Label") if pd.notnull(row.get("Final_Immune_Label")) else "Immune"
    elif row["RefinedPhenotype"] == "Endothelial":
        return "Endothelial"
    elif row["RefinedPhenotype"] == "Other":
        return "Other"
    else:
        return row["RefinedPhenotype"]

normalized_data["Final_Phenotype"] = normalized_data.apply(assign_final_phenotype, axis=1)

def get_detailed_phenotype(row):
    if row["RefinedPhenotype"] == "Tumour":
        return row.get("Tumour_Subcluster_Label", row["RefinedPhenotype"])
    elif row["RefinedPhenotype"] == "CAF":
        return row.get("CAF_Subcluster_Label", row["RefinedPhenotype"])
    elif row["RefinedPhenotype"] == "Immune":
        # Use broad immune type when no detailed label
        if pd.notnull(row.get("Immune_Subcluster_Label")):
            label = row.get("Immune_Subcluster_Label")
            return label if label.lower() != "other immune" else "other immune"
        else:
            return row["RefinedPhenotype"]
    elif row["RefinedPhenotype"] == "Endothelial":
        return "Endothelial"
    elif row["RefinedPhenotype"] == "Other":
        return "Other"
    else:
        return "Other"

normalized_data["Detailed_Phenotype"] = normalized_data.apply(get_detailed_phenotype, axis=1)

# Cluster number columns
normalized_data["MainCluster_Number"] = normalized_data["MainCluster"]

def get_subcluster_number(row):
    if pd.notnull(row.get("Tumour_Subcluster")):
        return row.get("Tumour_Subcluster")
    elif pd.notnull(row.get("CAF_Subcluster")):
        return row.get("CAF_Subcluster")
    elif pd.notnull(row.get("Immune_Subcluster")):
        return row.get("Immune_Subcluster")
    else:
        return np.nan

normalized_data["Subcluster_Number"] = normalized_data.apply(get_subcluster_number, axis=1)

# Ensure sub-subcluster numeric columns exist
for col in ["CD4_SubSubCluster", "CD8_SubSubCluster", "B Cell_SubSubCluster", "Macrophage_SubSubCluster"]:
    if col not in normalized_data.columns:
        normalized_data[col] = np.nan

