# Fill missing with 0 for bounds calc
data[all_markers] = data[all_markers].fillna(0)

lower_bounds = data[all_markers].quantile(0.01)
upper_bounds = data[all_markers].quantile(0.99)

data_excluded = data[all_markers].copy()
for marker in all_markers:
    mask = (data_excluded[marker] >= lower_bounds[marker]) & (data_excluded[marker] <= upper_bounds[marker])
    data_excluded.loc[~mask, marker] = np.nan

# Log1p on positive-shifted values to avoid log(0)
