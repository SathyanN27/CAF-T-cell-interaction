def combine_immune_labels(row):
    # Prefer detailed sub-subcluster labels (for CD4/CD8/B Cell/Macro)
    for col in ["CD4_SubSubCluster_Label", "CD8_SubSubCluster_Label",
                "Bcell_SubSubCluster_Label", "Macrophage_SubSubCluster_Label"]:
        val = row.get(col)
        if pd.notnull(val):
            return val
    # Else, fall back to the broad immune subcluster label (includes "Other Immune")
    if pd.notnull(row.get("Immune_Subcluster_Label")):
        return row.get("Immune_Subcluster_Label")
    return "Unknown"

normalized_data["Final_Immune_Label"] = normalized_data.apply(
    lambda r: combine_immune_labels(r) if r["RefinedPhenotype"] == "Immune" else np.nan, axis=1
)

