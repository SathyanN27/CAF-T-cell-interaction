def ensure_dir(path):
    Path(path).mkdir(parents=True, exist_ok=True)


def _canon_col(s: str) -> str:
    s = str(s).strip().lower()
    s = re.sub(r"[^a-z0-9]+", "", s)
    return s


def find_column(df: pd.DataFrame, candidates):
    canon_map = {_canon_col(c): c for c in df.columns}
    for cand in candidates:
        cc = _canon_col(cand)
        if cc in canon_map:
            return canon_map[cc]
    return None


def normalize_matrix_global(mat: pd.DataFrame) -> pd.DataFrame:
    total = float(np.nansum(mat.values))
    if total <= 0:
        return mat.copy()
    return mat / total


def normalize_matrix_rowwise(mat: pd.DataFrame) -> pd.DataFrame:
    out = mat.copy().astype(float)
    row_sums = out.sum(axis=1).replace(0, np.nan)
    out = out.div(row_sums, axis=0).fillna(0.0)
    return out


def median_mats(mats):
    if len(mats) == 0:
        return None

    ref = mats[0]
    arr = np.stack(
        [m.reindex(index=ref.index, columns=ref.columns).to_numpy(dtype=float) for m in mats],
        axis=0
    )
    med = np.nanmedian(arr, axis=0)
    return pd.DataFrame(med, index=ref.index, columns=ref.columns)


def epsilon_squared_kw(H, k, n):
    denom = (n - k)
    if denom <= 0:
        return np.nan
    return max(0.0, (H - k + 1.0) / denom)


def add_core_key(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()
    df["Spot Id 1"] = df["Spot Id 1"].astype(str).str.strip()
    df["Spot Id 2"] = df["Spot Id 2"].astype(str).str.strip()

    if "TMA Block Name" in df.columns:
        df["TMA Block Name"] = df["TMA Block Name"].astype(str).str.strip()
        df["CORE_KEY"] = (
            df["Spot Id 1"] + "__" +
            df["TMA Block Name"] + "__" +
            df["Spot Id 2"]
        )
    else:
        df["CORE_KEY"] = df["Spot Id 1"] + "__" + df["Spot Id 2"]

    return df


def preprocess_clinical(
    df: pd.DataFrame,
    patient_col_candidates=("Spot Id 1", "SpotId1", "Donor ID", "DonorID", "Patient", "PatientID"),
    os_days_candidates=(
        "Overall Survival (days)",
        "Overall_Survival_(days)",
        "Overall Survival Days",
        "OverallSurvivaldays",
        "OverallSurvivalDays",
        "OS_days",
        "OSDays",
    ),
    followup_candidates=("Follow_up", "Follow up", "Followup", "FollowUp"),
) -> pd.DataFrame:
    """
    Returns:
      ['Spot Id 1', 'SurvivalDays', 'SurvivalCategory']
    """
    df = df.copy()

    pt_col = find_column(df, patient_col_candidates)
    if pt_col is None:
        raise ValueError(
            f"Could not find patient ID column. Tried: {list(patient_col_candidates)}. "
            f"Seen: {list(df.columns)}"
        )

    os_col = find_column(df, os_days_candidates)
    if os_col is None:
        raise ValueError(
            f"Could not find OS days column. Tried: {list(os_days_candidates)}. "
            f"Seen: {list(df.columns)}"
        )

    fu_col = find_column(df, followup_candidates)

    out = df.rename(columns={pt_col: "Spot Id 1", os_col: "SurvivalDays"}).copy()
    out["Spot Id 1"] = out["Spot Id 1"].astype(str).str.strip()

    out = out[~out["SurvivalDays"].astype(str).str.contains("lost to follow up", case=False, na=False)]

    if fu_col is not None:
        mask = out["SurvivalDays"].astype(str).str.strip().isin(["NA", "N/A", "nan", "None", ""])
        out.loc[mask, "SurvivalDays"] = df.loc[out.index, fu_col]

    out["SurvivalDays"] = pd.to_numeric(out["SurvivalDays"], errors="coerce")
    out = out.dropna(subset=["Spot Id 1", "SurvivalDays"]).copy()

    out = out.groupby("Spot Id 1", as_index=False)["SurvivalDays"].max()

    out["SurvivalCategory"] = pd.cut(
        out["SurvivalDays"],
        bins=[-np.inf, 540, 900, np.inf],
        labels=["Short", "Intermediate", "Long"]
    )

    return out[["Spot Id 1", "SurvivalDays", "SurvivalCategory"]]


# -------------------- LABEL NORMALISATION --------------------

def normalise_final_label(x):
    if pd.isna(x):
        return np.nan
    s = str(x).strip()
    fixes = {
        "Other immune": "Other Immune",
        "OTHER IMMUNE": "Other Immune",
        "Tripple negative": "Triple negative",
        "Tripple Negative": "Triple negative",
        "Tripple positive": "Triple positive",
        "Tripple Positive": "Triple positive",
    }
    return fixes.get(s, s)


def normalise_detailed_label(x):
    if pd.isna(x):
        return np.nan
    s = str(x).strip()
    fixes = {
        "Other immune": "Other Immune",
        "OTHER IMMUNE": "Other Immune",
        "Tripple negative": "Triple negative",
        "Tripple positive": "Triple positive",
    }
    return fixes.get(s, s)


def normalise_main_phenotype_label(x):
    if pd.isna(x):
        return np.nan
    s = str(x).strip().lower()

    if s in {"tumour", "tumor", "tumour cell", "tumor cell"}:
        return "Tumour"
    if "tum" in s:
        return "Tumour"
    return str(x).strip()


def derive_immune_main_from_detailed(x):
    """
    Coarse immune class derived from Detailed_Phenotype.
    """
    if pd.isna(x):
        return np.nan

    s = str(x).strip()
    lc = s.lower()

    if "apc" in lc:
        return "APC"

    if lc.startswith("cd4") or "treg" in lc or lc == "follicular":
        return "CD4"

    if lc.startswith("cd8"):
        return "CD8"

    if ("b cell" in lc) or (lc in {"gc-", "gc+", "gc- fdr+", "gc- fdr"}):
        return "B Cell"

    if (lc in {"m1", "m2"}) or ("macroph" in lc):
        return "Macrophage"

    if "other immune" in lc:
        return "Other Immune"

    return np.nan


def derive_immune_main_from_final(x):
    """
    Immune main class derived from Final_Phenotype.
    Used for colouring subtype-level circular plots.
    """
    if pd.isna(x):
        return np.nan

    s = str(x).strip()
    lc = s.lower()

    if lc == "apc":
        return "APC"

    if lc in {"b cell", "b cell fdr+"}:
        return "B Cell"

    if lc.startswith("cd4") or lc == "treg":
        return "CD4"

    if lc.startswith("cd8"):
        return "CD8"

    if lc in {"m1", "m2"} or "macroph" in lc:
        return "Macrophage"

    if "other immune" in lc:
        return "Other Immune"

    return np.nan


def prepare_analysis_columns(
    final_data: pd.DataFrame,
    final_col: str,
    detailed_col: str,
):
    df = final_data.copy()
    df = add_core_key(df)

    df[final_col] = df[final_col].apply(normalise_final_label)
    df[detailed_col] = df[detailed_col].apply(normalise_detailed_label)

    caf_labels_master = [
        "Subtype A",
        "Subtype B",
        "Subtype C",
        "Triple negative",
        "Triple positive",
    ]

    immune_final_preferred_order = [
        "APC",
        "B Cell",
        "B Cell FDR+",
        "CD4 Conventional",
        "CD8 AE",
        "CD8 Bystander",
        "CD8 Cytotoxic",
        "CD8 Exhausted",
        "M1",
        "M2",
        "Other Immune",
        "Treg",
    ]

    df["CAF_Subtype"] = np.where(df[final_col].isin(caf_labels_master), df[final_col], np.nan)

    df["Immune_Main_From_Detailed"] = df[detailed_col].apply(derive_immune_main_from_detailed)

    df["Immune_Final_Label"] = df[final_col].where(
        df[final_col].apply(lambda x: pd.notna(derive_immune_main_from_final(x)))
    )
    df["Immune_Final_Main"] = df["Immune_Final_Label"].apply(derive_immune_main_from_final)

    final_present = list(pd.unique(df[final_col].dropna()))
    caf_labels = [x for x in caf_labels_master if x in set(final_present)]

    immune_main_order = [
        x for x in ["CD4", "CD8", "B Cell", "Macrophage", "APC", "Other Immune"]
        if x in set(df["Immune_Main_From_Detailed"].dropna().unique())
    ]

    immune_final_present = list(pd.unique(df["Immune_Final_Label"].dropna()))
    immune_final_order = [x for x in immune_final_preferred_order if x in immune_final_present]
    immune_final_remaining = [x for x in immune_final_present if x not in set(immune_final_order)]
    immune_final_order.extend(sorted(immune_final_remaining))

    print("[INFO] CAF labels:", caf_labels)
    print("[INFO] Immune main classes from Detailed_Phenotype:", immune_main_order)
    print("[INFO] Immune final phenotypes from Final_Phenotype:", immune_final_order)

    return df, caf_labels, immune_main_order, immune_final_order


# -------------------- DENSE TUMOUR / PROXIMITY FLAGS --------------------

def add_dense_tumour_proximity_flags(
    df: pd.DataFrame,
    main_col: str,
    radius_dense_um: float = 50.0,
    min_other_tumour_neighbours: int = 5,
    caf_to_tumour_um: float = 30.0,
    microns_per_pixel: float = 0.325002431869506,
    coords_are_pixels: bool = True,
):
    """
    Adds:
      - Is_Tumour_Main
      - Is_Dense_Tumour_50um
      - Dist_to_Dense_Tumour_um
      - CAF_Proximal_30um

    Returns core-level QC dataframe.
    """
    df = df.copy()

    if "CORE_KEY" not in df.columns:
        df = add_core_key(df)

    if main_col not in df.columns:
        raise ValueError(f"Column '{main_col}' not found in dataframe.")

    df["_Main_Norm"] = df[main_col].apply(normalise_main_phenotype_label)
    df["Is_Tumour_Main"] = df["_Main_Norm"].eq("Tumour")

    df["Is_Dense_Tumour_50um"] = False
    df["Dist_to_Dense_Tumour_um"] = np.nan
    df["CAF_Proximal_30um"] = False

    if coords_are_pixels:
        dense_radius = float(radius_dense_um) / float(microns_per_pixel)
        prox_radius = float(caf_to_tumour_um) / float(microns_per_pixel)
    else:
        dense_radius = float(radius_dense_um)
        prox_radius = float(caf_to_tumour_um)

    qc_rows = []

    for core, sub_idx in df.groupby("CORE_KEY").groups.items():
        sub = df.loc[sub_idx].copy()

        tumour_mask = sub["Is_Tumour_Main"].fillna(False).to_numpy()
        tumour_sub = sub.loc[tumour_mask].copy()

        n_total = int(sub.shape[0])
        n_tumour = int(tumour_sub.shape[0])
        n_caf = int(sub["CAF_Subtype"].notna().sum()) if "CAF_Subtype" in sub.columns else 0
        n_immune = int(sub["Immune_Main_From_Detailed"].notna().sum())

        if n_tumour == 0:
            qc_rows.append({
                "CORE_KEY": core,
                "n_cells": n_total,
                "n_tumour_main": 0,
                "n_dense_tumour_50um": 0,
                "n_caf_cells": n_caf,
                "n_caf_prox_30um": 0,
                "n_immune_cells": n_immune,
            })
            continue

        tumour_coords = tumour_sub[["X", "Y"]].to_numpy(dtype=float)
        tumour_tree = cKDTree(tumour_coords)

        neigh_lists = tumour_tree.query_ball_point(tumour_coords, r=dense_radius)
        n_other = np.array([max(len(v) - 1, 0) for v in neigh_lists], dtype=int)
        dense_mask_local = n_other >= int(min_other_tumour_neighbours)

        dense_tumour_idx = tumour_sub.index[dense_mask_local]
        df.loc[dense_tumour_idx, "Is_Dense_Tumour_50um"] = True

        n_dense = int(len(dense_tumour_idx))

        if n_dense == 0:
            qc_rows.append({
                "CORE_KEY": core,
                "n_cells": n_total,
                "n_tumour_main": n_tumour,
                "n_dense_tumour_50um": 0,
                "n_caf_cells": n_caf,
                "n_caf_prox_30um": 0,
                "n_immune_cells": n_immune,
            })
            continue

        dense_coords = df.loc[dense_tumour_idx, ["X", "Y"]].to_numpy(dtype=float)
        dense_tree = cKDTree(dense_coords)

        sub_coords = sub[["X", "Y"]].to_numpy(dtype=float)
        dists, _ = dense_tree.query(sub_coords, k=1)

        if coords_are_pixels:
            dists_um = dists * float(microns_per_pixel)
        else:
            dists_um = dists

        df.loc[sub.index, "Dist_to_Dense_Tumour_um"] = dists_um

        caf_like = sub["CAF_Subtype"].notna()
        caf_prox_mask = caf_like & (dists <= prox_radius)
        df.loc[sub.index[caf_prox_mask], "CAF_Proximal_30um"] = True

        qc_rows.append({
            "CORE_KEY": core,
            "n_cells": n_total,
            "n_tumour_main": n_tumour,
            "n_dense_tumour_50um": n_dense,
            "n_caf_cells": n_caf,
            "n_caf_prox_30um": int(caf_prox_mask.sum()),
            "n_immune_cells": n_immune,
        })

    df.drop(columns=["_Main_Norm"], inplace=True, errors="ignore")
    qc_df = pd.DataFrame(qc_rows).sort_values(
        ["n_dense_tumour_50um", "n_caf_prox_30um", "n_cells"],
        ascending=False
    )

    return df, qc_df


# -------------------- CORE MATRIX BUILDER --------------------

def compute_core_caf_target_matrices(
    df: pd.DataFrame,
    row_col: str,
    target_col: str,
    row_labels,
    target_labels,
    radius_um: float,
    k_nn: int,
    microns_per_pixel: float,
    coords_are_pixels: bool,
):
    row_to_idx = {x: i for i, x in enumerate(row_labels)}
    col_to_idx = {x: j for j, x in enumerate(target_labels)}

    R = len(row_labels)
    C = len(target_labels)

    if coords_are_pixels:
        if microns_per_pixel <= 0:
            raise ValueError("microns_per_pixel must be > 0 when coords_are_pixels=True.")
        radius_thresh = float(radius_um) / float(microns_per_pixel)
    else:
        radius_thresh = float(radius_um)

    core_mats_raw = {}
    core_mats_global = {}
    core_mats_row = {}
    core_qc_rows = []

    for core, sub in df.groupby("CORE_KEY"):
        sub = sub.dropna(subset=["X", "Y"]).reset_index(drop=True)
        n = len(sub)
        if n < 2:
            continue

        coords = sub[["X", "Y"]].to_numpy(dtype=float)
        row_arr = sub[row_col].to_numpy(object)
        col_arr = sub[target_col].to_numpy(object)

        tree = cKDTree(coords)
        k_query = min(int(k_nn) + 1, n)
        if k_query <= 1:
            continue

        dists, nbrs = tree.query(coords, k=k_query)

        i_idx = np.repeat(np.arange(n), k_query - 1)
        j_idx = nbrs[:, 1:].reshape(-1)
        d_flat = dists[:, 1:].reshape(-1)

        keep = d_flat <= radius_thresh
        i_idx = i_idx[keep]
        j_idx = j_idx[keep]

        if i_idx.size == 0:
            mat_raw = pd.DataFrame(0.0, index=row_labels, columns=target_labels)
            core_mats_raw[core] = mat_raw
            core_mats_global[core] = normalize_matrix_global(mat_raw)
            core_mats_row[core] = normalize_matrix_rowwise(mat_raw)
            core_qc_rows.append({
                "CORE_KEY": core,
                "n_cells": int(n),
                "n_unique_edges": 0,
                "n_target_edges": 0,
                "total_matrix_sum": 0.0,
            })
            continue

        a = np.minimum(i_idx, j_idx)
        b = np.maximum(i_idx, j_idx)
        edges = np.unique(np.stack([a, b], axis=1), axis=0)

        ia = edges[:, 0]
        ib = edges[:, 1]

        row_a = row_arr[ia]
        row_b = row_arr[ib]
        col_a = col_arr[ia]
        col_b = col_arr[ib]

        mask_ab = (~pd.isna(row_a)) & (~pd.isna(col_b))
        mask_ba = (~pd.isna(row_b)) & (~pd.isna(col_a))

        mat_np = np.zeros((R, C), dtype=float)
        n_target_edges = 0

        if np.any(mask_ab):
            r = np.array([row_to_idx[x] for x in row_a[mask_ab]], dtype=int)
            c = np.array([col_to_idx[x] for x in col_b[mask_ab]], dtype=int)
            np.add.at(mat_np, (r, c), 1.0)
            n_target_edges += len(r)

        if np.any(mask_ba):
            r = np.array([row_to_idx[x] for x in row_b[mask_ba]], dtype=int)
            c = np.array([col_to_idx[x] for x in col_a[mask_ba]], dtype=int)
            np.add.at(mat_np, (r, c), 1.0)
            n_target_edges += len(r)

        mat_raw = pd.DataFrame(mat_np, index=row_labels, columns=target_labels)
        mat_global = normalize_matrix_global(mat_raw)
        mat_row = normalize_matrix_rowwise(mat_raw)

        core_mats_raw[core] = mat_raw
        core_mats_global[core] = mat_global
        core_mats_row[core] = mat_row

        core_qc_rows.append({
            "CORE_KEY": core,
            "n_cells": int(n),
            "n_unique_edges": int(len(edges)),
            "n_target_edges": int(n_target_edges),
            "total_matrix_sum": float(np.nansum(mat_raw.values)),
        })

    core_qc = pd.DataFrame(core_qc_rows)
    return core_mats_raw, core_mats_global, core_mats_row, core_qc


# -------------------- HEATMAPS --------------------

def _pretty_caf_label(lab: str) -> str:
    mapping = {
        "Triple negative": "Triple\nnegative",
        "Triple positive": "Triple\npositive",
    }
    return mapping.get(str(lab), str(lab))


def plot_rect_heatmap(mat, title, path, label, vmin=0.0, vmax=None):
    mat_plot = mat.copy()
    mat_plot.index = [_pretty_caf_label(x) for x in mat_plot.index]
    mat_plot.columns = [str(x) for x in mat_plot.columns]

    n_rows, n_cols = mat_plot.shape
    fig_w = max(10, 0.85 * n_cols + 4)
    fig_h = max(6.5, 1.6 * n_rows + 2)

    fig, ax = plt.subplots(figsize=(fig_w, fig_h))

    sns.heatmap(
        mat_plot,
        cmap="viridis",
        square=False,
        vmin=vmin,
        vmax=vmax,
        cbar_kws={"label": label},
        ax=ax
    )

    ax.set_title(title, pad=14, fontsize=16)
    ax.set_xlabel(mat.columns.name if mat.columns.name else "", fontsize=14)
    ax.set_ylabel(mat.index.name if mat.index.name else "", fontsize=14)

    ax.set_xticklabels(
        ax.get_xticklabels(),
        rotation=90,
        ha="center",
        va="top",
        fontsize=11
    )
    ax.set_yticklabels(
        ax.get_yticklabels(),
        rotation=0,
        ha="right",
        va="center",
        fontsize=13
    )

    ax.tick_params(axis="y", pad=12)
    ax.tick_params(axis="x", pad=6)

    fig.subplots_adjust(left=0.28, bottom=0.22, right=0.96, top=0.90)
    plt.savefig(path, dpi=300, bbox_inches="tight")
    plt.close()


