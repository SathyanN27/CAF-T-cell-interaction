def run_survival_stats_for_measure(
    strat_for_stats: dict,
    row_labels,
    target_labels,
    analysis_name: str,
    row_col: str,
    stats_name: str,
    outdir: Path,
    min_patients_per_group: int = 2,
    pairwise_alpha_fdr: float = 0.05,
):
    cats = ["Short", "Intermediate", "Long"]

    rows = []
    data_lookup = {}

    for caf in row_labels:
        for tgt in target_labels:
            data = {}
            ns = {}
            meds = {}

            for cat in cats:
                vals = [
                    float(m.at[caf, tgt])
                    for m in strat_for_stats[cat]
                    if (caf in m.index and tgt in m.columns)
                ]
                data[cat] = vals
                ns[cat] = len(vals)
                meds[cat] = float(np.median(vals)) if len(vals) else np.nan

            row = {
                "CAF_Phenotype": caf,
                "Target_Label": tgt,
                "Analysis": analysis_name,
                "RowColUsed": row_col,
                "StatsOn": stats_name,
                "n_Short": ns["Short"],
                "n_Intermediate": ns["Intermediate"],
                "n_Long": ns["Long"],
                "median_Short": meds["Short"],
                "median_Intermediate": meds["Intermediate"],
                "median_Long": meds["Long"],
            }

            if all(ns[c] >= min_patients_per_group for c in cats):
                H, p = kruskal(data["Short"], data["Intermediate"], data["Long"])
                n_total = int(ns["Short"] + ns["Intermediate"] + ns["Long"])
                row["KW_H"] = float(H)
                row["KW_p"] = float(p)
                row["KW_eps2"] = float(epsilon_squared_kw(float(H), len(cats), n_total))
            else:
                row["KW_H"] = np.nan
                row["KW_p"] = np.nan
                row["KW_eps2"] = np.nan

            rows.append(row)
            data_lookup[(caf, tgt)] = data

    df_stats = pd.DataFrame(rows)

    stats_path = outdir / f"Interaction_Survival_Stats_{stats_name}.csv"
    sig_path = outdir / f"Significant_Interaction_Survival_Stats_{stats_name}.csv"

    if df_stats.empty:
        df_stats.to_csv(stats_path, index=False)
        pd.DataFrame().to_csv(sig_path, index=False)
        return df_stats

    df_stats["KW_p_FDR"] = np.nan
    kw_mask = df_stats["KW_p"].notna()
    if kw_mask.any():
        df_stats.loc[kw_mask, "KW_p_FDR"] = multipletests(
            df_stats.loc[kw_mask, "KW_p"].values,
            method="fdr_bh"
        )[1]

    pair_defs = [
        ("Short", "Intermediate", "MWU_Short_vs_Intermediate"),
        ("Short", "Long", "MWU_Short_vs_Long"),
        ("Intermediate", "Long", "MWU_Intermediate_vs_Long"),
    ]

    for _, _, prefix in pair_defs:
        df_stats[f"{prefix}_U"] = np.nan
        df_stats[f"{prefix}_p"] = np.nan
        df_stats[f"{prefix}_p_FDR"] = np.nan

    sig_kw_mask = df_stats["KW_p_FDR"].notna() & (df_stats["KW_p_FDR"] < pairwise_alpha_fdr)

    for idx in df_stats.index[sig_kw_mask]:
        caf = df_stats.at[idx, "CAF_Phenotype"]
        tgt = df_stats.at[idx, "Target_Label"]
        data = data_lookup[(caf, tgt)]

        for g1, g2, prefix in pair_defs:
            x = data[g1]
            y = data[g2]
            if len(x) >= 1 and len(y) >= 1:
                try:
                    U, p = mannwhitneyu(x, y, alternative="two-sided", method="auto")
                    df_stats.at[idx, f"{prefix}_U"] = float(U)
                    df_stats.at[idx, f"{prefix}_p"] = float(p)
                except Exception:
                    pass

    for _, _, prefix in pair_defs:
        mask = df_stats[f"{prefix}_p"].notna()
        if mask.any():
            df_stats.loc[mask, f"{prefix}_p_FDR"] = multipletests(
                df_stats.loc[mask, f"{prefix}_p"].values,
                method="fdr_bh"
            )[1]

    df_stats = df_stats.sort_values(["KW_p_FDR", "KW_p"], na_position="last")
    df_stats.to_csv(stats_path, index=False)

    sig_any = (
        (df_stats["KW_p_FDR"].notna() & (df_stats["KW_p_FDR"] < pairwise_alpha_fdr)) |
        (df_stats["MWU_Short_vs_Intermediate_p_FDR"].notna() & (df_stats["MWU_Short_vs_Intermediate_p_FDR"] < pairwise_alpha_fdr)) |
        (df_stats["MWU_Short_vs_Long_p_FDR"].notna() & (df_stats["MWU_Short_vs_Long_p_FDR"] < pairwise_alpha_fdr)) |
        (df_stats["MWU_Intermediate_vs_Long_p_FDR"].notna() & (df_stats["MWU_Intermediate_vs_Long_p_FDR"] < pairwise_alpha_fdr))
    )
    df_stats.loc[sig_any].to_csv(sig_path, index=False)

    return df_stats


