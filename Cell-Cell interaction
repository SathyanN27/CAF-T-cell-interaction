def stage10_caf_immune_full(
    final_data: pd.DataFrame,
    clinical_df: pd.DataFrame,
    outdir,
    final_col_candidates=("Final_Phenotype", "Final phenotype", "FinalPhenotype"),
    detailed_col_candidates=("Detailed_Phenotype", "Detailed phenotype", "DetailedPhenotype"),
    main_pheno_candidates=("Main phenotype", "Main_Phenotype", "Main_Cell_Type", "Main Cell Type", "MainCellType"),
    radius_um: float = 50,
    k_nn: int = 15,
    microns_per_pixel: float = 0.325002431869506,
    coords_are_pixels: bool = True,
    min_patients_per_group: int = 2,
    pairwise_alpha_fdr: float = 0.05,
    tumour_dense_radius_um: float = 50.0,
    min_other_tumour_neighbours: int = 5,
    tumour_prox_um: float = 30.0,
):
    outdir = Path(outdir)
    ensure_dir(outdir)

    final_col = find_column(final_data, final_col_candidates)
    detailed_col = find_column(final_data, detailed_col_candidates)
    main_col = find_column(final_data, main_pheno_candidates)

    if final_col is None:
        raise ValueError(f"Could not find final phenotype column. Tried: {list(final_col_candidates)}")
    if detailed_col is None:
        raise ValueError(f"Could not find detailed phenotype column. Tried: {list(detailed_col_candidates)}")
    if main_col is None:
        raise ValueError(f"Could not find main phenotype column. Tried: {list(main_pheno_candidates)}")

    required_cols = {"Spot Id 1", "Spot Id 2", "X", "Y", final_col, detailed_col, main_col}
    missing = required_cols - set(final_data.columns)
    if missing:
        raise ValueError(f"final_data missing required columns: {sorted(missing)}")

    if "Spot Id 1" not in clinical_df.columns or "SurvivalCategory" not in clinical_df.columns:
        raise ValueError("clinical_df must contain ['Spot Id 1', 'SurvivalCategory'].")

    print(f"[INFO] Using final phenotype column: {final_col}")
    print(f"[INFO] Using detailed phenotype column: {detailed_col}")
    print(f"[INFO] Using main phenotype column: {main_col}")

    df, caf_labels, immune_main_order, immune_final_order = prepare_analysis_columns(
        final_data=final_data,
        final_col=final_col,
        detailed_col=detailed_col,
    )

    df, dense_qc = add_dense_tumour_proximity_flags(
        df=df,
        main_col=main_col,
        radius_dense_um=tumour_dense_radius_um,
        min_other_tumour_neighbours=min_other_tumour_neighbours,
        caf_to_tumour_um=tumour_prox_um,
        microns_per_pixel=microns_per_pixel,
        coords_are_pixels=coords_are_pixels,
    )
