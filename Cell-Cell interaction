def _pol2cart(theta_deg, r):
    theta = np.deg2rad(theta_deg)
    return np.array([r * np.cos(theta), r * np.sin(theta)])


def _pretty_label(lab: str) -> str:
    mapping = {
        "Triple negative": "Triple\nnegative",
        "Triple positive": "Triple\npositive",
        "Other Immune": "Other\nImmune",
        "B Cell FDR+": "B Cell\nFDR+",
        "CD4 Conventional": "CD4\nConventional",
        "CD8 Bystander": "CD8\nBystander",
        "CD8 Cytotoxic": "CD8\nCytotoxic",
        "CD8 Exhausted": "CD8\nExhausted",
    }
    return mapping.get(str(lab), str(lab))


def build_fixed_chord_layout(row_labels, col_labels, within_gap_deg=3.0, block_gap_deg=12.0):
    row_labels = list(row_labels)
    col_labels = list(col_labels)
    node_order = row_labels + col_labels

    n = len(node_order)
    total_gap = (max(len(row_labels) - 1, 0) * within_gap_deg) + \
                (max(len(col_labels) - 1, 0) * within_gap_deg) + \
                (2 * block_gap_deg)

    usable = 360.0 - total_gap
    span = usable / n

    sectors = {}
    angle = 90.0

    for i, lab in enumerate(row_labels):
        theta1 = angle
        theta2 = angle + span
        mid = 0.5 * (theta1 + theta2)
        sectors[lab] = {"theta1": theta1, "theta2": theta2, "mid": mid}
        angle = theta2 + (within_gap_deg if i < len(row_labels) - 1 else block_gap_deg)

    for i, lab in enumerate(col_labels):
        theta1 = angle
        theta2 = angle + span
        mid = 0.5 * (theta1 + theta2)
        sectors[lab] = {"theta1": theta1, "theta2": theta2, "mid": mid}
        angle = theta2 + (within_gap_deg if i < len(col_labels) - 1 else block_gap_deg)

    return node_order, sectors


def _label_rotation(angle_deg):
    rot = angle_deg - 90.0
    if rot < -90.0:
        rot += 180.0
    if rot > 90.0:
        rot -= 180.0
    return rot


def _node_colour_map(row_labels, col_labels, immune_main_lookup):
    caf_colours = {
        "Subtype A": "#ff7f00",
        "Subtype B": "#f28e2b",
        "Subtype C": "#f6b04f",
        "Triple negative": "#d95f02",
        "Triple positive": "#ff9f1a",
    }

    immune_colours = {
        "CD4": "#a6cee3",
        "CD8": "#1f78b4",
        "B Cell": "#a6d57a",
        "Macrophage": "#33a02c",
        "APC": "#e31a1c",
        "Other Immune": "#f29595",
    }

    out = {}
    for r in row_labels:
        out[r] = caf_colours.get(r, "#ff7f00")

    for c in col_labels:
        grp = immune_main_lookup.get(c, c)
        out[c] = immune_colours.get(grp, "#cccccc")

    return out


def plot_circular_interaction_map(
    mat: pd.DataFrame,
    title: str,
    path: Path,
    sectors: dict,
    node_colour_map: dict,
    row_labels,
    col_labels,
    width_scale_ref: float,
    chord_min_frac: float = 0.05,
):
    mat = mat.fillna(0.0).copy()

    fig, ax = plt.subplots(figsize=(13, 13))
    ax.set_aspect("equal")
    ax.axis("off")

    outer_r = 1.06
    ring_w = 0.12
    chord_r = 0.84
    label_r = 1.24

    for lab, spec in sectors.items():
        theta1 = spec["theta1"]
        theta2 = spec["theta2"]
        mid = spec["mid"]

        wedge = Wedge(
            center=(0, 0),
            r=outer_r,
            theta1=theta1,
            theta2=theta2,
            width=ring_w,
            facecolor=node_colour_map.get(lab, "#cccccc"),
            edgecolor="white",
            linewidth=3,
        )
        ax.add_patch(wedge)

        xy = _pol2cart(mid, label_r)
        rot = _label_rotation(mid)

        ax.text(
            xy[0], xy[1], _pretty_label(lab),
            rotation=rot,
            rotation_mode="anchor",
            ha="center",
            va="center",
            fontsize=11,
        )

    min_edge = chord_min_frac * width_scale_ref if width_scale_ref > 0 else 0.0

    edges_to_plot = []
    for r in row_labels:
        for c in col_labels:
            w = float(mat.at[r, c]) if (r in mat.index and c in mat.columns) else 0.0
            if w > 0 and w >= min_edge:
                edges_to_plot.append((r, c, w))

    edges_to_plot.sort(key=lambda x: x[2])

    for r, c, w in edges_to_plot:
        a1 = sectors[r]["mid"]
        a2 = sectors[c]["mid"]

        p0 = _pol2cart(a1, chord_r)
        p3 = _pol2cart(a2, chord_r)
        c1 = _pol2cart(a1, 0.18)
        c2 = _pol2cart(a2, 0.18)

        verts = [tuple(p0), tuple(c1), tuple(c2), tuple(p3)]
        codes = [MplPath.MOVETO, MplPath.CURVE4, MplPath.CURVE4, MplPath.CURVE4]
        path_obj = MplPath(verts, codes)

        lw = np.clip((w / width_scale_ref) * 10.0, 0.6, 10.0) if width_scale_ref > 0 else 1.0

        patch = PathPatch(
            path_obj,
            facecolor="none",
            edgecolor=node_colour_map.get(r, "#888888"),
            lw=lw,
            alpha=0.42,
            capstyle="round",
            joinstyle="round",
        )
        ax.add_patch(patch)

    ax.set_xlim(-1.38, 1.38)
    ax.set_ylim(-1.38, 1.38)
    plt.title(title, pad=22)
    plt.tight_layout()
    plt.savefig(path, dpi=300)
    plt.close()


