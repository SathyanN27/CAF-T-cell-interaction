def run_caf_target_analysis(
    df: pd.DataFrame,
    clinical_df: pd.DataFrame,
    outdir,
    analysis_name: str,
    row_col: str,
    target_col: str,
    row_labels,
    target_labels,
    target_axis_name: str,
    row_axis_name: str = "CAF subtype",
    radius_um: float = 50,
    k_nn: int = 15,
    microns_per_pixel: float = 0.325002431869506,
    coords_are_pixels: bool = True,
    min_patients_per_group: int = 2,
    pairwise_alpha_fdr: float = 0.05,
):
    outdir = Path(outdir)
    ensure_dir(outdir)

    row_labels = [x for x in row_labels if x in set(df[row_col].dropna().unique())]
    target_labels = [x for x in target_labels if x in set(df[target_col].dropna().unique())]

    if len(row_labels) == 0:
        print(f"[WARN] No row labels found for {analysis_name}")
        return

    if len(target_labels) == 0:
        print(f"[WARN] No target labels found for {analysis_name}")
        return

    core_mats_raw, core_mats_global, core_mats_row, core_qc = compute_core_caf_target_matrices(
        df=df,
        row_col=row_col,
        target_col=target_col,
        row_labels=row_labels,
        target_labels=target_labels,
        radius_um=radius_um,
        k_nn=k_nn,
        microns_per_pixel=microns_per_pixel,
        coords_are_pixels=coords_are_pixels,
    )

    if len(core_mats_raw) == 0:
        print(f"[WARN] No core matrices computed for {analysis_name}")
        return

    core_qc = core_qc.sort_values(["n_cells", "n_target_edges"], ascending=False)
    core_qc.to_csv(outdir / "Core_QC.csv", index=False)

    totals_raw = {core: float(np.nansum(m.values)) for core, m in core_mats_raw.items()}
    median_total = float(np.median(list(totals_raw.values())))
    rep_core = min(totals_raw, key=lambda c: abs(totals_raw[c] - median_total))

    core2pt = df.groupby("CORE_KEY")["Spot Id 1"].first().to_dict()

    pt_cores = {}
    for core in core_mats_raw.keys():
        pt = core2pt.get(core)
        if pd.notna(pt):
            pt_cores.setdefault(pt, []).append(core)

    pt_raw = {}
    pt_global = {}
    pt_row = {}
    for pt, cores in pt_cores.items():
        pt_raw[pt] = median_mats([core_mats_raw[c] for c in cores])
        pt_global[pt] = median_mats([core_mats_global[c] for c in cores])
        pt_row[pt] = median_mats([core_mats_row[c] for c in cores])

    pt_qc = pd.DataFrame(
        [{"Spot Id 1": pt, "n_cores": len(cores)} for pt, cores in pt_cores.items()]
    ).sort_values("n_cores", ascending=False)
    pt_qc.to_csv(outdir / "Patient_QC.csv", index=False)

    pt2surv = clinical_df.set_index("Spot Id 1")["SurvivalCategory"].to_dict()
    cats = ["Short", "Intermediate", "Long"]

    strat_raw = {c: [] for c in cats}
    strat_global = {c: [] for c in cats}
    strat_row = {c: [] for c in cats}

    for pt in pt_raw.keys():
        cat = pt2surv.get(pt)
        if pd.isna(cat):
            continue
        cat = str(cat)
        if cat in strat_raw:
            strat_raw[cat].append(pt_raw[pt])
            strat_global[cat].append(pt_global[pt])
            strat_row[cat].append(pt_row[pt])

    def _avg_or_zero(mats):
        if mats:
            return sum(mats) / len(mats)
        return pd.DataFrame(0.0, index=row_labels, columns=target_labels)

    strat_avg_raw = {cat: _avg_or_zero(mats) for cat, mats in strat_raw.items()}
    strat_avg_global = {cat: _avg_or_zero(mats) for cat, mats in strat_global.items()}
    strat_avg_row = {cat: _avg_or_zero(mats) for cat, mats in strat_row.items()}

    for cat in cats:
        for d in (strat_avg_raw, strat_avg_global, strat_avg_row):
            d[cat].index.name = row_axis_name
            d[cat].columns.name = target_axis_name

    raw_vmax = max(float(np.nanmax(m.values)) for m in strat_avg_raw.values()) if strat_avg_raw else 0.0
    global_vmax = max(float(np.nanmax(m.values)) for m in strat_avg_global.values()) if strat_avg_global else 0.0
    row_vmax = max(float(np.nanmax(m.values)) for m in strat_avg_row.values()) if strat_avg_row else 0.0

    for cat in cats:
        plot_rect_heatmap(
            strat_avg_raw[cat],
            f"{analysis_name} Heatmap (RAW) — {cat}",
            outdir / f"Heatmap_RAW_{cat}.png",
            label="Contact count",
            vmin=0.0,
            vmax=raw_vmax,
        )
        plot_rect_heatmap(
            strat_avg_global[cat],
            f"{analysis_name} Heatmap (GLOBAL_NORM) — {cat}",
            outdir / f"Heatmap_GLOBAL_NORM_{cat}.png",
            label="Proportion of all matrix interactions",
            vmin=0.0,
            vmax=global_vmax,
        )
        plot_rect_heatmap(
            strat_avg_row[cat],
            f"{analysis_name} Heatmap (ROW_NORM) — {cat}",
            outdir / f"Heatmap_ROW_NORM_{cat}.png",
            label="Proportion within CAF row",
            vmin=0.0,
            vmax=row_vmax,
        )

        strat_avg_raw[cat].to_csv(outdir / f"Matrix_RAW_{cat}.csv")
        strat_avg_global[cat].to_csv(outdir / f"Matrix_GLOBAL_NORM_{cat}.csv")
        strat_avg_row[cat].to_csv(outdir / f"Matrix_ROW_NORM_{cat}.csv")

    def _edge_scale_ref(strat_dict):
        vals_all = []
        for cat in cats:
            vals = strat_dict[cat].values.ravel()
            vals = vals[np.isfinite(vals) & (vals > 0)]
            vals_all.extend(vals.tolist())
        if len(vals_all) == 0:
            return 1.0
        ref = float(np.quantile(vals_all, 0.90))
        if ref <= 0:
            ref = float(np.max(vals_all))
        return ref if ref > 0 else 1.0

    global_edge_ref = _edge_scale_ref(strat_avg_global)
    row_edge_ref = _edge_scale_ref(strat_avg_row)

    if target_col == "Immune_Main_From_Detailed":
        immune_main_lookup = {x: x for x in target_labels}
    elif target_col == "Immune_Final_Label":
        lookup_rows = df.loc[df[target_col].notna(), [target_col, "Immune_Final_Main"]].drop_duplicates()
        immune_main_lookup = lookup_rows.set_index(target_col)["Immune_Final_Main"].to_dict()
    else:
        immune_main_lookup = {x: x for x in target_labels}

    _, sectors = build_fixed_chord_layout(row_labels, target_labels)
    node_colour_map = _node_colour_map(row_labels, target_labels, immune_main_lookup)

    for cat in cats:
        plot_circular_interaction_map(
            strat_avg_global[cat],
            f"{analysis_name} Circular Interaction Map (GLOBAL_NORM) — {cat}",
            outdir / f"Network_GLOBAL_NORM_{cat}.png",
            sectors=sectors,
            node_colour_map=node_colour_map,
            row_labels=row_labels,
            col_labels=target_labels,
            width_scale_ref=global_edge_ref,
            chord_min_frac=0.05,
        )
        plot_circular_interaction_map(
            strat_avg_row[cat],
            f"{analysis_name} Circular Interaction Map (ROW_NORM) — {cat}",
            outdir / f"Network_ROW_NORM_{cat}.png",
            sectors=sectors,
            node_colour_map=node_colour_map,
            row_labels=row_labels,
            col_labels=target_labels,
            width_scale_ref=row_edge_ref,
            chord_min_frac=0.05,
        )

    rep_raw = core_mats_raw[rep_core]
    rep_global = core_mats_global[rep_core]
    rep_row = core_mats_row[rep_core]

    for m in (rep_raw, rep_global, rep_row):
        m.index.name = row_axis_name
        m.columns.name = target_axis_name

    plot_rect_heatmap(
        rep_raw,
        f"Representative {analysis_name} Heatmap (RAW) — Core {rep_core}",
        outdir / f"Representative_Heatmap_RAW_{rep_core}.png",
        label="Contact count",
        vmin=0.0,
        vmax=raw_vmax,
    )
    plot_rect_heatmap(
        rep_global,
        f"Representative {analysis_name} Heatmap (GLOBAL_NORM) — Core {rep_core}",
        outdir / f"Representative_Heatmap_GLOBAL_NORM_{rep_core}.png",
        label="Proportion of all matrix interactions",
        vmin=0.0,
        vmax=global_vmax,
    )
    plot_rect_heatmap(
        rep_row,
        f"Representative {analysis_name} Heatmap (ROW_NORM) — Core {rep_core}",
        outdir / f"Representative_Heatmap_ROW_NORM_{rep_core}.png",
        label="Proportion within CAF row",
        vmin=0.0,
        vmax=row_vmax,
    )

    plot_circular_interaction_map(
        rep_global,
        f"Representative {analysis_name} Circular Interaction Map (GLOBAL_NORM) — Core {rep_core}",
        outdir / f"Representative_Network_GLOBAL_NORM_{rep_core}.png",
        sectors=sectors,
        node_colour_map=node_colour_map,
        row_labels=row_labels,
        col_labels=target_labels,
        width_scale_ref=global_edge_ref,
        chord_min_frac=0.05,
    )
    plot_circular_interaction_map(
        rep_row,
        f"Representative {analysis_name} Circular Interaction Map (ROW_NORM) — Core {rep_core}",
        outdir / f"Representative_Network_ROW_NORM_{rep_core}.png",
        sectors=sectors,
        node_colour_map=node_colour_map,
        row_labels=row_labels,
        col_labels=target_labels,
        width_scale_ref=row_edge_ref,
        chord_min_frac=0.05,
    )

    rep_raw.to_csv(outdir / f"Representative_Matrix_RAW_{rep_core}.csv")
    rep_global.to_csv(outdir / f"Representative_Matrix_GLOBAL_NORM_{rep_core}.csv")
    rep_row.to_csv(outdir / f"Representative_Matrix_ROW_NORM_{rep_core}.csv")

    # Separate stats for each measure
    df_stats_raw = run_survival_stats_for_measure(
        strat_for_stats=strat_raw,
        row_labels=row_labels,
        target_labels=target_labels,
        analysis_name=analysis_name,
        row_col=row_col,
        stats_name="RAW",
        outdir=outdir,
        min_patients_per_group=min_patients_per_group,
        pairwise_alpha_fdr=pairwise_alpha_fdr,
    )

    df_stats_global = run_survival_stats_for_measure(
        strat_for_stats=strat_global,
        row_labels=row_labels,
        target_labels=target_labels,
        analysis_name=analysis_name,
        row_col=row_col,
        stats_name="GLOBAL_NORM",
        outdir=outdir,
        min_patients_per_group=min_patients_per_group,
        pairwise_alpha_fdr=pairwise_alpha_fdr,
    )

    df_stats_row = run_survival_stats_for_measure(
        strat_for_stats=strat_row,
        row_labels=row_labels,
        target_labels=target_labels,
        analysis_name=analysis_name,
        row_col=row_col,
        stats_name="ROW_NORM",
        outdir=outdir,
        min_patients_per_group=min_patients_per_group,
        pairwise_alpha_fdr=pairwise_alpha_fdr,
    )

    summary = {
        "analysis_name": analysis_name,
        "row_col": row_col,
        "target_col": target_col,
        "radius_um": float(radius_um),
        "k_nn": int(k_nn),
        "coords_are_pixels": bool(coords_are_pixels),
        "microns_per_pixel": float(microns_per_pixel) if coords_are_pixels else np.nan,
        "n_cores_used": int(len(core_mats_raw)),
        "n_patients_used": int(len(pt_raw)),
        "patients_in_short": int(len(strat_row["Short"])),
        "patients_in_intermediate": int(len(strat_row["Intermediate"])),
        "patients_in_long": int(len(strat_row["Long"])),
        "shared_raw_vmax": float(raw_vmax),
        "shared_global_norm_vmax": float(global_vmax),
        "shared_row_norm_vmax": float(row_vmax),
        "shared_global_edge_width_ref": float(global_edge_ref),
        "shared_row_edge_width_ref": float(row_edge_ref),
        "representative_core": rep_core,
        "pairwise_alpha_fdr": float(pairwise_alpha_fdr),
        "patient_summary_method": "median_across_cores",
        "stats_files": "RAW, GLOBAL_NORM, ROW_NORM",
        "n_stats_rows_raw": int(df_stats_raw.shape[0]) if isinstance(df_stats_raw, pd.DataFrame) else 0,
        "n_stats_rows_global_norm": int(df_stats_global.shape[0]) if isinstance(df_stats_global, pd.DataFrame) else 0,
        "n_stats_rows_row_norm": int(df_stats_row.shape[0]) if isinstance(df_stats_row, pd.DataFrame) else 0,
    }
    pd.Series(summary).to_csv(outdir / "RUN_SUMMARY.csv")

    pd.Series(row_labels, name="CAF_labels_used").to_csv(outdir / "CAF_labels_used.csv", index=False)
    pd.Series(target_labels, name="Target_labels_used").to_csv(outdir / "Target_labels_used.csv", index=False)

    print(f"[DONE] {analysis_name}")
    print(f"       Outputs in: {outdir}")


