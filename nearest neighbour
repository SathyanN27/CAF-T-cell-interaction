def plot_heatmap_df(
    mat: pd.DataFrame,
    outpath,
    title: str,
    order=None,
    cmap="viridis",
    figsize=(12, 10),
    cbar_label=None,
    annot: bool = False,
    fmt: str = ".2f",
    linewidths: float = 0.0,
    triangle: bool = False,
    triangle_side: str = "lower",  # lower or upper
):
    if order is not None:
        order = [x for x in order if x in mat.index]
        matp = mat.reindex(index=order, columns=order)
    else:
        matp = mat.copy()

    mask = None
    if triangle:
        n = matp.shape[0]
        if triangle_side == "lower":
            mask = np.triu(np.ones((n, n), dtype=bool), k=1)
        else:
            mask = np.tril(np.ones((n, n), dtype=bool), k=-1)

    plt.figure(figsize=figsize)
    ax = sns.heatmap(
        matp,
        cmap=cmap,
        square=True,
        annot=annot,
        fmt=fmt,
        linewidths=linewidths,
        mask=mask,
        cbar_kws={"label": cbar_label} if cbar_label else None,
    )
    ax.set_title(title)
    plt.tight_layout()
    plt.savefig(outpath, dpi=300)
    plt.close()

def plot_network_from_adjacency(
    mat: pd.DataFrame,
    outpath,
    title: str,
    order=None,
    cell_type_map=None,
    cat_colors=None,
    seed: int = 0,
):
    matp = mat.copy()
    if order is not None:
        order = [x for x in order if x in matp.index]
        matp = matp.reindex(index=order, columns=order).fillna(0)

    G = nx.from_pandas_adjacency(matp)
    G.remove_nodes_from(list(nx.isolates(G)))
    if len(G) == 0:
        return

    weights = np.array([G[u][v]["weight"] for u, v in G.edges()], dtype=float)
    if weights.size == 0:
        return

    scale = np.quantile(weights, 0.90)
    scale = scale if (np.isfinite(scale) and scale > 0) else max(1.0, weights.max())
    widths = np.clip(weights / scale, 0.2, 4.0).tolist()

    pos = nx.spring_layout(G, k=0.5, seed=seed)

    node_strengths = dict(G.degree(weight="weight"))
    total_strength = sum(node_strengths.values())
    prop = {n: (node_strengths[n] / total_strength if total_strength > 0 else 0) for n in G.nodes()}

    node_colors = []
    for n in G.nodes():
        if cell_type_map is not None and cat_colors is not None:
            broad = cell_type_map.get(n, "Other")
            node_colors.append(cat_colors.get(broad, "#cccccc"))
        else:
            node_colors.append("#cccccc")

    node_sizes = [300 + 9000 * prop[n] for n in G.nodes()]

    plt.figure(figsize=(9, 9))
    nx.draw(
        G, pos,
        with_labels=True,
        node_color=node_colors,
        node_size=node_sizes,
        width=widths,
        edge_color="grey",
        font_size=8
    )
    plt.title(title)
    plt.axis("off")
    plt.tight_layout()
    plt.savefig(outpath, dpi=300)
    plt.close()

