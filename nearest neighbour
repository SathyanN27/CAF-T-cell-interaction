# ===================== CLINICAL PREPROCESS =====================
def preprocess_clinical(clin: pd.DataFrame) -> pd.DataFrame:
    df = clin.copy()

    pt_col = find_column(df, ["Spot Id 1", "SpotId1", "Donor ID", "DonorID", "Patient", "PatientID"])
    if pt_col is None:
        raise ValueError(f"Could not find patient ID column in clinical. Seen: {list(df.columns)}")
    if pt_col != "Spot Id 1":
        df = df.rename(columns={pt_col: "Spot Id 1"})

    os_col = find_column(df, ["Overall_Survival_(days)", "Overall Survival (days)", "OverallSurvivalDays",
                              "OS_days", "OSDays", "SurvivalDays"])
    if os_col is None:
        raise ValueError(f"Could not find OS days column in clinical. Seen: {list(df.columns)}")
    if os_col != "SurvivalDays":
        df = df.rename(columns={os_col: "SurvivalDays"})

    fu_col = find_column(df, ["Follow_up", "Follow up", "Followup", "FollowUp"])

    df["Spot Id 1"] = df["Spot Id 1"].astype(str).str.strip()
    df = df[~df["SurvivalDays"].astype(str).str.contains("lost to follow up", case=False, na=False)].copy()

    if fu_col is not None:
        mask = df["SurvivalDays"].astype(str).str.strip().isin(["NA", "N/A", "nan", "None", ""])
        df.loc[mask, "SurvivalDays"] = df.loc[mask, fu_col]

    df["SurvivalDays"] = pd.to_numeric(df["SurvivalDays"], errors="coerce")
    df["SurvivalCategory"] = pd.cut(df["SurvivalDays"], bins=[-np.inf, 540, 900, np.inf], labels=SURV_ORDER)
    df["SurvivalCategory"] = pd.Categorical(df["SurvivalCategory"], categories=SURV_ORDER, ordered=True)

    df = df[["Spot Id 1", "SurvivalDays", "SurvivalCategory"]].drop_duplicates()

    dup = df.duplicated(subset=["Spot Id 1"], keep=False)
    if dup.any():
        offenders = df.loc[dup, "Spot Id 1"].value_counts()
        raise ValueError("Clinical file has multiple rows for some patients:\n" + offenders.to_string())

    return df


# ===================== AREA LOOKUP (mm² -> µm²) =====================
def find_area_cols(area_df: pd.DataFrame) -> dict:
    cols = list(area_df.columns)
    ccanon = {c: _canon(c) for c in cols}

    def pick(kind_words):
        hits = []
        for c in cols:
            s = ccanon[c]
            if "area" in s and any(w in s for w in kind_words):
                hits.append(c)
        return hits[0] if hits else None

    total = pick(["total"]) or pick(["tissue"])
    tumour = pick(["tumour", "tumor"])
    immune = pick(["immune"])
    stroma = pick(["stroma"])
    return {"total": total, "tumour": tumour, "immune": immune, "stroma": stroma}

def build_area_lookup_um2(area_df: pd.DataFrame) -> dict:
    if area_df is None or area_df.empty:
        return {}

    df = area_df.copy()
    if "Spot Id 1" not in df.columns or "Spot Id 2" not in df.columns:
        return {}

    df["Spot Id 1"] = df["Spot Id 1"].astype(str).str.strip()
    df["Spot Id 2"] = df["Spot Id 2"].apply(_norm_core_id)

    cols = find_area_cols(df)
    cols = {k: v for k, v in cols.items() if v is not None and v in df.columns}
    if not cols:
        return {}

    for _, c in cols.items():
        df[c] = pd.to_numeric(df[c], errors="coerce")

    df = df.dropna(subset=list(cols.values()), how="all").copy()
    if df.empty:
        return {}

    for k, c in cols.items():
        df[f"Area_um2_{k}"] = df[c].astype(float) * 1e6

    agg_cols = [f"Area_um2_{k}" for k in cols.keys()]
    g = df.groupby(["Spot Id 1", "Spot Id 2"], as_index=False)[agg_cols].median()

    lookup = {}
    for _, r in g.iterrows():
        key = (r["Spot Id 1"], r["Spot Id 2"])
        d = {}
        for k in cols.keys():
            v = float(r[f"Area_um2_{k}"])
            if np.isfinite(v) and v > 0:
                d[k] = v
        if d:
            lookup[key] = d
    return lookup

def get_area_um2(area_lookup: dict, pat: str, core: str, kind: str, fallback_um2: float) -> float:
    d = area_lookup.get((str(pat).strip(), _norm_core_id(core)), None)
    if isinstance(d, dict):
        v = d.get(kind, None)
        if v is not None and v > 0:
            return float(v)
    return float(fallback_um2)


