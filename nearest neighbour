    for (pat, core), grp in df.groupby(["Spot Id 1", "Spot Id 2"]):
        tum = grp[grp["Main_Cell_Type"] == "Tumour"]
        imm = grp[grp["Main_Cell_Type"] == "Immune"]
        if tum.empty or imm.empty:
            continue
        tree = cKDTree(imm[["X_um", "Y_um"]].to_numpy())
        d_um, _ = tree_query(tree, tum[["X_um", "Y_um"]].to_numpy(), k=1)
        rec_any.append({
            "Spot Id 1": str(pat).strip(),
            "Spot Id 2": str(core).strip(),
            "N_tumour": int(len(d_um)),
            "Median_Distance_um": float(np.median(d_um)),
        })

    df_core_any = pd.DataFrame(rec_any)
    df_core_any.to_csv(out_dir / "TumorToAnyImmune_PerCore.csv", index=False)

    if not df_core_any.empty:
        df_pt_any = core_to_patient_median(df_core_any, value_cols="Median_Distance_um")
        df_pt_any = df_pt_any.merge(clinical[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")
        df_pt_any.to_csv(out_dir / "TumorToAnyImmune_PerPatient_MedianOfCores.csv", index=False)

        plot_box_with_points(
            df_pt_any, x="SurvivalCategory", y="Median_Distance_um",
            outpath=out_dir / "Boxplot_TumorToAnyImmune_bySurvival.png",
            title="Tumour→Any Immune nearest distance (µm) per patient (median-of-cores) by Survival",
            order=SURV_ORDER, palette=SURV_PALETTE, rotate=0, point_size=3, point_alpha=0.25
        )
        stats_by_group(df_pt_any, "SurvivalCategory", "Median_Distance_um", out_dir, "TumorToAnyImmune_bySurvival")

    # ---------- (B) Immune subtype (per-core) ----------
    rec_sub = []
    for imm_type in imm_types:
        imm_all_type = df[(df["Main_Cell_Type"] == "Immune") & (df["Detailed_Phenotype"] == imm_type)]
        if imm_all_type.empty:
            continue
        for (pat, core), tum_pts in df[df["Main_Cell_Type"] == "Tumour"].groupby(["Spot Id 1", "Spot Id 2"]):
            imm_pts = imm_all_type[(imm_all_type["Spot Id 1"] == pat) & (imm_all_type["Spot Id 2"] == core)]
            if tum_pts.empty or imm_pts.empty:
                continue
            tree = cKDTree(imm_pts[["X_um", "Y_um"]].to_numpy())
            d_um, _ = tree_query(tree, tum_pts[["X_um", "Y_um"]].to_numpy(), k=1)
            rec_sub.append({
                "Spot Id 1": str(pat).strip(),
                "Spot Id 2": str(core).strip(),
                "Immune_Subtype": imm_type,
                "N_tumour": int(len(d_um)),
                "Median_Distance_um": float(np.median(d_um)),
            })

    df_core_sub = pd.DataFrame(rec_sub)
    df_core_sub.to_csv(out_dir / "TumorToImmuneSubtype_PerCore.csv", index=False)

    if not df_core_sub.empty:
        df_pt_sub = core_to_patient_median(df_core_sub,
                                           value_cols="Median_Distance_um",
                                           extra_group_cols=["Immune_Subtype"])
        df_pt_sub = df_pt_sub.merge(clinical[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")
        df_pt_sub.to_csv(out_dir / "TumorToImmuneSubtype_PerPatient_MedianOfCores.csv", index=False)

        # subtype-by-survival plots + stats
        for imm_type in ordered_subset(df_pt_sub["Immune_Subtype"].dropna().unique().tolist(), IMMUNE_DETAILED):
            sub = df_pt_sub[df_pt_sub["Immune_Subtype"] == imm_type].copy()
            if sub.empty:
                continue
            plot_box_with_points(
                sub, x="SurvivalCategory", y="Median_Distance_um",
                outpath=out_dir / f"Boxplot_TumorTo_{sanitize(imm_type)}_bySurvival.png",
                title=f"Tumour→{imm_type} nearest distance (µm) per patient (median-of-cores) by Survival",
                order=SURV_ORDER, palette=SURV_PALETTE, rotate=0, point_size=3, point_alpha=0.25
            )
            stats_by_group(sub, "SurvivalCategory", "Median_Distance_um", out_dir, f"TumorTo_{sanitize(imm_type)}_bySurvival")

        # pooled-across-survival: compare immune subtypes (patient-level)
        pooled = df_pt_sub.dropna(subset=["Immune_Subtype", "Median_Distance_um"]).copy()
        pooled.to_csv(out_dir / "TumorToImmuneSubtype_PooledAcrossSurvival_PerPatient.csv", index=False)

        plot_box_with_points(
            pooled, x="Immune_Subtype", y="Median_Distance_um",
            outpath=out_dir / "Boxplot_TumorToImmuneSubtype_PooledAcrossSurvival.png",
            title="Tumour→Immune subtype nearest distance (µm) per patient (median-of-cores), pooled across survival",
            order=ordered_subset(pooled["Immune_Subtype"].unique().tolist(), IMMUNE_DETAILED),
            palette=None, rotate=90, point_size=3, point_alpha=0.25
        )
        stats_by_group(pooled, "Immune_Subtype", "Median_Distance_um", out_dir, "TumorToImmuneSubtype_PooledAcrossSurvival")

    print("[14g] Complete.")


