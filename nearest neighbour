def load_data(final_csv: str, area_csv: str, clin_csv: str):
    final_csv = resolve_path(final_csv, fallback_candidates=[
        "/data/home/hfx986/Combat/Final_Cell_Phenotypes.csv",
        "/data/home/hfx986/Final_Cell_Phenotypes.csv",
    ])
    area_csv = resolve_path(area_csv, fallback_candidates=[
        "/data/home/hfx986/Area.csv",
        "/data/home/hfx986/Combat/Area.csv",
    ])
    clin_csv = resolve_path(clin_csv, fallback_candidates=[
        "/data/home/hfx986/Clinical_Data.csv",
        "/data/home/hfx986/Combat/Clinical_Data.csv",
    ])

    print(f"[Input] final_csv: {final_csv}")
    print(f"[Input] area_csv : {area_csv}")
    print(f"[Input] clin_csv : {clin_csv}")

    final = pd.read_csv(final_csv)
    area = pd.read_csv(area_csv)
    clin = pd.read_csv(clin_csv)

    req = ["Spot Id 1", "Spot Id 2", "X", "Y", "Main_Cell_Type", "Detailed_Phenotype"]
    miss = [c for c in req if c not in final.columns]
    if miss:
        raise ValueError(f"Final CSV missing columns: {miss}")

    final["Spot Id 1"] = final["Spot Id 1"].astype(str).str.strip()
    final["Spot Id 2"] = final["Spot Id 2"].apply(_norm_core_id)
    final["Main_Cell_Type"] = final["Main_Cell_Type"].astype(str).str.strip()
    final["Detailed_Phenotype"] = final["Detailed_Phenotype"].apply(canonicalize_detailed_pheno)

    final["X_um"] = pd.to_numeric(final["X"], errors="coerce") * PIXEL_TO_MICRON
    final["Y_um"] = pd.to_numeric(final["Y"], errors="coerce") * PIXEL_TO_MICRON

    if "CellID" not in final.columns:
        final["CellID"] = np.arange(len(final), dtype=int)

    clinical = preprocess_clinical(clin)

    if "Spot Id 1" in area.columns:
        area["Spot Id 1"] = area["Spot Id 1"].astype(str).str.strip()
    if "Spot Id 2" in area.columns:
        area["Spot Id 2"] = area["Spot Id 2"].apply(_norm_core_id)

    area_lookup = build_area_lookup_um2(area)
    if area_lookup:
        print(f"[Area] Built area lookup for {len(area_lookup)} (patient,core) entries.")
        print(f"[Area] Detected columns: {find_area_cols(area)}")
    else:
        print("[Area] WARNING: Could not build area lookup (Ripley will fall back to bbox area).")

    return final, area, clinical, area_lookup


# ===================== STATS HELPERS =====================
def stats_by_group(df: pd.DataFrame, group_col: str, value_col: str, output_dir, output_prefix: str) -> pd.DataFrame:
    ensure_dir(output_dir)
    df = df[[group_col, value_col]].dropna().copy()

    if df.empty or df[value_col].nunique() <= 1:
        out = pd.DataFrame([{"Test": "NA", "stat": np.nan, "p": np.nan, "group1": "-", "group2": "-"}])
        out.to_csv(Path(output_dir) / f"{output_prefix}_stats.csv", index=False)
        return out

    group_names = sorted(df[group_col].dropna().unique().tolist())
    groups = [df[df[group_col] == g][value_col].values for g in group_names]

    stat_table = []
    if sum((len(g) > 1) for g in groups) >= 3:
        try:
            kw_stat, kw_p = kruskal(*groups, nan_policy="omit")
        except Exception:
            kw_stat, kw_p = np.nan, np.nan
        stat_table.append({"Test": "Kruskal–Wallis", "stat": kw_stat, "p": kw_p, "group1": "all", "group2": "all"})

    mw_stats = []
    for a, b in combinations(group_names, 2):
        xa = df[df[group_col] == a][value_col].dropna().values
        xb = df[df[group_col] == b][value_col].dropna().values
        if len(xa) < 2 or len(xb) < 2:
            mw_stats.append({"Test": "Mann–Whitney", "stat": np.nan, "p": np.nan, "group1": a, "group2": b})
            continue
        if (np.all(xa == xa[0]) and np.all(xb == xb[0])):
            mw_stats.append({"Test": "Mann–Whitney", "stat": np.nan, "p": np.nan, "group1": a, "group2": b})
            continue
        try:
            u, p = mannwhitneyu(xa, xb, alternative="two-sided")
        except Exception:
            u, p = np.nan, np.nan
        mw_stats.append({"Test": "Mann–Whitney", "stat": u, "p": p, "group1": a, "group2": b})

    pvals = [d["p"] for d in mw_stats if d["p"] == d["p"]]
    if pvals:
        _, fdr, _, _ = multipletests(pvals, method="fdr_bh")
        j = 0
        for d in mw_stats:
            if d["p"] == d["p"]:
                d["FDR_p"] = fdr[j]
                j += 1
            else:
                d["FDR_p"] = np.nan

    stat_df = pd.DataFrame(stat_table + mw_stats)
    stat_df.to_csv(Path(output_dir) / f"{output_prefix}_stats.csv", index=False)
    return stat_df


