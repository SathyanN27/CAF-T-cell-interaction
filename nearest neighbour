def stage11e_spatial_nn_maps_detailed_um(
    final_data: pd.DataFrame,
    dist_df: pd.DataFrame,
    outdir,
    max_rois: int = 250,
    min_tumour_cells: int = 20,
    min_non_t_cells_with_dist: int = 50,
    invert_y: bool = True,
    representative_per_patient: bool = True,
):
    out = Path(outdir) / "Stage11e_SpatialMaps_DETAILED_um"
    ensure_dir(out)

    if dist_df is None or dist_df.empty:
        print("[Stage11e] dist_df empty, skipping.")
        return

    df = get_valid_um(final_data).copy()
    merged = df.merge(dist_df[["CellID", "NN_Distance_um"]], on="CellID", how="left")
    merged["Main_Cell_Type"] = merged["Main_Cell_Type"].astype(str).str.strip()
    merged["Spot Id 1"] = merged["Spot Id 1"].astype(str).str.strip()
    merged["Spot Id 2"] = merged["Spot Id 2"].astype(str).str.strip()

    qc_rows = []
    for roi, sub in merged.groupby("Spot Id 2"):
        pid = sub["Spot Id 1"].mode().iat[0] if not sub["Spot Id 1"].mode().empty else str(sub["Spot Id 1"].iloc[0])
        tum = sub[sub["Main_Cell_Type"] == "Tumour"]
        non_t = sub[(sub["Main_Cell_Type"] != "Tumour") & sub["NN_Distance_um"].notna()]
        qc_rows.append({
            "Spot Id 1": pid,
            "Spot Id 2": roi,
            "n_cells_total": int(len(sub)),
            "n_tumour": int(len(tum)),
            "n_non_t_with_dist": int(len(non_t)),
        })

    qc = pd.DataFrame(qc_rows).sort_values(["n_non_t_with_dist", "n_tumour"], ascending=False)
    qc.to_csv(out / "ROI_SpatialMap_QC.csv", index=False)

    eligible = qc[(qc["n_tumour"] >= int(min_tumour_cells)) & (qc["n_non_t_with_dist"] >= int(min_non_t_cells_with_dist))].copy()
    if eligible.empty:
        print("[Stage11e] No ROIs passed thresholds.")
        return

    eligible_bulk = eligible.sort_values("n_non_t_with_dist", ascending=False).head(int(max_rois)) if (max_rois is not None and len(eligible) > int(max_rois)) else eligible
    eligible_rois_bulk = set(eligible_bulk["Spot Id 2"].astype(str).tolist())

    def _plot_one_roi(roi_id: str, subdf: pd.DataFrame, outpath: Path, title: str):
        tum = subdf[subdf["Main_Cell_Type"] == "Tumour"]
        non_t = subdf[(subdf["Main_Cell_Type"] != "Tumour") & subdf["NN_Distance_um"].notna()]
        if tum.empty or non_t.empty:
            return False

        plt.figure(figsize=(6.5, 6.5))
        sc = plt.scatter(non_t["X_um"], non_t["Y_um"], c=non_t["NN_Distance_um"], cmap="viridis", s=6, linewidths=0)
        plt.colorbar(sc, label="NN distance to tumour (µm)")
        plt.scatter(tum["X_um"], tum["Y_um"], c="k", marker="x", s=12, linewidths=0.7)
        plt.axis("equal")
        if invert_y:
            plt.gca().invert_yaxis()
        plt.xticks([]); plt.yticks([])
        plt.title(title)
        save_plot(outpath)
        return True

    n_saved = 0
    for roi, sub in merged.groupby("Spot Id 2"):
        roi_s = str(roi)
        if roi_s not in eligible_rois_bulk:
            continue
        n_saved += int(_plot_one_roi(roi_s, sub, out / f"Spatial_NN_DETAILED_um_{safe_name(roi_s)}.png", f"NN-to-tumour map (µm) — ROI {roi_s}"))
    print(f"[Stage11e] Saved {n_saved} bulk maps to: {out}")

    if representative_per_patient:
        rep_dir = out / "Representative_PerPatient"
        ensure_dir(rep_dir)

        rep_rows = []
        for pid, subp in eligible.groupby("Spot Id 1"):
            target = float(np.median(subp["n_tumour"].values))
            cand = subp.copy()
            cand["tumour_dev"] = (cand["n_tumour"] - target).abs()
            cand = cand.sort_values(["tumour_dev", "n_non_t_with_dist"], ascending=[True, False])
            rep_rows.append(cand.iloc[0])

        rep = pd.DataFrame(rep_rows).sort_values(["Spot Id 1"])
        rep.to_csv(out / "Representative_ROI_PerPatient.csv", index=False)

        rep_rois = set(rep["Spot Id 2"].astype(str).tolist())
        n_rep = 0
        for roi, sub in merged.groupby("Spot Id 2"):
            roi_s = str(roi)
            if roi_s not in rep_rois:
                continue
            pid = sub["Spot Id 1"].mode().iat[0] if not sub["Spot Id 1"].mode().empty else str(sub["Spot Id 1"].iloc[0])
            n_rep += int(_plot_one_roi(roi_s, sub, rep_dir / f"RepROI_Patient_{safe_name(pid)}__ROI_{safe_name(roi_s)}.png",
                                       f"Representative ROI — Patient {pid} — ROI {roi_s}"))
        print(f"[Stage11e] Saved {n_rep} representative maps to: {rep_dir}")


# ===================== STAGE 14 (µm-native) — Ripley helpers =====================
def _core_window_bbox_um(core_df: pd.DataFrame):
    pts = core_df[["X_um", "Y_um"]].dropna().to_numpy()
    if pts.size == 0:
        return None
    xmin, ymin = pts.min(axis=0)
    xmax, ymax = pts.max(axis=0)
    return (xmin, xmax, ymin, ymax)

def _bbox_area_um2(window_bbox) -> float:
    xmin, xmax, ymin, ymax = window_bbox
    return float((xmax - xmin) * (ymax - ymin))

def _border_mask(points_um: np.ndarray, window_bbox, r_um: float) -> np.ndarray:
    xmin, xmax, ymin, ymax = window_bbox
    x, y = points_um[:, 0], points_um[:, 1]
    return (x >= xmin + r_um) & (x <= xmax - r_um) & (y >= ymin + r_um) & (y <= ymax - r_um)

def _query_ball_counts(tree: cKDTree, src_points: np.ndarray, r_um: float) -> np.ndarray:
    try:
        return tree.query_ball_point(src_points, r_um, return_length=True).astype(float)
    except TypeError:
        neigh = tree.query_ball_point(src_points, r_um)
        return np.array([len(v) for v in neigh], dtype=float)

def _K_self_um(points_um: np.ndarray, r_vals_um: np.ndarray, area_um2: float, window_bbox):
    n = len(points_um)
    if n < 2 or area_um2 <= 0 or window_bbox is None:
        return np.full_like(r_vals_um, np.nan, dtype=float), np.zeros_like(r_vals_um, dtype=int)

    tree = cKDTree(points_um)
    K = np.full_like(r_vals_um, np.nan, dtype=float)
    n_centres = np.zeros_like(r_vals_um, dtype=int)

    for i, r_um in enumerate(r_vals_um):
        mask = _border_mask(points_um, window_bbox, float(r_um))
        src = points_um[mask]
        m = len(src)
        n_centres[i] = m
        if m < 2:
            K[i] = np.nan
            continue
        counts = _query_ball_counts(tree, src, float(r_um)) - 1.0
        K[i] = area_um2 * counts.sum() / (m * (m - 1))
    return K, n_centres

def _K_cross_um(source_um: np.ndarray, target_um: np.ndarray, r_vals_um: np.ndarray, area_um2: float, window_bbox):
    n_s, n_t = len(source_um), len(target_um)
    if n_s == 0 or n_t == 0 or area_um2 <= 0 or window_bbox is None:
        return np.full_like(r_vals_um, np.nan, dtype=float), np.zeros_like(r_vals_um, dtype=int)

    tree_t = cKDTree(target_um)
    K = np.full_like(r_vals_um, np.nan, dtype=float)
    n_centres = np.zeros_like(r_vals_um, dtype=int)

    for i, r_um in enumerate(r_vals_um):
        mask = _border_mask(source_um, window_bbox, float(r_um))
        src = source_um[mask]
        m = len(src)
        n_centres[i] = m
        if m == 0:
            K[i] = np.nan
            continue
        counts = _query_ball_counts(tree_t, src, float(r_um))
        K[i] = area_um2 * counts.sum() / (m * n_t)
    return K, n_centres

def _L_minus_r_um(K_um2: np.ndarray, r_um: np.ndarray) -> np.ndarray:
    return np.sqrt(np.maximum(K_um2, 0.0) / np.pi) - r_um

def _plot_LminusR_survival(pat_df: pd.DataFrame, out_dir: Path, title: str, stem: str):
    fig, ax = plt.subplots(figsize=(10, 6))
    tmp = pat_df.dropna(subset=["SurvivalCategory"])
    for surv, sub in tmp.groupby("SurvivalCategory"):
        med = sub.groupby("r_um")["L_minus_r_um"].median()
        ax.plot(med.index, med.values, label=str(surv), color=SURV_PALETTE[str(surv)])
    ax.axhline(0, ls="--", lw=1, color="gray")
    ax.set_xlabel("r (µm)")
    ax.set_ylabel("L(r) − r (µm)  (CSR=0)")
    ax.set_title(title)
    ax.legend(title="Survival")
    fig.tight_layout()
    savefig_both(fig, out_dir / stem)
    plt.close(fig)

def run_ripley_module(
    final_data: pd.DataFrame,
    clinical: pd.DataFrame,
    area_lookup: dict,
    output_dir: Path,
    module_name: str,
    source_selector,
    target_selector,
    area_kind: str,
    min_source: int = 5,
    min_target: int = 5,
    make_plots: bool = True,
    stats_radii=(50, 100),
):
    out = Path(output_dir) / module_name
    ensure_dir(out)

    r_um = RIPLEY_R_UM
    core_dfs = []

    for (pat, core), grp in final_data.groupby(["Spot Id 1", "Spot Id 2"]):
        g = get_valid_um(grp)
        window_bbox = _core_window_bbox_um(g)
        if window_bbox is None:
            continue
        bbox_area = _bbox_area_um2(window_bbox)
        area_um2 = get_area_um2(area_lookup, pat, core, area_kind, bbox_area)

        src = source_selector(g)
        tgt = target_selector(g)

        if len(src) < min_source or len(tgt) < min_target:
            continue

        src_pts = src[["X_um", "Y_um"]].to_numpy()
        tgt_pts = tgt[["X_um", "Y_um"]].to_numpy()

        if src is tgt:
            K_um2, n_centres = _K_self_um(src_pts, r_um, area_um2, window_bbox)
        else:
            K_um2, n_centres = _K_cross_um(src_pts, tgt_pts, r_um, area_um2, window_bbox)

        Lmr_um = _L_minus_r_um(K_um2, r_um)

        K_um2  = np.where(n_centres >= MIN_CENTRES_RIPLEY, K_um2, np.nan)
        Lmr_um = np.where(n_centres >= MIN_CENTRES_RIPLEY, Lmr_um, np.nan)

        core_dfs.append(pd.DataFrame({
            "Spot Id 1": pat, "Spot Id 2": core,
            "r_um": r_um,
            "Area_um2_used": float(area_um2),
            "n_centres_used": n_centres.astype(int),
            "K_um2": K_um2,
            "L_minus_r_um": Lmr_um
        }))

    if not core_dfs:
        print(f"[{module_name}] No valid cores.")
        return

    core_df = pd.concat(core_dfs, ignore_index=True)
    core_df.to_csv(out / f"{module_name}_PerCore.csv", index=False)

    pat_df = (core_df.groupby(["Spot Id 1", "r_um"])[["K_um2", "L_minus_r_um"]]
              .median().reset_index()
              .merge(clinical[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left"))
    pat_df.to_csv(out / f"{module_name}_PerPatient.csv", index=False)

    if make_plots:
        _plot_LminusR_survival(pat_df, out, title=module_name.replace("_", " "), stem="LminusR_SurvivalStratified")

    for r0 in stats_radii:
        stats_by_group(pat_df[np.isclose(pat_df["r_um"], r0)], "SurvivalCategory", "L_minus_r_um", out, f"LminusR_r{r0}")

