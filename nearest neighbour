    stats_on: str = "norm",
):
    outdir = Path(outdir)
    ensure_dir(outdir)

    required = {"Spot Id 1", "Spot Id 2", "X_um", "Y_um", phenotype_col}
    miss = required - set(final_data.columns)
    if miss:
        raise ValueError(f"final_data missing required columns: {sorted(miss)}")

    phenos_in_data = sorted(final_data[phenotype_col].dropna().unique())
    if not phenos_in_data:
        print("[Stage10] No phenotypes found.")
        return

    plot_order = build_plot_order(phenos_in_data, group_order)
    sanity_report(phenotype_col, phenos_in_data, group_order, cell_type_map)

    ph_to_idx = {ph: i for i, ph in enumerate(phenos_in_data)}
    P = len(phenos_in_data)

    roi_mats_raw, roi_mats_norm, roi_qc_rows = {}, {}, []

    for roi, sub in final_data.groupby("Spot Id 2"):
        sub = sub.dropna(subset=["X_um", "Y_um", phenotype_col]).reset_index(drop=True)
        n = len(sub)
        if n < 2:
            continue

        coords = sub[["X_um", "Y_um"]].to_numpy(dtype=float)
        tree = cKDTree(coords)

        k_query = min(k_nn + 1, n)
        dists, nbrs = tree_query(tree, coords, k=k_query)
        if k_query <= 1:
            continue

        i_idx = np.repeat(np.arange(n), k_query - 1)
        j_idx = nbrs[:, 1:].reshape(-1)
        d_flat = dists[:, 1:].reshape(-1)

        m = d_flat <= float(radius_um)
        i_idx = i_idx[m]
        j_idx = j_idx[m]

        if i_idx.size == 0:
            mat_raw = pd.DataFrame(0.0, index=phenos_in_data, columns=phenos_in_data)
            roi_mats_raw[roi] = mat_raw
            roi_mats_norm[roi] = normalize_matrix(mat_raw) if normalize else mat_raw
            roi_qc_rows.append({"Spot Id 2": roi, "n_cells": n, "n_relations_kept": 0, "n_unique_edges": 0, "total_matrix_sum": 0.0})
            continue

        if undirected:
            a = np.minimum(i_idx, j_idx)
            b = np.maximum(i_idx, j_idx)
            edges = np.unique(np.stack([a, b], axis=1), axis=0)
            ia, ib = edges[:, 0], edges[:, 1]
        else:
            ia, ib = i_idx, j_idx

        ph_codes = sub[phenotype_col].map(ph_to_idx).to_numpy()
        pha, phb = ph_codes[ia], ph_codes[ib]

        mat_np = np.zeros((P, P), dtype=float)
        np.add.at(mat_np, (pha, phb), 1.0)
        if undirected:
            off = pha != phb
            np.add.at(mat_np, (phb[off], pha[off]), 1.0)

        mat_raw = pd.DataFrame(mat_np, index=phenos_in_data, columns=phenos_in_data)
        mat_norm = normalize_matrix(mat_raw) if normalize else mat_raw

        roi_mats_raw[roi] = mat_raw
        roi_mats_norm[roi] = mat_norm
        roi_qc_rows.append({
            "Spot Id 2": roi,
            "n_cells": n,
            "n_relations_kept": int(i_idx.size),
            "n_unique_edges": int(len(ia)) if undirected else int(i_idx.size),
            "total_matrix_sum": float(mat_raw.values.sum()),
        })

    if not roi_mats_raw:
        print("[Stage10] No interaction matrices computed.")
        return

    pd.DataFrame(roi_qc_rows).sort_values(["n_cells", "n_unique_edges"], ascending=False).to_csv(outdir / "ROI_QC.csv", index=False)

    totals_raw = {roi: m.values.sum() for roi, m in roi_mats_raw.items()}
    median_total = np.median(list(totals_raw.values()))
    rep_roi = min(totals_raw, key=lambda r: abs(totals_raw[r] - median_total))
    rep_raw = roi_mats_raw[rep_roi]
    rep_norm = roi_mats_norm[rep_roi]

    # Representative plots: TRIANGLE + coolwarm (match your correlation triangle request)
    plot_heatmap_df(rep_raw,  outdir / f"Representative_Heatmap_RAW_{rep_roi}.png",
                    title=f"Representative Heatmap (RAW) — ROI {rep_roi} ({phenotype_col})",
                    order=plot_order, cmap="coolwarm", cbar_label="Contact count", figsize=(12, 10),
                    triangle=True, triangle_side="lower")

    plot_heatmap_df(rep_norm, outdir / f"Representative_Heatmap_NORM_{rep_roi}.png",
                    title=f"Representative Heatmap (NORM) — ROI {rep_roi} ({phenotype_col})",
                    order=plot_order, cmap="coolwarm", cbar_label="Proportion", figsize=(12, 10),
                    triangle=True, triangle_side="lower")

    plot_network_from_adjacency(rep_norm, outdir / f"Representative_Network_NORM_{rep_roi}.png",
                                title=f"Representative Network (NORM) — ROI {rep_roi} ({phenotype_col})",
                                order=plot_order, cell_type_map=cell_type_map, cat_colors=cat_colors)

    # patient averaging (ROI-equal weights)
    roi2pt = final_data.groupby("Spot Id 2")["Spot Id 1"].agg(lambda x: x.mode().iat[0] if not x.mode().empty else x.iloc[0]).to_dict()
    pt_raw_list, pt_norm_list = {}, {}
    for roi in roi_mats_raw.keys():
        pt = roi2pt.get(roi)
        if pd.notna(pt):
            pt_raw_list.setdefault(pt, []).append(roi_mats_raw[roi])
            pt_norm_list.setdefault(pt, []).append(roi_mats_norm[roi])

    pt_raw = {pt: average_mats(mats) for pt, mats in pt_raw_list.items()}
    pt_norm = {pt: average_mats(mats) for pt, mats in pt_norm_list.items()}

    pd.DataFrame([{"Spot Id 1": pt, "n_rois": len(pt_raw_list[pt])} for pt in pt_raw_list]) \
      .sort_values("n_rois", ascending=False).to_csv(outdir / "Patient_QC.csv", index=False)

    # survival stratified averages (patient-level)
    pt2surv = clinical_df.set_index("Spot Id 1")["SurvivalCategory"].to_dict()
    strat_raw = {k: [] for k in SURV_ORDER}
    strat_norm = {k: [] for k in SURV_ORDER}

    for pt in pt_raw.keys():
        cat = pt2surv.get(pt)
        if pd.notna(cat):
            strat_raw[str(cat)].append(pt_raw[pt])
            strat_norm[str(cat)].append(pt_norm[pt])

    strat_avg_raw = {cat: (average_mats(mats) if mats else pd.DataFrame(0.0, index=phenos_in_data, columns=phenos_in_data))
                     for cat, mats in strat_raw.items()}
    strat_avg_norm = {cat: (average_mats(mats) if mats else pd.DataFrame(0.0, index=phenos_in_data, columns=phenos_in_data))
                      for cat, mats in strat_norm.items()}

    for cat in SURV_ORDER:
        plot_heatmap_df(strat_avg_raw[cat], outdir / f"Heatmap_RAW_{cat}.png",
                        title=f"Heatmap (RAW) — {cat} Survival Avg ({phenotype_col})",
                        order=plot_order, cmap="coolwarm", cbar_label="Contact count", figsize=(12, 10),
                        triangle=True, triangle_side="lower")

        plot_heatmap_df(strat_avg_norm[cat], outdir / f"Heatmap_NORM_{cat}.png",
                        title=f"Heatmap (NORM) — {cat} Survival Avg ({phenotype_col})",
                        order=plot_order, cmap="coolwarm", cbar_label="Proportion", figsize=(12, 10),
                        triangle=True, triangle_side="lower")

        plot_network_from_adjacency(strat_avg_norm[cat], outdir / f"Network_NORM_{cat}.png",
                                    title=f"Network (NORM) — {cat} Survival Avg ({phenotype_col})",
                                    order=plot_order, cell_type_map=cell_type_map, cat_colors=cat_colors)

    # stats (patient-level matrices)
    strat_for_stats = strat_norm if stats_on == "norm" else strat_raw
    results = []
    for i, ph1 in enumerate(phenos_in_data):
        for j, ph2 in enumerate(phenos_in_data):
            if j < i:
                continue
            data = []
            for cat in SURV_ORDER:
                vals = [m.at[ph1, ph2] for m in strat_for_stats[cat] if (ph1 in m.index and ph2 in m.columns)]
                data.append(vals)
            if all(len(d) > 1 for d in data):
                _, p = kruskal(*data)
                results.append({"Pheno1": ph1, "Pheno2": ph2, "KW_p": p, "StatsOn": stats_on})

    df_stats = pd.DataFrame(results)
    if not df_stats.empty:
        df_stats["KW_p_FDR"] = multipletests(df_stats["KW_p"], method="fdr_bh")[1]
        df_stats.to_csv(outdir / "Interaction_Survival_Stats.csv", index=False)

    pd.Series(phenos_in_data, name=f"Unique_{phenotype_col}").to_csv(outdir / f"Unique_{phenotype_col}.csv", index=False)
    print(f"[DONE] Stage10 complete (µm-native). Outputs: {outdir}")


