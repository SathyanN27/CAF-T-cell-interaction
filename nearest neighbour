# ===================== STAGE 14b: Tumour -> CAF nearest-cell distance (patient-level) =====================
def stage14b_tumour_caf_distance_um(final_data, clinical, output_dir):
    """
    Nearest-cell distances via cKDTree.query(k=1):
      For each tumour cell, distance to nearest CAF (any) OR nearest CAF subtype.
    Then per-core median -> per-patient median-of-cores.

    Outputs:
      A) Any CAF by survival (patient)
      B) CAF subtype by survival (patient)
      C) Across CAF subtypes pooled across survival (patient; grouped by CAF_Subtype)
    """
    out_base = Path(output_dir) / "Stage14b_TumorCAF_Distance_um"
    ensure_dir(out_base)

    df = get_valid_um(final_data)
    caf_all = df[df["Main_Cell_Type"] == "CAF"].copy()
    tumor_all = df[df["Main_Cell_Type"] == "Tumour"].copy()

    # ---------------- A) Any CAF (per-core) ----------------
    core_rows = []
    for (pat, core), grp in df.groupby(["Spot Id 1", "Spot Id 2"]):
        tum = grp[grp["Main_Cell_Type"] == "Tumour"]
        caf = grp[grp["Main_Cell_Type"] == "CAF"]
        if tum.empty or caf.empty:
            continue
        tree = cKDTree(caf[["X_um", "Y_um"]].to_numpy())
        d_um, _ = tree_query(tree, tum[["X_um", "Y_um"]].to_numpy(), k=1)
        core_rows.append({
            "Spot Id 1": str(pat).strip(),
            "Spot Id 2": str(core).strip(),
            "N_tumour": int(len(d_um)),
            "Median_Distance_um": float(np.median(d_um)),
        })

    df_core_any = pd.DataFrame(core_rows)
    df_core_any.to_csv(out_base / "TumorToAnyCAF_PerCore.csv", index=False)

    if df_core_any.empty:
        print("[14b] No tumour–CAF distances computed (any CAF).")
        return

    # patient median-of-cores
    med_pt = core_to_patient_median(df_core_any, value_cols="Median_Distance_um")
    med_pt = med_pt.merge(clinical[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")
    med_pt.to_csv(out_base / "TumorToAnyCAF_PerPatient_MedianOfCores.csv", index=False)

    stats_by_group(med_pt, "SurvivalCategory", "Median_Distance_um", out_base, "TumorToAnyCAF_bySurvival")
    plot_box_with_points(
        med_pt, x="SurvivalCategory", y="Median_Distance_um",
        outpath=out_base / "Boxplot_TumorToAnyCAF_bySurvival.png",
        title="Tumour→Any CAF nearest distance (µm) per patient (median-of-cores) by Survival",
        order=SURV_ORDER, palette=SURV_PALETTE, rotate=0, point_size=3, point_alpha=0.25
    )

    # ---------------- B) CAF subtype (per-core) ----------------
    out_sub = Path(output_dir) / "Stage14b_TumorCAF_ByCAFSubtype_um"
    ensure_dir(out_sub)

    rec = []
    for caf_type in CAF_DETAILED:
        caf_pts_type = caf_all[caf_all["Detailed_Phenotype"] == caf_type]
        for (pat, core), tum_pts in tumor_all.groupby(["Spot Id 1", "Spot Id 2"]):
            caf = caf_pts_type[(caf_pts_type["Spot Id 1"] == pat) & (caf_pts_type["Spot Id 2"] == core)]
            if tum_pts.empty or caf.empty:
                continue
            tree = cKDTree(caf[["X_um", "Y_um"]].to_numpy())
            d_um, _ = tree_query(tree, tum_pts[["X_um", "Y_um"]].to_numpy(), k=1)
            rec.append({
                "Spot Id 1": str(pat).strip(),
                "Spot Id 2": str(core).strip(),
                "CAF_Subtype": caf_type,
                "N_tumour": int(len(d_um)),
                "Median_Distance_um": float(np.median(d_um)),
            })

    df_core_sub = pd.DataFrame(rec)
    df_core_sub.to_csv(out_sub / "TumorToCAFSubtype_PerCore.csv", index=False)

    if not df_core_sub.empty:
        df_pt_sub = core_to_patient_median(df_core_sub,
                                           value_cols="Median_Distance_um",
                                           extra_group_cols=["CAF_Subtype"])
        df_pt_sub = df_pt_sub.merge(clinical[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")
        df_pt_sub.to_csv(out_sub / "TumorToCAFSubtype_PerPatient_MedianOfCores.csv", index=False)

        # subtype-by-survival plots + stats
        for caf_type in ordered_subset(df_pt_sub["CAF_Subtype"].dropna().unique().tolist(), CAF_DETAILED):
            sub = df_pt_sub[df_pt_sub["CAF_Subtype"] == caf_type].copy()
            if sub.empty:
                continue
            plot_box_with_points(
                sub, x="SurvivalCategory", y="Median_Distance_um",
                outpath=out_sub / f"Boxplot_TumorTo_{sanitize(caf_type)}_bySurvival.png",
                title=f"Tumour→{caf_type} nearest distance (µm) per patient (median-of-cores) by Survival",
                order=SURV_ORDER, palette=SURV_PALETTE, rotate=0, point_size=3, point_alpha=0.25
            )
            stats_by_group(sub, "SurvivalCategory", "Median_Distance_um", out_sub, f"TumorTo_{sanitize(caf_type)}_bySurvival")

        # ---------------- C) Across CAF subtypes pooled across survival ----------------
        pooled = df_pt_sub.dropna(subset=["CAF_Subtype", "Median_Distance_um"]).copy()
        pooled.to_csv(out_sub / "TumorToCAFSubtype_PooledAcrossSurvival_PerPatient.csv", index=False)

        plot_box_with_points(
            pooled, x="CAF_Subtype", y="Median_Distance_um",
            outpath=out_sub / "Boxplot_TumorToCAFSubtype_PooledAcrossSurvival.png",
            title="Tumour→CAF subtype nearest distance (µm) per patient (median-of-cores), pooled across survival",
            order=ordered_subset(pooled["CAF_Subtype"].unique().tolist(), CAF_DETAILED),
            palette=None, rotate=90, point_size=3, point_alpha=0.25
        )
        stats_by_group(pooled, "CAF_Subtype", "Median_Distance_um", out_sub, "TumorToCAFSubtype_PooledAcrossSurvival")

    print("[14b] Complete.")


# ===================== STAGE 14c: First neighbour identity (kept) =====================
def stage14c_first_neighbor_identity_um(final_data, clinical, output_dir):
    out = Path(output_dir) / "Stage14c_FirstNeighbor_Identity_um"
    ensure_dir(out)

    valid = get_valid_um(final_data)
    tumor = valid[valid["Main_Cell_Type"] == "Tumour"]
    other = valid[valid["Main_Cell_Type"] != "Tumour"]

    rec = []
    for (pat, core), tum_grp in tumor.groupby(["Spot Id 1", "Spot Id 2"]):
        oth = other[(other["Spot Id 1"] == pat) & (other["Spot Id 2"] == core)]
        if tum_grp.empty or oth.empty:
            continue
        tree = cKDTree(oth[["X_um", "Y_um"]].to_numpy())
        d_um, idx = tree_query(tree, tum_grp[["X_um", "Y_um"]].to_numpy(), k=1)

        oth = oth.reset_index(drop=True)
        for i in range(len(d_um)):
            nbr = oth.iloc[int(idx[i])]
            nd = canonicalize_detailed_pheno(nbr.get("Detailed_Phenotype", np.nan))
            if pd.isna(nd):
                continue
            rec.append({
                "Spot Id 1": str(pat).strip(),
                "Spot Id 2": str(core).strip(),
                "Neighbor_Distance_um": float(d_um[i]),
                "Neighbor_Detailed": nd,
                "Neighbor_MainType": str(nbr.get("Main_Cell_Type", "")).strip(),
            })

    df = pd.DataFrame(rec).merge(clinical[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left")
    df.to_csv(out / "Tumor_FirstNeighbors_PerCell_um.csv", index=False)
    if df.empty:
        print("[14c] No neighbours computed.")
        return

    core_comp = df.groupby(["Spot Id 1", "Spot Id 2", "Neighbor_Detailed"]).size().unstack(fill_value=0)
    core_comp = core_comp.div(core_comp.sum(axis=1), axis=0).reset_index()
    core_comp.to_csv(out / "NeighborDetailed_Composition_PerCore.csv", index=False)

    ph_cols = [c for c in core_comp.columns if c not in {"Spot Id 1", "Spot Id 2"}]
    ph_cols = ordered_subset(ph_cols, GROUP_ORDER_DETAILED)

    pat_comp = (core_comp.groupby("Spot Id 1")[ph_cols].median().reset_index()
                .merge(clinical[["Spot Id 1", "SurvivalCategory"]], on="Spot Id 1", how="left"))
    pat_comp.to_csv(out / "NeighborDetailed_Composition_PerPatient_MedianOfCores.csv", index=False)

    for ph in ph_cols:
        plot_box_with_points(
            pat_comp, x="SurvivalCategory", y=ph,
            outpath=out / f"Boxplot_Detailed_{sanitize(ph)}_bySurvival.png",
            title=f"Nearest-neighbour composition (median-of-cores): {ph}",
            order=SURV_ORDER, palette=SURV_PALETTE, rotate=0, point_size=3, point_alpha=0.25
        )
        stats_by_group(pat_comp, "SurvivalCategory", ph, out, f"NeighborDetailed_{sanitize(ph)}")

    plot_df = pat_comp.set_index("Spot Id 1")[ph_cols]
    plot_heatmap_df(plot_df, out / "Heatmap_NeighborDetailed_Composition_PerPatient.png",
                    title="Tumour nearest-neighbour composition (per-patient median-of-cores)",
                    cmap="mako", figsize=(min(22, 2 + 0.45 * len(ph_cols)), 8), linewidths=0.3)


