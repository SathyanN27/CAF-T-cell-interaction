# ===================== UTILITIES =====================
def ensure_dir(path) -> None:
    Path(path).mkdir(parents=True, exist_ok=True)

def safe_name(x) -> str:
    return re.sub(r"[^A-Za-z0-9]+", "_", str(x))

def sanitize(x: str) -> str:
    return str(x).replace("/", "_").replace(" ", "_").replace("(", "").replace(")", "").replace(":", "")

def save_plot(path, dpi: int = 300) -> None:
    plt.tight_layout()
    plt.savefig(path, dpi=dpi, bbox_inches="tight")
    plt.close()

def savefig_both(fig: plt.Figure, out_base: Path) -> None:
    fig.savefig(str(out_base) + ".png", dpi=300, bbox_inches="tight")
    fig.savefig(str(out_base) + ".pdf", bbox_inches="tight")

def ordered_subset(values, order_list):
    values = [v for v in values if pd.notna(v)]
    s = set(values)
    ordered = [v for v in order_list if v in s]
    tail = sorted([v for v in values if v not in set(ordered)])
    return ordered + tail

def canonicalize_detailed_pheno(x):
    if pd.isna(x):
        return np.nan
    s = str(x).strip()
    s = " ".join(s.split())
    low = s.lower()
    if low in {"other immune", "other_immune", "otherimmune", "other-immune", "other immune "}:
        return "other immune"
    if low in {"b cell", "bcell", "b-cell"}:
        return "B Cell"
    if low in {"triple negative", "tripple negative", "triple_negative", "triple-negative"}:
        return "Triple negative"
    return s

def _norm_core_id(x) -> str:
    if pd.isna(x):
        return ""
    s = str(x).strip()
    try:
        f = float(s)
        if np.isfinite(f) and abs(f - round(f)) < 1e-9:
            return str(int(round(f)))
    except Exception:
        pass
    if s.endswith(".0"):
        s = s[:-2]
    return s

def resolve_path(path_or_name: str, fallback_candidates=None) -> str:
    tried = []
    p = Path(path_or_name)
    tried.append(str(p))
    if p.exists():
        return str(p)
    if fallback_candidates:
        for cand in fallback_candidates:
            pc = Path(cand)
            tried.append(str(pc))
            if pc.exists():
                print(f"[Path] Using fallback: {pc}")
                return str(pc)
    raise FileNotFoundError("Could not find input file. Tried:\n" + "\n".join(f"  - {t}" for t in tried))

def tree_query(tree: cKDTree, pts: np.ndarray, k=1):
    if KD_WORKERS_ALL:
        try:
            return tree.query(pts, k=k, workers=-1)
        except TypeError:
            pass
    return tree.query(pts, k=k)

def get_valid_um(df: pd.DataFrame) -> pd.DataFrame:
    return df.dropna(subset=["X_um", "Y_um"]).copy()

def get_cell_id_series(df: pd.DataFrame) -> pd.Series:
    return df["CellID"] if "CellID" in df.columns else pd.Series(df.index.values, index=df.index)

def _canon(s: str) -> str:
    s = str(s).strip().lower()
    s = re.sub(r"[^a-z0-9]+", "", s)
    return s

def find_column(df: pd.DataFrame, candidates):
    can = {_canon(c): c for c in df.columns}
    for cand in candidates:
        k = _canon(cand)
        if k in can:
            return can[k]
    return None

def average_mats(mats):
    acc = mats[0].copy()
    for m in mats[1:]:
        acc = acc.add(m, fill_value=0)
    return acc / float(len(mats))

def normalize_matrix(mat: pd.DataFrame) -> pd.DataFrame:
    total = mat.values.sum()
    return mat if total == 0 else mat / total

def build_plot_order(values_in_data, preferred_order=None):
    values_in_data = list(values_in_data)
    if preferred_order is None:
        return values_in_data
    preferred = [v for v in preferred_order if v in values_in_data]
    remaining = [v for v in values_in_data if v not in set(preferred)]
    return preferred + remaining

def sanity_report(phenotype_col, values_in_data, group_order, cell_type_map):
    values_in_data = set(values_in_data)
    if group_order is not None:
        group_order = list(group_order)
        missing_in_order = sorted([v for v in values_in_data if v not in set(group_order)])
        extra_in_order = sorted([v for v in group_order if v not in values_in_data])
        if extra_in_order:
            print(f"[WARN] group_order has values not in {phenotype_col}: {extra_in_order}")
        if missing_in_order:
            print(f"[INFO] {phenotype_col} values not in group_order; appended: {missing_in_order}")
    if cell_type_map is not None:
        missing_in_map = sorted([v for v in values_in_data if v not in cell_type_map])
        if missing_in_map:
            print(f"[WARN] cell_type_map missing phenotypes (colored as Other): {missing_in_map}")

def mannwhitney_safe(a, b):
    a = pd.Series(a).dropna().values
    b = pd.Series(b).dropna().values
    if len(a) < 2 or len(b) < 2:
        return np.nan
    try:
        return float(mannwhitneyu(a, b, alternative="two-sided").pvalue)
    except Exception:
        return np.nan

def kruskal_safe(groups_dict, order=SURV_ORDER):
    vals = []
    for k in order:
        v = pd.Series(groups_dict.get(k, [])).dropna().values
        if len(v) > 0:
            vals.append(v)
    if len(vals) < 2:
        return np.nan
    try:
        return float(kruskal(*vals).pvalue)
    except Exception:
        return np.nan

def core_to_patient_median(df: pd.DataFrame,
                           value_cols,
                           extra_group_cols=None,
                           patient_col="Spot Id 1",
                           core_col="Spot Id 2") -> pd.DataFrame:
    """
    Collapse core-level -> patient-level as:
      per-core median (if multiple rows per core), then
      patient median across cores.
    """
    if extra_group_cols is None:
        extra_group_cols = []
    if isinstance(value_cols, str):
        value_cols = [value_cols]

    df = df.copy()
    df[patient_col] = df[patient_col].astype(str).str.strip()
    df[core_col] = df[core_col].astype(str).str.strip()

    grp_core = [patient_col, core_col] + list(extra_group_cols)
    core_med = df.groupby(grp_core, as_index=False)[value_cols].median()

    grp_pt = [patient_col] + list(extra_group_cols)
    pt_med = core_med.groupby(grp_pt, as_index=False)[value_cols].median()

    return pt_med


